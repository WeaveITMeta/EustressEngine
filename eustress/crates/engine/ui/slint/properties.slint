// ============================================================================
// Eustress Engine Studio - Properties Panel
// Dynamic property editor for selected entities
// ============================================================================

import { VerticalBox, HorizontalBox, LineEdit, ScrollView, CheckBox, Slider, ComboBox, SpinBox, GridBox } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { TagsEditor, TagChip, TagSuggestion } from "tags_editor.slint";

// One categorical-picker swatch as fed from Rust: a display name plus the
// 0-255 sRGB channels. Shared between the Properties panel and the ribbon's
// status-bar color widget (both render it through `ColorSwatchCell`).
export struct ColorEntry {
    name: string,
    r: int,
    g: int,
    b: int,
}

// One cell of a BrickColor wheel's 127-cell hexagon honeycomb. Pushed from
// Rust (`eustress_common::color_wheels::wheel_honeycomb`) into the Properties
// BrickColor picker. `x`/`y` are precomputed px offsets inside the 286x264
// honeycomb box so the layout lives in the data, not in a Slint expression.
export struct HoneycombCell {
    name: string,
    r: int,
    g: int,
    b: int,
    x: float,
    y: float,
}

// Property data structure
export struct PropertyData {
    name: string,
    value: string,
    property-type: string, // "string", "float", "int", "bool", "vec3", "color", "enum"
    category: string,
    editable: bool,
    options: [string], // For enum types
    // Section header flag: if true, this entry is a category header (not a property)
    is-header: bool,
    // When true, this property's section is collapsed and the row should be hidden
    section-collapsed: bool,
    // Vec3 parsed values (populated by Rust for vec3 types)
    x-value: string,
    y-value: string,
    z-value: string,
    // UDim2 parsed values (populated by Rust for udim2 types).
    // Order matches the on-disk canonical 4-tuple
    // `[scale_x, offset_x, scale_y, offset_y]`.
    x-scale: string,
    x-offset: string,
    y-scale: string,
    y-offset: string,
    // Color preview swatch — populated by Rust for color rows. Slint
    // can't parse the "r, g, b" string at runtime, so we pre-compute a
    // typed `color` here for the chip background.
    color-value: color,
    // Help tooltip text from TOML description field (empty = no icon shown)
    description: string,
    // URL path for the /learn documentation link (e.g. "/learn/atmosphere#density")
    learn-url: string,
    // Custom-attribute UX: when true this row is a user [attributes] entry and
    // gets the Roblox-style gear (change type) + red trash (delete) controls.
    is-attribute: bool,
    // AttributeValue type name for an attribute row (e.g. "String", "Number",
    // "Vector3", "Color3"). Shown as a small badge and used to prefill the
    // edit dialog's type dropdown.
    attribute-type: string,
}

// Help icon button — shown left of property label when description is present.
// Displays a tooltip on hover; on click opens the /learn documentation page.
// Color: grey by default, turns blue (accent) when description has a learn-url.
export component HelpIcon inherits Rectangle {
    in property <string> description: "";
    in property <string> learn-url: "";
    in property <bool> show-help-icons: true;

    callback open-learn-url(string);

    width: show-help-icons && description != "" ? 18px : 0px;
    height: 18px;
    visible: show-help-icons && description != "";

    // Tooltip popup — uses PopupWindow so it renders above all panels
    help-popup := PopupWindow {
        x: 20px;
        y: -6px;
        width: min(300px, max(120px, description.character-count * 6.5px + 20px));
        height: tip-text.preferred-height + 12px;

        Rectangle {
            background: Theme.panel-background;
            border-radius: 4px;
            border-width: 1px;
            border-color: learn-url != "" ? Theme.accent-blue : Theme.border-color;
            drop-shadow-blur: 8px;
            drop-shadow-color: #00000060;

            tip-text := Text {
                x: 8px;
                y: 6px;
                width: parent.width - 16px;
                text: description;
                color: Theme.text-primary;
                font-size: 11px;
                wrap: word-wrap;
            }
        }
    }

    tip-area := TouchArea {
        mouse-cursor: learn-url != "" ? pointer : default;
        clicked => {
            if root.learn-url != "" {
                root.open-learn-url(root.learn-url);
            }
        }
        moved => {
            if self.has-hover && root.description != "" {
                help-popup.show();
            }
        }
    }

    // Icon circle — grey when no URL, blue when has URL
    Rectangle {
        width: 14px;
        height: 14px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-radius: 7px;
        background: tip-area.has-hover && learn-url != "" ? Theme.accent-blue
                  : tip-area.has-hover ? #3a3a3a
                  : learn-url != "" ? #1e4a7a
                  : #2a2a2a;
        border-width: 1px;
        border-color: tip-area.has-hover && learn-url != "" ? Theme.accent-blue
                    : learn-url != "" ? Theme.accent-blue
                    : #444444;

        Text {
            text: "?";
            color: learn-url != "" ? white : Theme.text-secondary;
            font-size: 9px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

// Collapsible section header - polished with gradient and better typography
component SectionHeader inherits Rectangle {
    in property <string> title: "";
    in property <string> category: "";
    in-out property <bool> expanded: true;

    // Fired when chevron is clicked so parent can update model state
    callback clicked();
    // Fired when the "+" add button (Attributes section only) is clicked
    callback add-clicked();

    height: 32px;
    background: @linear-gradient(180deg, #252525 0%, #1e1e1e 100%);

    // Bottom border line
    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: #333333;
    }

    header-ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            // Do NOT toggle root.expanded locally — Rust is the single source of truth.
            // The callback fires on-section-toggle → Rust toggles collapsed_sections →
            // next sync pushes updated section-collapsed → expanded binding updates.
            root.clicked();
        }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 8px;
        spacing: 8px;

        // Chevron with smooth rotation feel
        Text {
            width: 14px;
            text: root.expanded ? "▼" : "▶";
            color: root.expanded ? Theme.accent-blue : Theme.text-secondary;
            font-size: 8px;
            vertical-alignment: center;
            horizontal-alignment: center;
        }

        Text {
            text: root.title;
            color: Theme.text-primary;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.3px;
            vertical-alignment: center;
        }

        // Spacer
        Rectangle { horizontal-stretch: 1; }

        // "+" add button — Attributes section only. Roblox-style: opens the
        // Add-Attribute modal (name + type + initial value).
        if root.category == "Attributes": Rectangle {
            width: 20px;
            height: 20px;
            y: (parent.height - self.height) / 2;
            border-radius: 4px;
            background: add-ta.has-hover ? Theme.accent-blue : #2e2e2e;
            border-width: 1px;
            border-color: add-ta.has-hover ? Theme.accent-blue : #3a3a3a;

            add-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.add-clicked(); }
            }
            Text {
                text: "+";
                color: add-ta.has-hover ? white : Theme.text-secondary;
                font-size: 14px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // Item count badge (visual polish)
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 6px;
                height: 6px;
                border-radius: 3px;
                background: root.expanded ? Theme.accent-blue : #444444;
            }
        }
    }
}

// Searchable material dropdown with scroll — shows all MaterialService options.
// Supports keyboard navigation: arrow keys move highlight, Enter confirms,
// letter keys jump to the first option starting with that letter (type-ahead).
// No visible text input — keys are consumed silently for fast selection.
component MaterialDropdown inherits Rectangle {
    in property <string> label: "Material";
    in property <string> value: "Plastic";
    in property <[string]> options: [];
    in property <bool> editable: true;
    in property <string> description: "";
    in property <string> learn-url: "";
    in property <bool> show-help-icons: true;

    callback value-changed(string);
    callback open-learn-url(string);
    callback focus-changed(bool);
    // Type-ahead callback — Rust side finds matching option index.
    // Arguments: (pressed-key, current-highlight-index) -> new-index
    callback find-material-by-key(string, int) -> int;

    property <bool> dropdown-open: false;
    // Keyboard-highlighted option index (-1 = none)
    property <int> highlight-index: -1;

    height: 28px;
    border-radius: 2px;

    // Bubble focus state up so the Bevy keybind gate
    // (`text_input_focused`) sees the dropdown as a focused input
    // when it has keyboard focus or its popup is open. Without this
    // the Material / Unit rows silently lost the focus signal and
    // global Delete/Backspace shortcuts fired through.
    out property <bool> has-focus: mat-focus.has-focus || root.dropdown-open;
    changed has-focus => { root.focus-changed(self.has-focus); }

    mat-focus := FocusScope {
        key-pressed(event) => {
            if event.text == Key.DownArrow && root.dropdown-open {
                if root.highlight-index < root.options.length - 1 { root.highlight-index += 1; }
                else { root.highlight-index = 0; }
                return accept;
            }
            if event.text == Key.UpArrow && root.dropdown-open {
                if root.highlight-index > 0 { root.highlight-index -= 1; }
                else { root.highlight-index = root.options.length - 1; }
                return accept;
            }
            if event.text == Key.Return {
                if root.dropdown-open {
                    if root.highlight-index >= 0 && root.highlight-index < root.options.length {
                        root.value-changed(root.options[root.highlight-index]);
                    }
                    root.dropdown-open = false;
                    root.highlight-index = -1;
                    dropdown-popup.close();
                } else {
                    root.dropdown-open = true;
                    root.highlight-index = 0;
                    dropdown-popup.show();
                }
                return accept;
            }
            if event.text == Key.Escape && root.dropdown-open {
                root.dropdown-open = false;
                root.highlight-index = -1;
                dropdown-popup.close();
                return accept;
            }
            // Type-ahead: any other key calls Rust to find matching option
            if root.dropdown-open {
                if event.text == Key.Shift { return reject; }
                if event.text == Key.Control { return reject; }
                if event.text == Key.Alt { return reject; }
                root.highlight-index = root.find-material-by-key(event.text, root.highlight-index);
                return accept;
            }
            return reject;
        }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 10px;
        spacing: 4px;

        HelpIcon {
            description: root.description;
            learn-url: root.learn-url;
            show-help-icons: root.show-help-icons;
            open-learn-url(url) => { root.open-learn-url(url); }
        }

        Text {
            width: 110px;
            text: root.label;
            color: Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }

        // Dropdown button
        Rectangle {
            horizontal-stretch: 1;
            height: 22px;
            background: mat-btn-touch.has-hover ? Theme.explorer-item-hover : Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: root.dropdown-open ? Theme.accent-blue : (mat-focus.has-focus ? Theme.accent-blue : Theme.input-border);

            mat-btn-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    mat-focus.focus();
                    root.dropdown-open = !root.dropdown-open;
                    if root.dropdown-open {
                        root.highlight-index = 0;
                        dropdown-popup.show();
                    } else {
                        root.highlight-index = -1;
                        dropdown-popup.close();
                    }
                }
            }

            HorizontalLayout {
                padding-left: 6px;
                padding-right: 6px;
                spacing: 4px;
                alignment: center;

                Text {
                    text: root.value;
                    color: Theme.text-primary;
                    font-size: 11px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
            }
        }
    }
    } // close FocusScope

    // Dropdown popup — uses PopupWindow to render above all other content
    dropdown-popup := PopupWindow {
        x: 112px;
        y: parent.height;
        width: parent.width - 120px;
        height: min(320px, root.options.length * 24px + 12px);

        Rectangle {
            background: #1e1e1e;
            border-radius: 6px;
            border-width: 1px;
            border-color: #3a3a3a;
            drop-shadow-blur: 12px;
            drop-shadow-color: #00000080;
            width: 100%;
            height: 100%;

        // Must be above other properties
        // Prevent clicks from going through to viewport
        TouchArea { }

        VerticalLayout {
            padding: 4px;
            spacing: 2px;

            // Scrollable option list
            ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    spacing: 1px;

                    for option[idx] in root.options: Rectangle {
                        height: 24px;
                        // Highlight keyboard-navigated row, hover row, or selected row
                        background: idx == root.highlight-index ? #4a4a4a : (opt-touch.has-hover ? #3a3a3a : (option == root.value ? #2a2a2a : transparent));
                        border-radius: 3px;

                        opt-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => {
                                root.value-changed(option);
                                root.dropdown-open = false;
                                root.highlight-index = -1;
                                dropdown-popup.close();
                            }
                        }

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 6px;

                            // Selected checkmark
                            Text {
                                width: 14px;
                                text: option == root.value ? "✓" : "";
                                color: Theme.accent-blue;
                                font-size: 11px;
                                vertical-alignment: center;
                            }

                            Text {
                                text: option;
                                color: (idx == root.highlight-index || option == root.value) ? Theme.accent-blue : Theme.text-primary;
                                font-size: 11px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }
            }
        }
        } // close inner Rectangle
    } // close PopupWindow

    // Close dropdown when clicking outside
    if root.dropdown-open: Rectangle {
        x: -1000px;
        y: -1000px;
        width: 10000px;
        height: 10000px;

        // This overlay behind the dropdown catches clicks outside
        TouchArea {
            clicked => {
                root.dropdown-open = false;
                root.highlight-index = -1;
            }
        }
    }
}

// Generic property row with label + value editor - polished design
component PropRow inherits Rectangle {
    in property <string> label: "";
    in property <string> value: "";
    in property <string> prop-type: "string";
    in property <bool> editable: true;
    in property <string> description: "";
    in property <string> learn-url: "";
    in property <bool> show-help-icons: true;
    // Roblox-style custom-attribute controls: when true, render a type badge,
    // a gear (change type / edit) icon, and a red trash (delete) icon.
    in property <bool> is-attribute: false;
    in property <string> attribute-type: "";

    // Expose focus state so parent can aggregate across all rows
    out property <bool> has-focus: input-edit.has-focus;

    // Fire focus-changed immediately on click-in / tab-out so the
    // Delete key doesn't delete the selected part while the user is
    // typing (relying on the `edited(text)` callback below missed
    // the pre-first-keystroke window).
    changed has-focus => { root.focus-changed(self.has-focus); }

    callback value-changed(string);
    callback open-learn-url(string);
    callback focus-changed(bool);
    // Attribute row: gear clicked → open edit dialog (passes name, type, value).
    callback gear-clicked(string, string, string);
    // Attribute row: trash clicked → delete this attribute (passes name).
    callback trash-clicked(string);

    // Hidden focus sink used by `accepted()` handlers to move focus away
    // from the LineEdit on Enter. Without this, pressing Enter commits the
    // value but the input keeps its focused-state highlight (blue border)
    // until the user clicks elsewhere. Sized 0×0 so it's invisible; sits
    // outside the layout so it doesn't claim space.
    focus_sink := FocusScope { width: 0px; height: 0px; }

    height: 28px;
    border-radius: 2px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 10px;
        spacing: 4px;

        // Help icon — only takes space when description is present
        HelpIcon {
            description: root.description;
            learn-url: root.learn-url;
            show-help-icons: root.show-help-icons;
            open-learn-url(url) => { root.open-learn-url(url); }
        }
        
        // Label — fixed width for consistent alignment
        Text {
            width: 110px;
            text: root.label;
            color: Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }
        
        // Value editor with refined styling — always present but visibility controlled
        Rectangle {
            horizontal-stretch: 1;
            height: 22px;
            visible: root.editable;
            background: Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: input-edit.has-focus ? Theme.accent-blue : Theme.input-border;
            
            input-edit := LineEdit {
                x: 0px;
                y: 0px;
                width: 100%;
                height: 100%;
                enabled: root.editable;
                text: root.value;
                // Fire `value-changed` on EVERY keystroke so the ECS
                // component (and therefore the renderer) updates live
                // as the user types. The drain handler writes TOML on
                // each call too — small files, sub-millisecond writes,
                // the recently-written debounce prevents reload loops.
                // Enter (accepted) re-fires for parity but is a no-op
                // since each keystroke already committed the same value.
                edited(text) => {
                    root.focus-changed(true);
                    root.value-changed(self.text);
                }
                accepted(text) => {
                    root.value-changed(self.text);
                    // Drop the LineEdit's focused state so the row no
                    // longer shows the active-input highlight.
                    focus_sink.focus();
                }
            }
        }

        if !root.editable: Text {
            horizontal-stretch: 1;
            text: root.value;
            color: Theme.text-primary;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }

        // ── Attribute controls (type badge + gear + trash) ──
        if root.is-attribute: HorizontalLayout {
            spacing: 3px;

            // Type badge
            Rectangle {
                width: 46px;
                height: 18px;
                y: (parent.height - self.height) / 2;
                border-radius: 9px;
                background: #2a3550;
                Text {
                    text: root.attribute-type;
                    color: Theme.accent-blue;
                    font-size: 8px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }

            // Gear (change type / edit) icon
            Rectangle {
                width: 20px;
                height: 20px;
                y: (parent.height - self.height) / 2;
                border-radius: 4px;
                background: gear-ta.has-hover ? #3a3a3a : transparent;
                gear-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.gear-clicked(root.label, root.attribute-type, root.value); }
                }
                Image {
                    width: 13px;
                    height: 13px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("../../assets/icons/ui/settings.svg");
                    image-fit: contain;
                    colorize: gear-ta.has-hover ? Theme.accent-blue : Theme.text-secondary;
                }
            }

            // Trash (delete) icon — red on hover
            Rectangle {
                width: 20px;
                height: 20px;
                y: (parent.height - self.height) / 2;
                border-radius: 4px;
                background: trash-ta.has-hover ? #5d1515 : transparent;
                trash-ta := TouchArea {
                    mouse-cursor: pointer;
                    clicked => { root.trash-clicked(root.label); }
                }
                Image {
                    width: 13px;
                    height: 13px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("../../assets/icons/ui/delete.svg");
                    image-fit: contain;
                    colorize: trash-ta.has-hover ? #ef5350 : Theme.text-secondary;
                }
            }
        }
    }
}

// Vec3 property row with colored X/Y/Z fields - polished design
// Value format: "x, y, z" (comma-separated)
component Vec3Row inherits Rectangle {
    in property <string> label: "";
    in property <string> value: "0, 0, 0"; // "x, y, z" format
    in property <bool> editable: true;
    in property <string> description: "";
    in property <string> learn-url: "";
    in property <bool> show-help-icons: true;

    // Parsed values (split from value string)
    in property <string> x-value: "0";
    in property <string> y-value: "0";
    in property <string> z-value: "0";

    // Expose focus state so parent can aggregate across all rows
    out property <bool> has-focus: x-edit.has-focus || y-edit.has-focus || z-edit.has-focus;

    // Fire focus-changed the INSTANT any of the three fields gains
    // or loses focus — not just on the first keystroke. Without this
    // binding the `edited(text)` callback below only fires after the
    // user types, leaving a window where the field is focused but
    // Bevy thinks no input is active and the Delete key deletes the
    // selected part instead of a character.
    changed has-focus => { root.focus-changed(self.has-focus); }

    callback value-changed(string);
    callback open-learn-url(string);
    callback focus-changed(bool);
    // Fired when the user clicks the tiny copy icon at the end of
    // the row. The argument is the full "x, y, z" triple so the
    // parent can push it to the OS clipboard without re-parsing
    // the LineEdit state.
    callback copy-vector(string);
    // Fired when the user clicks the paste icon. The argument is
    // irrelevant (empty string); the parent reads the clipboard on
    // the Rust side + pushes a value-changed.
    callback paste-vector();

    // Hidden focus sink — see PropRow for rationale. Pressing Enter in
    // any of the three fields hops focus here so the field defocuses
    // visually.
    focus_sink := FocusScope { width: 0px; height: 0px; }

    height: 28px;
    border-radius: 2px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 10px;
        spacing: 4px;

        HelpIcon {
            description: root.description;
            learn-url: root.learn-url;
            show-help-icons: root.show-help-icons;
            open-learn-url(url) => { root.open-learn-url(url); }
        }
        
        // Label — 92px instead of 110 to make room for the copy/
        // paste pair we now anchor on the left edge of the row.
        Text {
            width: 92px;
            text: root.label;
            color: Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }

        // Copy button (LEFT-anchored, no paste twin).
        //
        // Paste doesn't need a button: the X/Y/Z LineEdits use
        // `input-type: text` so a Ctrl+V of "5, 10, 20" keeps its
        // commas. Hitting Enter fires the `accepted` handler, which
        // concatenates `self.text + ", " + y + ", " + z` → the Rust
        // value-changed handler reads ≥ 3 comma parts and takes the
        // first three, so the pasted triple wins over the sibling
        // fields. A single-scalar edit produces exactly 3 parts and
        // still commits normally.
        Rectangle {
            width: 18px;
            height: 22px;
            border-radius: 3px;
            background: copy-touch.has-hover ? Theme.button-hover : transparent;
            copy-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.copy-vector(x-edit.text + ", " + y-edit.text + ", " + z-edit.text);
                }
            }
            Image {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 12px;
                height: 12px;
                source: @image-url("../../assets/icons/ui/copy.svg");
                image-fit: contain;
                colorize: copy-touch.has-hover ? Theme.text-primary : Theme.text-disabled;
            }
        }

        // X field with accent border
        Rectangle {
            horizontal-stretch: 1;
            min-width: 52px;
            height: 22px;
            background: Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: #3a2020;
            
            // Left accent bar
            Rectangle {
                x: 0px;
                y: 0px;
                width: 3px;
                height: 100%;
                background: Theme.gizmo-x;
            }
            
            HorizontalLayout {
                padding-left: 6px;
                padding-right: 4px;
                spacing: 2px;
                
                Text {
                    width: 12px;
                    text: "X";
                    color: Theme.gizmo-x;
                    font-size: 9px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                
                x-edit := LineEdit {
                    horizontal-stretch: 1;
                    text: root.x-value;
                    // `text` (not `decimal`) so Ctrl+V of a pasted
                    // triple like "5, 10, 20" keeps its commas — the
                    // Rust value-changed handler reads ≥3 comma parts
                    // and distributes into X/Y/Z atomically. `decimal`
                    // stripped the commas, breaking the paste flow.
                    input-type: text;
                    enabled: root.editable;
                    edited(t) => {
                        root.focus-changed(true);
                    }
                    accepted(t) => {
                        root.value-changed(self.text + ", " + y-edit.text + ", " + z-edit.text);
                        focus_sink.focus();
                    }
                }
            }
        }
        
        // Y field with accent border
        Rectangle {
            horizontal-stretch: 1;
            min-width: 52px;
            height: 22px;
            background: Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: #203a30;
            
            // Left accent bar
            Rectangle {
                x: 0px;
                y: 0px;
                width: 3px;
                height: 100%;
                background: Theme.gizmo-y;
            }
            
            HorizontalLayout {
                padding-left: 6px;
                padding-right: 4px;
                spacing: 2px;
                
                Text {
                    width: 12px;
                    text: "Y";
                    color: Theme.gizmo-y;
                    font-size: 9px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                
                y-edit := LineEdit {
                    horizontal-stretch: 1;
                    text: root.y-value;
                    input-type: text;
                    enabled: root.editable;
                    edited(t) => {
                        root.focus-changed(true);
                    }
                    accepted(t) => {
                        root.value-changed(x-edit.text + ", " + self.text + ", " + z-edit.text);
                        focus_sink.focus();
                    }
                }
            }
        }
        
        // Z field with accent border
        Rectangle {
            horizontal-stretch: 1;
            min-width: 52px;
            height: 22px;
            background: Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: #202a3a;
            
            // Left accent bar
            Rectangle {
                x: 0px;
                y: 0px;
                width: 3px;
                height: 100%;
                background: Theme.gizmo-z;
            }
            
            HorizontalLayout {
                padding-left: 6px;
                padding-right: 4px;
                spacing: 2px;
                
                Text {
                    width: 12px;
                    text: "Z";
                    color: Theme.gizmo-z;
                    font-size: 9px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                
                z-edit := LineEdit {
                    horizontal-stretch: 1;
                    text: root.z-value;
                    input-type: text;
                    enabled: root.editable;
                    edited(t) => {
                        root.focus-changed(true);
                    }
                    accepted(t) => {
                        root.value-changed(x-edit.text + ", " + y-edit.text + ", " + self.text);
                        focus_sink.focus();
                    }
                }
            }
        }

    }
}

// ────────────────────────────────────────────────────────────────────────────
// Vec2Row — Vector2 of pixel values (e.g. `BillboardGui.SizeOffset`,
// `Frame.AnchorPoint`). Same layout as `Vec3Row` minus the Z field —
// X / Y inputs side-by-side with axis-coloured accent bars and a
// copy button. Roblox-style Vector2 is pure pixels (no Scale column),
// so neither field carries a "Pixels" sub-label — the row's name
// ("SizeOffset", "AnchorPoint", …) already communicates the unit
// without the redundant decoration the legacy text-input variant
// pulled in from the UDim2 widget.
// ────────────────────────────────────────────────────────────────────────────
component Vec2Row inherits Rectangle {
    in property <string> label: "";
    in property <bool> editable: true;
    in property <string> description: "";
    in property <string> learn-url: "";
    in property <bool> show-help-icons: true;
    in property <string> x-value: "0";
    in property <string> y-value: "0";

    out property <bool> has-focus: x-edit.has-focus || y-edit.has-focus;
    changed has-focus => { root.focus-changed(self.has-focus); }
    callback value-changed(string);
    callback open-learn-url(string);
    callback focus-changed(bool);
    callback copy-vector(string);

    focus_sink := FocusScope { width: 0px; height: 0px; }

    height: 28px;
    border-radius: 2px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 10px;
        spacing: 4px;

        HelpIcon {
            description: root.description;
            learn-url: root.learn-url;
            show-help-icons: root.show-help-icons;
            open-learn-url(url) => { root.open-learn-url(url); }
        }
        Text {
            width: 92px;
            text: root.label;
            color: Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }
        Rectangle {
            width: 18px; height: 22px;
            border-radius: 3px;
            background: copy-touch.has-hover ? Theme.button-hover : transparent;
            copy-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.copy-vector(x-edit.text + ", " + y-edit.text);
                }
            }
            Image {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 12px; height: 12px;
                source: @image-url("../../assets/icons/ui/copy.svg");
                image-fit: contain;
                colorize: copy-touch.has-hover ? Theme.text-primary : Theme.text-disabled;
            }
        }

        // X field
        Rectangle {
            horizontal-stretch: 1;
            min-width: 60px;
            height: 22px;
            background: Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: #3a2020;
            Rectangle {
                x: 0px; y: 0px; width: 3px; height: 100%;
                background: Theme.gizmo-x;
            }
            HorizontalLayout {
                padding-left: 6px;
                padding-right: 4px;
                spacing: 2px;
                Text {
                    width: 12px;
                    text: "X";
                    color: Theme.gizmo-x;
                    font-size: 9px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                x-edit := LineEdit {
                    horizontal-stretch: 1;
                    text: root.x-value;
                    input-type: text;
                    enabled: root.editable;
                    edited(t) => { root.focus-changed(true); }
                    accepted(t) => {
                        root.value-changed(self.text + ", " + y-edit.text);
                        focus_sink.focus();
                    }
                }
            }
        }

        // Y field
        Rectangle {
            horizontal-stretch: 1;
            min-width: 60px;
            height: 22px;
            background: Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: #203a30;
            Rectangle {
                x: 0px; y: 0px; width: 3px; height: 100%;
                background: Theme.gizmo-y;
            }
            HorizontalLayout {
                padding-left: 6px;
                padding-right: 4px;
                spacing: 2px;
                Text {
                    width: 12px;
                    text: "Y";
                    color: Theme.gizmo-y;
                    font-size: 9px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
                y-edit := LineEdit {
                    horizontal-stretch: 1;
                    text: root.y-value;
                    input-type: text;
                    enabled: root.editable;
                    edited(t) => { root.focus-changed(true); }
                    accepted(t) => {
                        root.value-changed(x-edit.text + ", " + self.text);
                        focus_sink.focus();
                    }
                }
            }
        }
    }
}

// Rotation Vec3 row — degrees, supports negative values and +/- step buttons
// Step buttons use a special "step:X:±1" prefix that Rust's on-property-changed handles
// by parsing the current value, applying the step, and writing back.
// Direct text edits send "X, Y, Z" as usual.
// ────────────────────────────────────────────────────────────────────────────
// UDim2Row — Roblox-parity 2D layout coordinate (Position / Size).
// Renders four numeric inputs in a 2×2 grid: rows are X / Y axes,
// columns are Scale / Pixels (the Roblox `UDim` Offset component
// is shown as "Pixels" in the UI for clarity — "Offset" is
// ambiguous next to a position/size widget). Header line carries
// the property name + copy button. Total height ≈ 76 px (header
// 24 px + two 24 px field rows with 2 px spacing + 4 px top/bottom
// padding).
//
//   Size                                                       [📋]
//     X  Scale [ 0   ]   Pixels [ 200 ]
//     Y  Scale [ 0   ]   Pixels [ 50  ]
//
// Roblox-parity semantics:
//   final_pixels = Scale * parent_resolved_pixels + Pixels
// So `Scale = 1, Pixels = 0` fills the parent; `Scale = 0, Pixels = 200`
// is a fixed 200-px region. (For `BillboardGui.Size` specifically, the
// "parent" is the world stud-to-pixel reference rather than a UI parent
// — Scale is interpreted as studs.)
// ────────────────────────────────────────────────────────────────────────────
component UDim2Row inherits Rectangle {
    in property <string> label: "";
    in property <bool> editable: true;
    in property <string> description: "";
    in property <string> learn-url: "";
    in property <bool> show-help-icons: true;

    in property <string> x-scale: "0";
    in property <string> x-offset: "0";
    in property <string> y-scale: "0";
    in property <string> y-offset: "0";

    out property <bool> has-focus:
        xs.has-focus || xo.has-focus || ys.has-focus || yo.has-focus;
    changed has-focus => { root.focus-changed(self.has-focus); }

    callback value-changed(string);
    callback open-learn-url(string);
    callback focus-changed(bool);
    callback copy-vector(string);

    // Hidden focus sink — see PropRow for rationale.
    focus_sink := FocusScope { width: 0px; height: 0px; }

    // Explicit height — header + 2 axis rows + 4px gaps. Slint's
    // `preferred-height` doesn't propagate through a `for prop[i]`
    // loop, so the host VerticalLayout uses this fixed height to
    // allocate the row slot. Drift in any line height below requires
    // bumping this number.
    height: 76px;
    border-radius: 2px;

    VerticalLayout {
        padding-left: 8px;
        padding-right: 10px;
        padding-top: 4px;
        padding-bottom: 4px;
        spacing: 3px;

        // ── Header: label + copy button ────────────────────────────────
        Rectangle {
            height: 22px;
            HorizontalLayout {
                spacing: 4px;
                HelpIcon {
                    description: root.description;
                    learn-url: root.learn-url;
                    show-help-icons: root.show-help-icons;
                    open-learn-url(url) => { root.open-learn-url(url); }
                }
                Text {
                    horizontal-stretch: 1;
                    text: root.label;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    vertical-alignment: center;
                    overflow: elide;
                }
                Rectangle {
                    width: 18px; height: 22px;
                    border-radius: 3px;
                    background: copy-touch.has-hover ? Theme.button-hover : transparent;
                    copy-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.copy-vector(
                                xs.text + ", " + xo.text + ", " + ys.text + ", " + yo.text
                            );
                        }
                    }
                    Image {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 12px; height: 12px;
                        source: @image-url("../../assets/icons/ui/copy.svg");
                        image-fit: contain;
                        colorize: copy-touch.has-hover ? Theme.text-primary : Theme.text-disabled;
                    }
                }
            }
        }

        // ── X-axis row: Scale | Pixels ─────────────────────────────────
        Rectangle {
            height: 22px;
            // Coloured accent strip on the left edge (red = X) matches
            // the Vec3Row convention so the user can scan rows by axis.
            Rectangle {
                x: 0px;
                y: 1px;
                width: 3px;
                height: parent.height - 2px;
                background: Theme.gizmo-x;
                border-radius: 1.5px;
            }
            HorizontalLayout {
                padding-left: 10px;
                spacing: 6px;
                Text {
                    text: "X";
                    color: Theme.gizmo-x;
                    font-size: 11px;
                    font-weight: 600;
                    width: 12px;
                    vertical-alignment: center;
                }
                Text {
                    text: "Scale";
                    color: Theme.text-disabled;
                    font-size: 10px;
                    width: 36px;
                    vertical-alignment: center;
                }
                xs := LineEdit {
                    horizontal-stretch: 1;
                    text: root.x-scale;
                    enabled: root.editable;
                    edited(t) => {
                        root.focus-changed(true);
                        root.value-changed(t + ", " + xo.text + ", " + ys.text + ", " + yo.text);
                    }
                    accepted(t) => {
                        root.value-changed(t + ", " + xo.text + ", " + ys.text + ", " + yo.text);
                        focus_sink.focus();
                    }
                }
                Text {
                    text: "Pixels";
                    color: Theme.text-disabled;
                    font-size: 10px;
                    width: 38px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
                xo := LineEdit {
                    horizontal-stretch: 1;
                    text: root.x-offset;
                    enabled: root.editable;
                    edited(t) => {
                        root.focus-changed(true);
                        root.value-changed(xs.text + ", " + t + ", " + ys.text + ", " + yo.text);
                    }
                    accepted(t) => {
                        root.value-changed(xs.text + ", " + t + ", " + ys.text + ", " + yo.text);
                        focus_sink.focus();
                    }
                }
            }
        }

        // ── Y-axis row: Scale | Pixels ─────────────────────────────────
        Rectangle {
            height: 22px;
            // Green accent strip — matches the Vec3 Y axis colour.
            Rectangle {
                x: 0px;
                y: 1px;
                width: 3px;
                height: parent.height - 2px;
                background: Theme.gizmo-y;
                border-radius: 1.5px;
            }
            HorizontalLayout {
                padding-left: 10px;
                spacing: 6px;
                Text {
                    text: "Y";
                    color: Theme.gizmo-y;
                    font-size: 11px;
                    font-weight: 600;
                    width: 12px;
                    vertical-alignment: center;
                }
                Text {
                    text: "Scale";
                    color: Theme.text-disabled;
                    font-size: 10px;
                    width: 36px;
                    vertical-alignment: center;
                }
                ys := LineEdit {
                    horizontal-stretch: 1;
                    text: root.y-scale;
                    enabled: root.editable;
                    edited(t) => {
                        root.focus-changed(true);
                        root.value-changed(xs.text + ", " + xo.text + ", " + t + ", " + yo.text);
                    }
                    accepted(t) => {
                        root.value-changed(xs.text + ", " + xo.text + ", " + t + ", " + yo.text);
                        focus_sink.focus();
                    }
                }
                Text {
                    text: "Pixels";
                    color: Theme.text-disabled;
                    font-size: 10px;
                    width: 38px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
                yo := LineEdit {
                    horizontal-stretch: 1;
                    text: root.y-offset;
                    enabled: root.editable;
                    edited(t) => {
                        root.focus-changed(true);
                        root.value-changed(xs.text + ", " + xo.text + ", " + ys.text + ", " + t);
                    }
                    accepted(t) => {
                        root.value-changed(xs.text + ", " + xo.text + ", " + ys.text + ", " + t);
                        focus_sink.focus();
                    }
                }
            }   // close HorizontalLayout (Y row)
        }       // close Rectangle wrapper (Y row)
    }           // close VerticalLayout
}               // close UDim2Row Rectangle

component RotationVec3Row inherits Rectangle {
    in property <string> label: "";
    in property <string> value: "0, 0, 0";
    in property <bool> editable: true;
    in property <string> x-value: "0";
    in property <string> y-value: "0";
    in property <string> z-value: "0";
    in property <string> description: "";
    in property <string> learn-url: "";
    in property <bool> show-help-icons: true;
    
    // Expose focus state so parent can aggregate across all rows
    out property <bool> has-focus: rx-edit.has-focus || ry-edit.has-focus || rz-edit.has-focus;

    // Fire focus-changed on actual focus transitions — see Vec3Row
    // for the Delete-key-deletes-selected-part rationale.
    changed has-focus => { root.focus-changed(self.has-focus); }

    callback value-changed(string);
    callback open-learn-url(string);
    callback focus-changed(bool);
    // Matches `Vec3Row` — copy pushes the current triple; paste asks
    // the parent/Rust to read the clipboard and drive a value-changed.
    callback copy-vector(string);
    callback paste-vector();

    // Hidden focus sink — see PropRow for rationale.
    focus_sink := FocusScope { width: 0px; height: 0px; }

    height: 28px;
    border-radius: 2px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 10px;
        spacing: 4px;

        HelpIcon {
            description: root.description;
            learn-url: root.learn-url;
            show-help-icons: root.show-help-icons;
            open-learn-url(url) => { root.open-learn-url(url); }
        }

        // Label — 92px instead of 110 to make room for the left-
        // anchored copy button; matches `Vec3Row`.
        Text {
            width: 92px;
            text: root.label;
            color: Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }

        // Copy button (LEFT-anchored). Paste doesn't need a button:
        // Ctrl+V of a triple like "90, 0, 45" into any rx/ry/rz field
        // then Enter is detected by the Rust value-changed handler
        // (>=3 comma parts) and applied atomically.
        Rectangle {
            width: 18px;
            height: 22px;
            border-radius: 3px;
            background: r-copy-touch.has-hover ? Theme.button-hover : transparent;
            r-copy-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.copy-vector(rx-edit.text + ", " + ry-edit.text + ", " + rz-edit.text);
                }
            }
            Image {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 12px;
                height: 12px;
                source: @image-url("../../assets/icons/ui/copy.svg");
                image-fit: contain;
                colorize: r-copy-touch.has-hover ? Theme.text-primary : Theme.text-disabled;
            }
        }

        // ── X ──────────────────────────────────────────────
        Rectangle {
            horizontal-stretch: 1;
            min-width: 68px;
            height: 22px;
            background: Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: #3a2020;

            Rectangle { x: 0px; y: 0px; width: 3px; height: 100%; background: Theme.gizmo-x; }

            HorizontalLayout {
                padding-left: 6px;
                padding-right: 2px;
                spacing: 2px;

                Text { width: 12px; text: "X"; color: Theme.gizmo-x; font-size: 9px; font-weight: 700; vertical-alignment: center; horizontal-alignment: center; }

                rx-edit := LineEdit {
                    horizontal-stretch: 1;
                    text: root.x-value;
                    input-type: text;
                    enabled: root.editable;
                    edited(t) => {
                        root.focus-changed(true);
                    }
                    accepted(t) => {
                        root.value-changed(self.text + ", " + ry-edit.text + ", " + rz-edit.text);
                        focus_sink.focus();
                    }
                }

                Rectangle {
                    width: 16px; height: 18px; background: rx-m.has-hover ? #3a3a3a : #2a2a2a; border-radius: 2px;
                    rx-m := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.value-changed("step:x:-1:" + rx-edit.text + "," + ry-edit.text + "," + rz-edit.text); }
                    }
                    Text { text: "-"; color: Theme.text-secondary; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle {
                    width: 16px; height: 18px; background: rx-p.has-hover ? #3a3a3a : #2a2a2a; border-radius: 2px;
                    rx-p := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.value-changed("step:x:+1:" + rx-edit.text + "," + ry-edit.text + "," + rz-edit.text); }
                    }
                    Text { text: "+"; color: Theme.text-secondary; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }

        // ── Y ──────────────────────────────────────────────
        Rectangle {
            horizontal-stretch: 1;
            min-width: 68px;
            height: 22px;
            background: Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: #203a30;

            Rectangle { x: 0px; y: 0px; width: 3px; height: 100%; background: Theme.gizmo-y; }

            HorizontalLayout {
                padding-left: 6px;
                padding-right: 2px;
                spacing: 2px;

                Text { width: 12px; text: "Y"; color: Theme.gizmo-y; font-size: 9px; font-weight: 700; vertical-alignment: center; horizontal-alignment: center; }

                ry-edit := LineEdit {
                    horizontal-stretch: 1;
                    text: root.y-value;
                    input-type: text;
                    enabled: root.editable;
                    edited(t) => {
                        root.focus-changed(true);
                    }
                    accepted(t) => {
                        root.value-changed(rx-edit.text + ", " + self.text + ", " + rz-edit.text);
                        focus_sink.focus();
                    }
                }

                Rectangle {
                    width: 16px; height: 18px; background: ry-m.has-hover ? #3a3a3a : #2a2a2a; border-radius: 2px;
                    ry-m := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.value-changed("step:y:-1:" + rx-edit.text + "," + ry-edit.text + "," + rz-edit.text); }
                    }
                    Text { text: "-"; color: Theme.text-secondary; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle {
                    width: 16px; height: 18px; background: ry-p.has-hover ? #3a3a3a : #2a2a2a; border-radius: 2px;
                    ry-p := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.value-changed("step:y:+1:" + rx-edit.text + "," + ry-edit.text + "," + rz-edit.text); }
                    }
                    Text { text: "+"; color: Theme.text-secondary; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }

        // ── Z ──────────────────────────────────────────────
        Rectangle {
            horizontal-stretch: 1;
            min-width: 68px;
            height: 22px;
            background: Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: #202a3a;

            Rectangle { x: 0px; y: 0px; width: 3px; height: 100%; background: Theme.gizmo-z; }

            HorizontalLayout {
                padding-left: 6px;
                padding-right: 2px;
                spacing: 2px;

                Text { width: 12px; text: "Z"; color: Theme.gizmo-z; font-size: 9px; font-weight: 700; vertical-alignment: center; horizontal-alignment: center; }

                rz-edit := LineEdit {
                    horizontal-stretch: 1;
                    text: root.z-value;
                    input-type: text;
                    enabled: root.editable;
                    edited(t) => {
                        root.focus-changed(true);
                    }
                    accepted(t) => {
                        root.value-changed(rx-edit.text + ", " + ry-edit.text + ", " + self.text);
                        focus_sink.focus();
                    }
                }

                Rectangle {
                    width: 16px; height: 18px; background: rz-m.has-hover ? #3a3a3a : #2a2a2a; border-radius: 2px;
                    rz-m := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.value-changed("step:z:-1:" + rx-edit.text + "," + ry-edit.text + "," + rz-edit.text); }
                    }
                    Text { text: "-"; color: Theme.text-secondary; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle {
                    width: 16px; height: 18px; background: rz-p.has-hover ? #3a3a3a : #2a2a2a; border-radius: 2px;
                    rz-p := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.value-changed("step:z:+1:" + rx-edit.text + "," + ry-edit.text + "," + rz-edit.text); }
                    }
                    Text { text: "+"; color: Theme.text-secondary; font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }

    }
}

// One tile in the 127-swatch ColorPickerPopup honeycomb. The chip is
// rendered as a real hexagon (Slint Path) so the wheel reads as a
// proper hex tessellation rather than a circle grid; tightly-packed
// flat-top hexes nest perfectly against one another. Hover shows a
// floating name tag above the chip — pixel real-estate is too tight
// for inline labels at this density.
//
// Cell box is 22×19 px; the hex chip occupies 18×16 of that, leaving
// a 2-px gutter so adjacent cells read as discrete clickable targets
// rather than a single mottled blob.
export component ColorSwatchCell inherits Rectangle {
    in property <string> swatch-name: "";
    in property <int> r: 128;
    in property <int> g: 128;
    in property <int> b: 128;
    callback swatch-clicked();

    width: 22px;
    height: 19px;

    // Flat-top regular hexagon. For a hex of width 18 px and height
    // 16 px, the six vertices are at:
    //   left mid, top-left, top-right, right mid, bottom-right, bottom-left
    // Stroke + fill driven by hover state so the active swatch reads
    // visibly against its neighbours.
    chip := Path {
        x: 2px;
        y: 1.5px;
        width: 18px;
        height: 16px;
        viewbox-x: 0;
        viewbox-y: 0;
        viewbox-width: 18;
        viewbox-height: 16;
        fill: rgb(root.r, root.g, root.b);
        stroke: touch.has-hover ? Theme.accent-blue : #20202080;
        stroke-width: touch.has-hover ? 1.5px : 0.5px;
        commands: "M 0 8 L 4.5 0 L 13.5 0 L 18 8 L 13.5 16 L 4.5 16 Z";
        animate stroke-width { duration: 80ms; }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.swatch-clicked(); }
    }

    // Hover-only floating name. Sits ABOVE the chip so it doesn't
    // collide with the hex packing of neighbouring cells.
    if touch.has-hover: Rectangle {
        x: -40px;
        y: -22px;
        width: 100px;
        height: 18px;
        background: #1a1a22;
        border-radius: 4px;
        border-width: 1px;
        border-color: #3a3a3a;
        drop-shadow-blur: 6px;
        drop-shadow-color: #000000a0;
        Text {
            text: root.swatch-name;
            color: Theme.text-primary;
            font-size: 10px;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: parent.width;
            height: parent.height;
        }
    }
}

// Color property row with swatch + hex value - polished design
component ColorRow inherits Rectangle {
    in property <string> label: "";
    in property <string> value: "#808080";
    // Live preview color, populated by Rust from the same RGB the
    // `value` string represents. Used for the swatch chip — Slint can't
    // parse the "r, g, b" string into a typed color at runtime so the
    // parsing has to happen Rust-side.
    in property <color> preview-color: #808080;
    in property <bool> editable: true;
    in property <string> description: "";
    in property <string> learn-url: "";
    in property <bool> show-help-icons: true;

    // Expose focus state so parent can aggregate across all rows
    out property <bool> has-focus: color-edit.has-focus;

    callback value-changed(string);
    callback open-learn-url(string);
    callback focus-changed(bool);

    // Hidden focus sink — see PropRow for rationale.
    focus_sink := FocusScope { width: 0px; height: 0px; }

    // RGB modal state — three sliders (0-255). Seeded from the live
    // `preview-color` whenever the modal opens (Slint can't parse the
    // "r, g, b" string, but a `color` exposes typed .red/.green/.blue
    // channels). On any slider move we emit the rounded triple back
    // through `value-changed` so the Rust property pipeline handles it
    // identically to manual hex entry.
    in-out property <float> r-val: 128;
    in-out property <float> g-val: 128;
    in-out property <float> b-val: 128;

    height: 28px;
    border-radius: 2px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 10px;
        spacing: 4px;

        HelpIcon {
            description: root.description;
            learn-url: root.learn-url;
            show-help-icons: root.show-help-icons;
            open-learn-url(url) => { root.open-learn-url(url); }
        }

        // Label
        Text {
            width: 110px;
            text: root.label;
            color: Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }

        // Color swatch — live preview of the row's RGB value, opens
        // the named-palette picker on click.
        Rectangle {
            width: 28px;
            height: 20px;
            background: root.preview-color;
            border-radius: 4px;
            border-width: 1px;
            border-color: swatch-touch.has-hover ? Theme.accent-blue : #444444;
            drop-shadow-blur: 2px;
            drop-shadow-color: #00000040;

            swatch-touch := TouchArea {
                mouse-cursor: root.editable ? pointer : default;
                clicked => {
                    if root.editable {
                        // Seed sliders from the current preview color so the
                        // modal opens on the row's actual RGB.
                        root.r-val = root.preview-color.red;
                        root.g-val = root.preview-color.green;
                        root.b-val = root.preview-color.blue;
                        color-picker-popup.show();
                    }
                }
            }
        }

        // Hex input with refined styling — always present but visibility controlled
        Rectangle {
            horizontal-stretch: 1;
            height: 22px;
            visible: root.editable;
            background: Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: color-edit.has-focus ? Theme.accent-blue : Theme.input-border;
            
            color-edit := LineEdit {
                x: 0px;
                y: 0px;
                width: 100%;
                height: 100%;
                enabled: root.editable;
                text: root.value;
                edited(text) => {
                    root.focus-changed(true);
                }
                accepted(text) => {
                    root.value-changed(self.text);
                    // Drop the LineEdit's focused state on Enter — see
                    // PropRow for rationale.
                    focus_sink.focus();
                }
            }
        }

        if !root.editable: Text {
            horizontal-stretch: 1;
            text: root.value;
            color: Theme.text-primary;
            font-size: 11px;
            vertical-alignment: center;
        }
    }

    // RGB modal. Sibling of the HorizontalLayout so the PopupWindow
    // gets root-level placement (Slint requirement). Three sliders
    // (0-255) + numeric readouts + a live preview swatch. Any slider
    // change emits the rounded "r, g, b" triple through the normal
    // value-changed callback so the Rust property pipeline handles it
    // identically to manual hex entry.
    color-picker-popup := PopupWindow {
        x: 140px;
        y: parent.height;
        width: 260px;
        height: 200px;

        Rectangle {
            width: 100%;
            height: 100%;
            background: #1a1a22;
            border-radius: 8px;
            border-width: 1px;
            border-color: #3a3a3a;
            drop-shadow-blur: 16px;
            drop-shadow-color: #000000a0;

            // Swallow clicks so they don't bubble to the viewport.
            TouchArea { }

            VerticalLayout {
                padding: 12px;
                spacing: 8px;

                // Title + live preview swatch on the same row.
                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: "RGB Color";
                        color: Theme.text-primary;
                        font-size: 13px;
                        font-weight: 700;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Rectangle {
                        width: 36px;
                        height: 20px;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: #444444;
                        background: rgb(Math.round(root.r-val), Math.round(root.g-val), Math.round(root.b-val));
                    }
                }

                // ── R row ──
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "R";
                        width: 14px;
                        color: #ff8080;
                        font-size: 11px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    Slider {
                        horizontal-stretch: 1;
                        minimum: 0;
                        maximum: 255;
                        value: root.r-val;
                        changed(v) => {
                            root.r-val = v;
                            root.value-changed(Math.round(root.r-val) + ", " + Math.round(root.g-val) + ", " + Math.round(root.b-val));
                        }
                    }
                    Text {
                        text: Math.round(root.r-val);
                        width: 30px;
                        color: Theme.text-primary;
                        font-size: 11px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                }

                // ── G row ──
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "G";
                        width: 14px;
                        color: #80ff80;
                        font-size: 11px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    Slider {
                        horizontal-stretch: 1;
                        minimum: 0;
                        maximum: 255;
                        value: root.g-val;
                        changed(v) => {
                            root.g-val = v;
                            root.value-changed(Math.round(root.r-val) + ", " + Math.round(root.g-val) + ", " + Math.round(root.b-val));
                        }
                    }
                    Text {
                        text: Math.round(root.g-val);
                        width: 30px;
                        color: Theme.text-primary;
                        font-size: 11px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                }

                // ── B row ──
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "B";
                        width: 14px;
                        color: #8080ff;
                        font-size: 11px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    Slider {
                        horizontal-stretch: 1;
                        minimum: 0;
                        maximum: 255;
                        value: root.b-val;
                        changed(v) => {
                            root.b-val = v;
                            root.value-changed(Math.round(root.r-val) + ", " + Math.round(root.g-val) + ", " + Math.round(root.b-val));
                        }
                    }
                    Text {
                        text: Math.round(root.b-val);
                        width: 30px;
                        color: Theme.text-primary;
                        font-size: 11px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    height: 24px;
                    width: 70px;
                    background: close-touch.has-hover ? #3a3a3a : #252530;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: #4a4a4a;

                    Text {
                        text: "Close";
                        color: Theme.text-primary;
                        font-size: 11px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    close-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { color-picker-popup.close(); }
                    }
                }
            }
        }
    }
}

// BrickColor property row — a preview swatch that opens a 2-step wheel
// picker. Step 1 lists the seven color wheels (each with a one-line
// descriptor); clicking one sets the LOCAL `active-wheel-id` so the drill is
// instant (no Rust round-trip). Step 2 shows that wheel's 127-cell honeycomb
// (all seven are pushed in from Rust once). Clicking a cell writes its
// "r, g, b" through `value-changed` (same path as ColorRow) so the selected
// part recolors, then closes the popup.
component BrickColorRow inherits Rectangle {
    in property <string> label: "";
    in property <string> value: "128, 128, 128";
    in property <color> preview-color: #808080;
    in property <bool> editable: true;
    in property <string> description: "";
    in property <string> learn-url: "";
    in property <bool> show-help-icons: true;

    // All seven wheels' 127-cell honeycombs, pushed once from Rust. The drill
    // is entirely local: clicking a wheel sets `active-wheel-id` directly.
    in property <[HoneycombCell]> aether-honeycomb: [];
    in property <[HoneycombCell]> halo-honeycomb: [];
    in property <[HoneycombCell]> verdure-honeycomb: [];
    in property <[HoneycombCell]> stone-honeycomb: [];
    in property <[HoneycombCell]> char-honeycomb: [];
    in property <[HoneycombCell]> hex-honeycomb: [];
    in property <[HoneycombCell]> umbra-honeycomb: [];
    // LOCAL drill state: "" = step 1 wheel list, else step 2 for that wheel.
    property <string> active-wheel-id: "";

    callback value-changed(string);
    callback open-learn-url(string);

    height: 28px;
    border-radius: 2px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 10px;
        spacing: 4px;

        HelpIcon {
            description: root.description;
            learn-url: root.learn-url;
            show-help-icons: root.show-help-icons;
            open-learn-url(url) => { root.open-learn-url(url); }
        }

        Text {
            width: 110px;
            text: root.label;
            color: Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }

        // Preview swatch — opens the wheel picker on click.
        Rectangle {
            width: 28px;
            height: 20px;
            background: root.preview-color;
            border-radius: 4px;
            border-width: 1px;
            border-color: bc-swatch-touch.has-hover ? Theme.accent-blue : #444444;
            drop-shadow-blur: 2px;
            drop-shadow-color: #00000040;

            bc-swatch-touch := TouchArea {
                mouse-cursor: root.editable ? pointer : default;
                clicked => {
                    if root.editable {
                        // Always (re)open at step 1, the wheel list.
                        root.active-wheel-id = "";
                        brick-color-popup.show();
                    }
                }
            }
        }

        // Read-only text of the current value.
        Text {
            horizontal-stretch: 1;
            text: root.value;
            color: Theme.text-primary;
            font-size: 11px;
            vertical-alignment: center;
        }
    }

    brick-color-popup := PopupWindow {
        x: 140px;
        y: parent.height;
        width: 310px;
        height: 340px;

        Rectangle {
            width: 100%;
            height: 100%;
            background: #1a1a22;
            border-radius: 8px;
            border-width: 1px;
            border-color: #3a3a3a;
            drop-shadow-blur: 16px;
            drop-shadow-color: #000000a0;

            // Swallow clicks so they don't bubble to the viewport.
            TouchArea { }

            VerticalLayout {
                padding: 12px;
                spacing: 6px;

                // ── STEP 1: wheel list ──
                if root.active-wheel-id == "": VerticalLayout {
                    spacing: 4px;

                    Text {
                        text: "Color Wheels";
                        color: Theme.text-primary;
                        font-size: 13px;
                        font-weight: 700;
                    }

                    for w in [
                        { id: "aether",  name: "Aether",  desc: "abstract · good — bright neons" },
                        { id: "halo",    name: "Halo",    desc: "light · good — ethereal" },
                        { id: "verdure", name: "Verdure", desc: "realistic · good — natural" },
                        { id: "stone",   name: "Stone",   desc: "neutral greys" },
                        { id: "char",    name: "Char",    desc: "realistic · evil — ash" },
                        { id: "hex",     name: "Hex",     desc: "abstract · evil — chaotic" },
                        { id: "umbra",   name: "Umbra",   desc: "dark · evil — voids" },
                    ]: Rectangle {
                        height: 38px;
                        background: wheel-touch.has-hover ? #2a2a3a : transparent;
                        border-radius: 4px;

                        wheel-touch := TouchArea {
                            mouse-cursor: pointer;
                            // Local drill — straight to the wheel's colors, no
                            // Rust round-trip (and no popup re-open).
                            clicked => { root.active-wheel-id = w.id; }
                        }

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            alignment: space-between;
                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: w.name;
                                    color: Theme.text-primary;
                                    font-size: 12px;
                                    font-weight: 600;
                                }
                                Text {
                                    text: w.desc;
                                    color: #8a8a9a;
                                    font-size: 9px;
                                }
                            }
                            Text {
                                text: "›";
                                color: #6c7080;
                                font-size: 14px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // ── STEP 2: one wheel's honeycomb ──
                if root.active-wheel-id != "": VerticalLayout {
                    spacing: 6px;

                    // Back row → return to the wheel list.
                    Rectangle {
                        height: 24px;
                        background: bc-back-touch.has-hover ? #2a2a3a : transparent;
                        border-radius: 4px;

                        bc-back-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.active-wheel-id = ""; }
                        }

                        HorizontalLayout {
                            padding-left: 8px;
                            alignment: start;
                            Text {
                                text: "‹ Back";
                                color: Theme.text-primary;
                                font-size: 11px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // 127-cell honeycomb for the active wheel. All seven are
                    // pushed from Rust; we render only the active one via a
                    // guarded `for` per wheel. Cells carry their own
                    // precomputed (x, y) offset inside the 286×264 box.
                    Rectangle {
                        width: 286px;
                        height: 264px;
                        background: transparent;

                        if root.active-wheel-id == "aether": Rectangle {
                            for cell in root.aether-honeycomb: ColorSwatchCell {
                                x: cell.x * 1px;
                                y: cell.y * 1px;
                                r: cell.r;
                                g: cell.g;
                                b: cell.b;
                                swatch-name: cell.name;
                                swatch-clicked => {
                                    root.value-changed(cell.name + "|" + cell.r + ", " + cell.g + ", " + cell.b);
                                    brick-color-popup.close();
                                }
                            }
                        }
                        if root.active-wheel-id == "halo": Rectangle {
                            for cell in root.halo-honeycomb: ColorSwatchCell {
                                x: cell.x * 1px;
                                y: cell.y * 1px;
                                r: cell.r;
                                g: cell.g;
                                b: cell.b;
                                swatch-name: cell.name;
                                swatch-clicked => {
                                    root.value-changed(cell.name + "|" + cell.r + ", " + cell.g + ", " + cell.b);
                                    brick-color-popup.close();
                                }
                            }
                        }
                        if root.active-wheel-id == "verdure": Rectangle {
                            for cell in root.verdure-honeycomb: ColorSwatchCell {
                                x: cell.x * 1px;
                                y: cell.y * 1px;
                                r: cell.r;
                                g: cell.g;
                                b: cell.b;
                                swatch-name: cell.name;
                                swatch-clicked => {
                                    root.value-changed(cell.name + "|" + cell.r + ", " + cell.g + ", " + cell.b);
                                    brick-color-popup.close();
                                }
                            }
                        }
                        if root.active-wheel-id == "stone": Rectangle {
                            for cell in root.stone-honeycomb: ColorSwatchCell {
                                x: cell.x * 1px;
                                y: cell.y * 1px;
                                r: cell.r;
                                g: cell.g;
                                b: cell.b;
                                swatch-name: cell.name;
                                swatch-clicked => {
                                    root.value-changed(cell.name + "|" + cell.r + ", " + cell.g + ", " + cell.b);
                                    brick-color-popup.close();
                                }
                            }
                        }
                        if root.active-wheel-id == "char": Rectangle {
                            for cell in root.char-honeycomb: ColorSwatchCell {
                                x: cell.x * 1px;
                                y: cell.y * 1px;
                                r: cell.r;
                                g: cell.g;
                                b: cell.b;
                                swatch-name: cell.name;
                                swatch-clicked => {
                                    root.value-changed(cell.name + "|" + cell.r + ", " + cell.g + ", " + cell.b);
                                    brick-color-popup.close();
                                }
                            }
                        }
                        if root.active-wheel-id == "hex": Rectangle {
                            for cell in root.hex-honeycomb: ColorSwatchCell {
                                x: cell.x * 1px;
                                y: cell.y * 1px;
                                r: cell.r;
                                g: cell.g;
                                b: cell.b;
                                swatch-name: cell.name;
                                swatch-clicked => {
                                    root.value-changed(cell.name + "|" + cell.r + ", " + cell.g + ", " + cell.b);
                                    brick-color-popup.close();
                                }
                            }
                        }
                        if root.active-wheel-id == "umbra": Rectangle {
                            for cell in root.umbra-honeycomb: ColorSwatchCell {
                                x: cell.x * 1px;
                                y: cell.y * 1px;
                                r: cell.r;
                                g: cell.g;
                                b: cell.b;
                                swatch-name: cell.name;
                                swatch-clicked => {
                                    root.value-changed(cell.name + "|" + cell.r + ", " + cell.g + ", " + cell.b);
                                    brick-color-popup.close();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

// Bool property row with true/false toggle - polished design
component BoolRow inherits Rectangle {
    in property <string> label: "";
    in-out property <string> value: "false";
    in property <bool> editable: true;
    in property <string> description: "";
    in property <string> learn-url: "";
    in property <bool> show-help-icons: true;
    
    callback value-changed(string);
    callback open-learn-url(string);
    
    // Derived: is the value currently "true"?
    property <bool> checked: root.value == "true";
    
    height: 28px;
    border-radius: 2px;
    
    touch := TouchArea {
        mouse-cursor: root.editable ? pointer : default;
        clicked => {
            if root.editable {
                // Toggle immediately so UI updates without waiting for Rust sync
                root.value = root.checked ? "false" : "true";
                root.value-changed(root.value);
            }
        }
    }
    
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 10px;
        spacing: 4px;

        HelpIcon {
            description: root.description;
            learn-url: root.learn-url;
            show-help-icons: root.show-help-icons;
            open-learn-url(url) => { root.open-learn-url(url); }
        }
        
        // Label
        Text {
            width: 110px;
            text: root.label;
            color: Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }
        
        // Checkbox — vertically centered, checkmark icon when true, empty box when false
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 16px;
                height: 16px;
                background: root.checked ? Theme.accent-blue : Theme.input-background;
                border-radius: 3px;
                border-width: 1px;
                border-color: touch.has-hover
                    ? Theme.accent-blue
                    : root.checked ? Theme.accent-blue : Theme.input-border;
                
                // Checkmark icon (visible only when checked)
                Text {
                    text: root.checked ? "✓" : "";
                    color: white;
                    font-size: 12px;
                    font-weight: 900;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
        
        // State label
        Text {
            horizontal-stretch: 1;
            text: root.checked ? "Enabled" : "Disabled";
            color: root.checked ? Theme.text-primary : Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
        }
    }
}

export component PropertiesPanel inherits Rectangle {
    // Properties
    in property <int> selected-count: 0;
    in property <string> selected-class: "";
    in property <image> selected-icon;   // SVG icon for the selected class
    in property <[PropertyData]> properties: [];
    // Show help (?) icons next to properties that have a description field
    in property <bool> show-help-icons: true;
    // Whether help icon clicks open in the tabbed viewer (true) or system browser (false)
    in property <bool> help-opens-in-tab: false;

    // BrickColor wheel picker. Rust pushes ALL seven wheels' 127-cell
    // honeycombs ONCE at startup; the two-step drill (wheel list → that
    // wheel's swatches) is entirely local to BrickColorRow with no Rust
    // round-trip, so picking a wheel goes straight to its colors. Panel-level
    // (not per-row) because only one BrickColor row is ever visible at a time.
    in property <[HoneycombCell]> aether-honeycomb: [];
    in property <[HoneycombCell]> halo-honeycomb: [];
    in property <[HoneycombCell]> verdure-honeycomb: [];
    in property <[HoneycombCell]> stone-honeycomb: [];
    in property <[HoneycombCell]> char-honeycomb: [];
    in property <[HoneycombCell]> hex-honeycomb: [];
    in property <[HoneycombCell]> umbra-honeycomb: [];

    // Callbacks
    callback on-property-changed(string, string);
    // Fired when a section header chevron is clicked — Rust toggles collapsed state
    callback on-section-toggle(string);
    // Fired when a help icon with a learn-url is clicked
    callback on-open-learn-url(string);
    // Fired when any input field gains or loses focus — Rust uses this to pause property sync
    callback on-input-focus-changed(bool);
    // Type-ahead callback for material dropdown keyboard navigation.
    // Rust scans material options and returns the index of the first match.
    // Arguments: (pressed-key, current-highlight-index) -> new-highlight-index
    callback on-find-material-by-key(string, int) -> int;
    // Fired when the copy icon on a Vec3 / Rotation row is clicked —
    // Rust pushes the `"x, y, z"` triple to the OS clipboard.
    callback on-copy-property-vector(string, string);
    // Fired when the paste icon on a Vec3 / Rotation row is clicked —
    // Rust reads the clipboard, parses whichever format the user
    // copied (`"x, y, z"`, `(x, y, z)`, `x y z`, `Vector3.new(x, y, z)`
    // are all accepted) and synthesises a matching
    // `on-property-changed(name, "x, y, z")` call.
    callback on-paste-property-vector(string);
    // Attributes UX. `on-add-attribute` opens the Add-Attribute modal (empty).
    // `on-attribute-edit` opens it prefilled for type/value change (name, type,
    // value). `on-attribute-delete` removes the attribute (name).
    callback on-add-attribute();
    callback on-attribute-edit(string, string, string);
    callback on-attribute-delete(string);
    // Tag system (chips). entity-tags = assigned (with color + count);
    // tag-suggestions = project registry tags not on this entity.
    in property <[TagChip]> entity-tags: [];
    // Flow-wrap rows. Rust splits entity-tags into ≤ 4 rows so each
    // HorizontalLayout sizes its chips naturally (no absolute positioning,
    // which breaks Slint TouchArea hit testing for the Explorer).
    in property <[TagChip]> entity-tag-row-0: [];
    in property <[TagChip]> entity-tag-row-1: [];
    in property <[TagChip]> entity-tag-row-2: [];
    in property <[TagChip]> entity-tag-row-3: [];
    in property <[TagSuggestion]> tag-suggestions: [];
    in-out property <string> tag-input-text: "";
    // Collapse state for the Tags section (shared collapsed_sections mechanism).
    in property <bool> tags-collapsed: false;
    callback on-tag-add(string);
    callback on-tag-remove(string);
    callback on-tag-select-tagged(string);
    callback on-tag-rename-request(string);   // open the rename modal for this tag

    background: Theme.panel-background;
    
    VerticalLayout {
        padding: 0px;
        spacing: 0px;
        
        // Header showing selection info - polished design
        Rectangle {
            height: 36px;
            background: @linear-gradient(180deg, #1e1e1e 0%, #181818 100%);
            
            // Bottom border
            Rectangle {
                y: parent.height - 1px;
                width: 100%;
                height: 1px;
                background: #2a2a2a;
            }
            
            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                spacing: 8px;
                alignment: start;

                // Class icon — SVG image when something is selected, fallback placeholder
                if root.selected-count > 0: VerticalLayout {
                    width: 16px;
                    alignment: center;
                    
                    Image {
                        width: 16px;
                        height: 16px;
                        source: root.selected-icon;
                        image-fit: contain;
                    }
                }
                if root.selected-count == 0: VerticalLayout {
                    width: 16px;
                    alignment: center;
                    
                    Rectangle {
                        width: 16px;
                        height: 16px;
                        border-radius: 3px;
                        background: #333333;
                        Text {
                            text: "?";
                            color: Theme.text-secondary;
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                Text {
                    text: root.selected-count == 0 ? "No Selection" :
                          root.selected-count == 1 ? root.selected-class :
                          root.selected-count + " Objects Selected";
                    color: Theme.text-primary;
                    font-weight: 600;
                    font-size: 12px;
                    letter-spacing: 0.3px;
                    vertical-alignment: center;
                }
                
                Rectangle { horizontal-stretch: 1; }
                
                // Selection count badge
                if root.selected-count > 1: Rectangle {
                    width: 24px;
                    height: 18px;
                    border-radius: 9px;
                    background: Theme.accent-blue;
                    
                    Text {
                        text: root.selected-count;
                        color: white;
                        font-size: 10px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
        
        // Empty state - polished design
        if root.selected-count == 0: Rectangle {
            vertical-stretch: 1;
            background: Theme.panel-background;
            
            VerticalLayout {
                alignment: center;
                spacing: 12px;
                
                // Empty state icon — centered horizontally
                HorizontalLayout {
                    alignment: center;
                    height: 48px;

                    Rectangle {
                        width: 48px;
                        height: 48px;
                        border-radius: 24px;
                        background: #1a1a1a;
                        border-width: 1px;
                        border-color: #2a2a2a;
                        
                        Text {
                            text: "◇";
                            color: Theme.text-secondary;
                            font-size: 20px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
                
                Text {
                    text: "No Selection";
                    color: Theme.text-primary;
                    font-size: 13px;
                    font-weight: 500;
                    horizontal-alignment: center;
                }
                
                Text {
                    text: "Select an object in the viewport\nor Explorer to view its properties";
                    color: Theme.text-secondary;
                    font-size: 11px;
                    horizontal-alignment: center;
                }
            }
        }
        
        // Dynamic property list — fully driven by Rust binding
        if root.selected-count > 0: ScrollView {
            vertical-stretch: 1;
            horizontal-scrollbar-policy: always-off;
            
            VerticalLayout {
                padding: 4px;
                padding-top: 6px;
                spacing: 1px;
                alignment: start;

                // First-class Tag system — uses the standard SectionHeader for
                // visual + collapse parity with Appearance / Attributes / etc.
                SectionHeader {
                    title: "Tags";
                    category: "Tags";
                    expanded: !root.tags-collapsed;
                    clicked => { root.on-section-toggle("Tags"); }
                }
                if !root.tags-collapsed: TagsEditor {
                    tags: root.entity-tags;
                    tag-row-0: root.entity-tag-row-0;
                    tag-row-1: root.entity-tag-row-1;
                    tag-row-2: root.entity-tag-row-2;
                    tag-row-3: root.entity-tag-row-3;
                    suggestions: root.tag-suggestions;
                    input-text <=> root.tag-input-text;
                    add-tag(name) => { root.on-tag-add(name); }
                    remove-tag(name) => { root.on-tag-remove(name); }
                    select-tagged(name) => { root.on-tag-select-tagged(name); }
                    rename-requested(name) => { root.on-tag-rename-request(name); }
                    input-focus-changed(f) => { root.on-input-focus-changed(f); }
                }

                for prop in root.properties: VerticalLayout {
                    spacing: 0px;
                    // Hide collapsed rows (height 0 + invisible)
                    visible: prop.is-header || !prop.section-collapsed;
                    height: (prop.is-header || !prop.section-collapsed) ? self.preferred-height : 0px;
                    
                    // Category header — fires on-section-toggle so Rust updates section-collapsed
                    if prop.is-header: SectionHeader {
                        title: prop.category;
                        category: prop.category;
                        expanded: !prop.section-collapsed;
                        clicked => { root.on-section-toggle(prop.category); }
                        add-clicked => { root.on-add-attribute(); }
                    }
                    
                    // UDim2 property (Roblox-parity 2D layout: Position / Size)
                    if !prop.is-header && !prop.section-collapsed && prop.property-type == "udim2": UDim2Row {
                        label: prop.name;
                        x-scale: prop.x-scale;
                        x-offset: prop.x-offset;
                        y-scale: prop.y-scale;
                        y-offset: prop.y-offset;
                        editable: prop.editable;
                        description: prop.description;
                        learn-url: prop.learn-url;
                        show-help-icons: root.show-help-icons;
                        value-changed(val) => { root.on-property-changed(prop.name, val); }
                        open-learn-url(url) => { root.on-open-learn-url(url); }
                        focus-changed(focused) => { root.on-input-focus-changed(focused); }
                        copy-vector(val) => { root.on-copy-property-vector(prop.name, val); }
                    }

                    // Vec2 property — pure-pixel Vector2 (AnchorPoint, SizeOffset, …).
                    // Uses the same X/Y accent-bar layout as Vec3Row, just
                    // without the Z field, so SizeOffset no longer falls
                    // through to PropRow's ugly comma-string text input.
                    if !prop.is-header && !prop.section-collapsed && prop.property-type == "vec2": Vec2Row {
                        label: prop.name;
                        x-value: prop.x-value;
                        y-value: prop.y-value;
                        editable: prop.editable;
                        description: prop.description;
                        learn-url: prop.learn-url;
                        show-help-icons: root.show-help-icons;
                        value-changed(val) => { root.on-property-changed(prop.name, val); }
                        open-learn-url(url) => { root.on-open-learn-url(url); }
                        focus-changed(focused) => { root.on-input-focus-changed(focused); }
                        copy-vector(val) => { root.on-copy-property-vector(prop.name, val); }
                    }

                    // Vec3 property (position, scale)
                    if !prop.is-header && !prop.section-collapsed && prop.property-type == "vec3": Vec3Row {
                        label: prop.name;
                        value: prop.value;
                        x-value: prop.x-value;
                        y-value: prop.y-value;
                        z-value: prop.z-value;
                        editable: prop.editable;
                        description: prop.description;
                        learn-url: prop.learn-url;
                        show-help-icons: root.show-help-icons;
                        value-changed(val) => { root.on-property-changed(prop.name, val); }
                        open-learn-url(url) => { root.on-open-learn-url(url); }
                        focus-changed(focused) => { root.on-input-focus-changed(focused); }
                        copy-vector(val) => { root.on-copy-property-vector(prop.name, val); }
                        paste-vector() => { root.on-paste-property-vector(prop.name); }
                    }

                    // Rotation property — degrees with +/- buttons, supports negatives
                    if !prop.is-header && !prop.section-collapsed && prop.property-type == "rotation": RotationVec3Row {
                        label: prop.name;
                        value: prop.value;
                        x-value: prop.x-value;
                        y-value: prop.y-value;
                        z-value: prop.z-value;
                        editable: prop.editable;
                        description: prop.description;
                        learn-url: prop.learn-url;
                        show-help-icons: root.show-help-icons;
                        value-changed(val) => { root.on-property-changed(prop.name, val); }
                        open-learn-url(url) => { root.on-open-learn-url(url); }
                        focus-changed(focused) => { root.on-input-focus-changed(focused); }
                        copy-vector(val) => { root.on-copy-property-vector(prop.name, val); }
                        paste-vector() => { root.on-paste-property-vector(prop.name); }
                    }
                    
                    // Color property
                    if !prop.is-header && !prop.section-collapsed && prop.property-type == "color": ColorRow {
                        label: prop.name;
                        value: prop.value;
                        preview-color: prop.color-value;
                        editable: prop.editable;
                        description: prop.description;
                        learn-url: prop.learn-url;
                        show-help-icons: root.show-help-icons;
                        value-changed(val) => { root.on-property-changed(prop.name, val); }
                        open-learn-url(url) => { root.on-open-learn-url(url); }
                        focus-changed(focused) => { root.on-input-focus-changed(focused); }
                    }

                    // BrickColor property — 7-wheel hexagon picker. All seven
                    // honeycombs come from the panel-level props (Rust pushes
                    // them once); the two-step drill is local to BrickColorRow.
                    if !prop.is-header && !prop.section-collapsed && prop.property-type == "brickcolor": BrickColorRow {
                        label: prop.name;
                        value: prop.value;
                        preview-color: prop.color-value;
                        editable: prop.editable;
                        description: prop.description;
                        learn-url: prop.learn-url;
                        show-help-icons: root.show-help-icons;
                        aether-honeycomb: root.aether-honeycomb;
                        halo-honeycomb: root.halo-honeycomb;
                        verdure-honeycomb: root.verdure-honeycomb;
                        stone-honeycomb: root.stone-honeycomb;
                        char-honeycomb: root.char-honeycomb;
                        hex-honeycomb: root.hex-honeycomb;
                        umbra-honeycomb: root.umbra-honeycomb;
                        value-changed(val) => { root.on-property-changed(prop.name, val); }
                        open-learn-url(url) => { root.on-open-learn-url(url); }
                    }

                    // Bool property
                    if !prop.is-header && !prop.section-collapsed && prop.property-type == "bool": BoolRow {
                        label: prop.name;
                        value: prop.value;
                        editable: prop.editable;
                        description: prop.description;
                        learn-url: prop.learn-url;
                        show-help-icons: root.show-help-icons;
                        value-changed(val) => { root.on-property-changed(prop.name, val); }
                        open-learn-url(url) => { root.on-open-learn-url(url); }
                    }
                    
                    // Material — searchable dropdown with all MaterialService options
                    if !prop.is-header && !prop.section-collapsed && prop.property-type == "material": MaterialDropdown {
                        label: prop.name;
                        value: prop.value;
                        options: prop.options;
                        editable: prop.editable;
                        description: prop.description;
                        learn-url: prop.learn-url;
                        show-help-icons: root.show-help-icons;
                        value-changed(val) => { root.on-property-changed(prop.name, val); }
                        open-learn-url(url) => { root.on-open-learn-url(url); }
                        focus-changed(focused) => { root.on-input-focus-changed(focused); }
                        find-material-by-key(key, current-idx) => { root.on-find-material-by-key(key, current-idx) }
                    }

                    // Unit — same generic dropdown component as Material,
                    // populated with the 6 canonical unit symbols. The
                    // writer reinterprets existing dimensional values
                    // when this changes (see `apply_property_to_toml_value`).
                    if !prop.is-header && !prop.section-collapsed && prop.property-type == "unit": MaterialDropdown {
                        label: prop.name;
                        value: prop.value;
                        options: prop.options;
                        editable: prop.editable;
                        description: prop.description;
                        learn-url: prop.learn-url;
                        show-help-icons: root.show-help-icons;
                        value-changed(val) => { root.on-property-changed(prop.name, val); }
                        open-learn-url(url) => { root.on-open-learn-url(url); }
                        focus-changed(focused) => { root.on-input-focus-changed(focused); }
                        find-material-by-key(key, current-idx) => { root.on-find-material-by-key(key, current-idx) }
                    }

                    // String / float / int / enum — generic row
                    if !prop.is-header && !prop.section-collapsed && prop.property-type != "vec2" && prop.property-type != "vec3" && prop.property-type != "rotation" && prop.property-type != "color" && prop.property-type != "brickcolor" && prop.property-type != "bool" && prop.property-type != "material" && prop.property-type != "unit" && prop.property-type != "udim2": PropRow {
                        label: prop.name;
                        value: prop.value;
                        prop-type: prop.property-type;
                        editable: prop.editable;
                        description: prop.description;
                        learn-url: prop.learn-url;
                        show-help-icons: root.show-help-icons;
                        is-attribute: prop.is-attribute;
                        attribute-type: prop.attribute-type;
                        value-changed(val) => { root.on-property-changed(prop.name, val); }
                        open-learn-url(url) => { root.on-open-learn-url(url); }
                        focus-changed(focused) => { root.on-input-focus-changed(focused); }
                        gear-clicked(n, t, v) => { root.on-attribute-edit(n, t, v); }
                        trash-clicked(n) => { root.on-attribute-delete(n); }
                    }
                }
            }
        }
    }
}
