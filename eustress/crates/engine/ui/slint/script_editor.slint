// ============================================================================
// Eustress Engine Studio - Script Editor
// Tabbed code editor for Soul scripts
// ============================================================================

import { VerticalBox, HorizontalBox, ScrollView, TextEdit } from "std-widgets.slint";
import { Theme } from "theme.slint";

// ─────────────────────────────────────────────────────────────────────────────
// Shared structs used by EustressTextEdit and the outer ScriptEditor. Defined
// at the top of the file because Slint name resolution is single-pass / top-
// down — the EustressTextEdit component below declares a
// `<[TokenSpan]>` property and must see the struct's definition already.
// ─────────────────────────────────────────────────────────────────────────────

// One highlighted line: Rust pre-joins all tokens for the line into a single
// text string and picks the dominant (first non-whitespace token) color.
export struct HighlightLine {
    text: string,  // full line text
    r: float,      // foreground color [0..1]
    g: float,
    b: float,
    bold: bool,    // true for headings, keywords, etc.
}

// Per-token span for true syntax highlighting.
// Each token has its own color and is positioned by character offset.
// Monospace: x = col * char_width (computed Rust-side for pixel precision).
export struct TokenSpan {
    line: int,     // 0-based line index
    x: float,      // x pixel offset from left edge
    text: string,  // token text
    r: float,      // foreground [0..1]
    g: float,
    b: float,
    bold: bool,
}

// One analyzer diagnostic, positioned for drawing as an underline squiggle
// under the offending text. `line` is 0-based; `x_start`/`x_end` are pixel
// offsets. `severity` is one of "error" | "warning" | "info" | "hint" — the
// renderer picks the color. Populated by Rust from `ScriptAnalysis`.
export struct DiagnosticSpan {
    line: int,
    x_start: float,
    x_end: float,
    severity: string,
    message: string,
}

// ─────────────────────────────────────────────────────────────────────────────
// EustressTextEdit — local replacement for std-widgets TextEdit.
//
// Slint's TextEdit bakes its own ContextMenuArea inside, so we can't add icons
// or our own items (Copy Path, future Find / Go To Line, etc.) to its Cut /
// Copy / Paste menu. The token-span syntax-highlighting overlay we draw on
// top of TextEdit is also a thing we own already, so owning the editor itself
// is the smaller step.
//
// This component mirrors TextEditBase's public surface (text / font / wrap /
// edited / key-pressed / set-selection-offsets / cut / copy / paste /
// select-all / has-focus) so existing callers swap in without changes, and
// wraps the inner TextInput in our own ContextMenuArea with MenuItem + icon.
// ─────────────────────────────────────────────────────────────────────────────
component EustressTextEdit inherits Rectangle {
    in-out property <string> text;
    in property <length> font-size;
    in property <string> font-family;
    in property <TextWrap> wrap: word-wrap;
    in property <bool> read-only: false;
    in property <brush> foreground: Theme.text-primary;
    out property <bool> has-focus: text-input.has-focus;

    // Syntax-highlight overlay. Per-token positioned Text elements that
    // render INSIDE the Flickable so they scroll atomically with the
    // TextInput — no manual scroll-tracking, no ghost lines. Callers
    // push a list of `TokenSpan`s (line + x + text + color) and flip
    // `has-token-spans` when highlighting is available.
    in property <[TokenSpan]> token-spans: [];
    in property <bool> has-token-spans: false;

    // Current viewport offset of the inner Flickable. Retained as an
    // output for sibling overlays (line-number gutter, diagnostic
    // squiggles) that aren't children of this component and therefore
    // have to offset themselves. Exposed as read-only.
    out property <length> scroll-x: flick.viewport-x;
    out property <length> scroll-y: flick.viewport-y;

    callback edited(text: string);
    callback key-pressed(event: KeyEvent) -> EventResult;
    /// Fired when the user picks "Go to Definition". `line` and `column`
    /// are 1-based and derived from the right-click position via monospace
    /// math (CHAR_WIDTH = 7.8px, LINE_HEIGHT = 18px). Rust resolves the
    /// symbol at that cursor position via the analyzer's SymbolIndex.
    callback go-to-definition(int, int);
    /// Fired when the user picks "Find References". Same coord convention.
    callback find-references(int, int);

    // Public API matching TextEditBase so scroll-to-top-trigger and friends
    // keep working with the same call sites.
    public function set-selection-offsets(start: int, end: int) {
        text-input.set-selection-offsets(start, end);
    }
    public function select-all() { text-input.select-all(); }
    public function clear-selection() { text-input.clear-selection(); }
    public function cut() { text-input.cut(); }
    public function copy() { text-input.copy(); }
    public function paste() { text-input.paste(); }

    forward-focus: text-input;

    // Tracks the last known caret line/col (1-based) so F12 / Shift+F12
    // can dispatch Go-to-Def / Find-Refs without needing pixel coords
    // from a right-click. Updated by `cursor-position-changed` on the
    // inner TextInput.
    property <int> caret-line: 1;
    property <int> caret-col: 1;

    // Slint's `ContextMenuArea` owns the right-click hook AND the popup
    // rendering; the popup's width is floored by the active style's
    // `MenuFrame.layout-min-width` (fluent = 280px). We can't narrow it
    // without shipping a custom style, so we live with the 280px and
    // use real Slint `MenuItem`s here — icons render because the
    // fluent MenuItem honours the `icon: image` property at 12px.
    //
    // Go-to-Definition and Find-References don't belong in this menu
    // because they need the caret position, not the mouse position —
    // see F12 / Shift+F12 bindings in the TextInput below.
    ContextMenuArea {
        Menu {
            MenuItem {
                title: "Cut";
                icon: @image-url("../../assets/icons/ui/cut.svg");
                enabled: !root.read-only;
                activated => { text-input.cut(); }
            }
            MenuItem {
                title: "Copy";
                icon: @image-url("../../assets/icons/ui/copy.svg");
                enabled: !root.text.is-empty;
                activated => { text-input.copy(); }
            }
            MenuItem {
                title: "Paste";
                icon: @image-url("../../assets/icons/ui/paste.svg");
                enabled: !root.read-only;
                activated => { text-input.paste(); }
            }
            MenuSeparator {}
            MenuItem {
                title: "Select All";
                icon: @image-url("../../assets/icons/ui/select.svg");
                enabled: !root.text.is-empty;
                activated => { text-input.select-all(); }
            }
        }

        // Flickable is transparent by default — the overlay token-span Text
        // elements underneath show through. std-widgets' ScrollView would
        // paint fluent's opaque `Palette.background` over them.
        flick := Flickable {
            x: 0px; y: 0px;
            width: parent.width;
            height: parent.height;
            viewport-width: root.wrap == TextWrap.no-wrap
                ? max(self.width, text-input.preferred-width)
                : self.width;
            viewport-height: max(self.height, text-input.preferred-height);

            // Syntax-highlight overlay — rendered INSIDE the Flickable's
            // viewport as a sibling of the TextInput. Because they share the
            // same scrolling parent, the overlay automatically moves with the
            // text on scroll — no manual scroll-tracking, no ghost lines.
            // Must come BEFORE the TextInput in z-order so the caret and
            // selection highlight stay on top.
            if root.has-token-spans: Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                background: transparent;

                for span in root.token-spans: Text {
                    x: span.x * 1px + 12px;
                    y: span.line * 18px + 5px;
                    text: span.text;
                    color: rgba(span.r, span.g, span.b, 1.0);
                    font-size: 13px;
                    font-family: "Consolas";
                    font-weight: span.bold ? 700 : 400;
                    height: 18px;
                    wrap: no-wrap;
                }
            }

            text-input := TextInput {
                x: 0px; y: 0px;
                width: parent.width;
                height: parent.height;
                enabled: true;
                single-line: false;
                wrap <=> root.wrap;
                font-size <=> root.font-size;
                font-family <=> root.font-family;
                color <=> root.foreground;
                text <=> root.text;
                read-only <=> root.read-only;
                page-height: flick.height;
                accessible-role: none;

                edited => { root.edited(self.text); }

                // Track caret via pixel position → 1-based line/col.
                // Monospace math: line = y/18 + 1, col = x/7.8 + 1.
                cursor-position-changed(pos) => {
                    root.caret-line = (pos.y / 18px) + 1;
                    root.caret-col = max(1, (pos.x / 7.8px) + 1);
                }

                // F12 = Go to Definition, Shift+F12 = Find References.
                // These use the caret we just tracked, which is the
                // VS Code convention and also removes our dependency on
                // a right-click menu for those actions.
                key-pressed(event) => {
                    if (event.text == Key.F12) {
                        if (event.modifiers.shift) {
                            root.find-references(root.caret-line, root.caret-col);
                        } else {
                            root.go-to-definition(root.caret-line, root.caret-col);
                        }
                        return accept;
                    }
                    root.key-pressed(event)
                }
            }
        }
    }
}

// (TokenSpan / HighlightLine / DiagnosticSpan moved above EustressTextEdit
// so the component can declare a `<[TokenSpan]>` property. Slint resolves
// names top-down in a single file, so struct definitions must precede
// the components that reference them.)

// Center tab types: "scene" = 3D viewport, "script" = Soul Script, "web" = browser
// Tab data model for the center tabbed viewer
export struct CenterTab {
    entity-id: int,      // Entity ID for script tabs (-1 for web/scene)
    name: string,        // Display name / page title
    tab-type: string,    // "scene", "script", "web", "code"
    mode: string,        // SoulScript mode: "summary" (md preview) or "code" (editor), "" for others
    dirty: bool,         // Unsaved changes indicator
    content: string,     // Script content or HTML
    url: string,         // URL for web tabs
    loading: bool,       // Loading state for web tabs
    favicon: image,      // Favicon for web tabs
    can-go-back: bool,   // Browser navigation state
    can-go-forward: bool,
}

// Backward-compatible alias
export struct ScriptTab {
    entity-id: int,
    name: string,
    dirty: bool,
    content: string,
}

component EditorTab inherits Rectangle {
    in property <string> name: "";
    in property <bool> dirty: false;
    in property <bool> active: false;
    
    callback clicked();
    callback close();
    
    height: 32px;
    min-width: 100px;
    max-width: 200px;
    background: self.active ? Theme.tab-active : Theme.tab-inactive;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    
    HorizontalBox {
        padding-left: 12px;
        padding-right: 4px;
        spacing: 4px;
        
        TouchArea {
            horizontal-stretch: 1;
            clicked => { root.clicked(); }
            
            HorizontalBox {
                Text {
                    text: root.name;
                    color: root.active ? Theme.text-primary : Theme.text-secondary;
                    vertical-alignment: center;
                    overflow: elide;
                }
                
                if root.dirty: Text {
                    text: "●";
                    color: Theme.text-warning;
                    font-size: 10px;
                    vertical-alignment: center;
                }
            }
        }
        
        // Close button
        Rectangle {
            width: 20px;
            height: 20px;
            background: close-touch.has-hover ? Theme.button-hover : transparent;
            border-radius: 4px;
            
            close-touch := TouchArea {
                clicked => { root.close(); }
            }
            
            Image {
                width: 10px;
                height: 10px;
                source: @image-url("../../assets/icons/ui/close.svg");
                image-fit: contain;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

export component ScriptEditor inherits Rectangle {
    // Properties
    in property <[CenterTab]> tabs: [];
    in property <int> active-tab: 0;
    in-out property <string> current-content: "";
    in property <int> cursor-line: 1;
    in property <int> cursor-column: 1;
    in property <bool> show-tab-bar: true;
    // Pre-computed line number string pushed from Rust (e.g. "1\n2\n3\n...N").
    // Kept for backwards compatibility with any other consumers; the gutter
    // itself now uses `line-numbers-array` so each digit sits on the same
    // 18px grid as the token-span overlay (no font-metric drift).
    in property <string> line-numbers-text: "1";
    // One entry per source line, e.g. ["1", "2", "3", ...]. The gutter
    // renders one Text per entry at `y: idx * 18px + 5px`, locking
    // alignment to the code overlay.
    in property <[string]> line-numbers-array: ["1"];
    // Set to true by Rust after loading new tab content; resets editor scroll to line 1.
    // Slint watches this and calls set-selection-offsets(0,0) on the TextEdit.
    in-out property <bool> scroll-to-top-trigger: false;
    // Syntax-highlighted lines pushed from Rust on every content change.
    // One entry per source line. Empty = highlighting inactive (plain TextEdit).
    in property <[HighlightLine]> highlight-lines: [];
    in property <bool> has-highlights: false;
    // Per-token spans for true syntax highlighting (replaces per-line coloring)
    in property <[TokenSpan]> token-spans: [];
    in property <bool> has-token-spans: false;
    // Analyzer diagnostics rendered as colored underlines under offending text.
    // Colors: error = red, warning = amber, info = blue, hint = grey.
    in property <[DiagnosticSpan]> diagnostic-spans: [];

    // Callbacks
    callback on-tab-selected(int);
    callback on-tab-closed(int);
    callback on-content-changed(string);
    callback on-save();
    callback on-build();
    callback on-summarize();        // Reverse build: generate summary from code via Claude
    callback on-toggle-mode(int);   // Toggle summary/code for tab at index
    callback on-go-to-definition(int, int);   // line, col (1-based)
    callback on-find-references(int, int);    // line, col (1-based)

    // Derived: active tab mode ("summary" | "code" | "markdown" | "")
    //
    // `is-soul-script` gates the Summary/Code toggle pill + the Build
    // button — those only make sense for a real Soul Script, where
    // Build compiles the summary brief into .rune code. Plain
    // markdown documents (README, PATENT, etc.) use the same editor
    // surface via `mode = "markdown"` but without those controls.
    //
    // `is-summary` selects the Summary editor surface (markdown view).
    // We treat "markdown" mode as summary-like so plain-MD tabs render
    // their content in the same editor; no Code view exists for them.
    property <string> active-mode: root.tabs.length > 0 && root.active-tab >= 0 && root.active-tab < root.tabs.length
        ? root.tabs[root.active-tab].mode
        : "";
    property <bool> is-soul-script: root.active-mode == "summary" || root.active-mode == "code";
    property <bool> is-summary: root.active-mode == "summary" || root.active-mode == "markdown";

    background: Theme.panel-background;

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // Tab bar
        if root.show-tab-bar: Rectangle {
            height: 32px;
            background: Theme.background-secondary;

            HorizontalBox {
                padding-left: 4px;
                spacing: 2px;

                for tab[index] in root.tabs: EditorTab {
                    name: tab.name;
                    dirty: tab.dirty;
                    active: index == root.active-tab;

                    clicked => { root.on-tab-selected(index); }
                    close => { root.on-tab-closed(index); }
                }

                Rectangle { horizontal-stretch: 1; }
            }
        }

        // Toolbar
        Rectangle {
            height: 32px;
            background: Theme.header-background;

            HorizontalBox {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;

                // Summary / Code mode toggle pill — green theme (only for SoulScript tabs)
                if root.is-soul-script: Rectangle {
                    width: 150px;
                    height: 26px;
                    border-radius: 4px;
                    background: #1a2e1a;

                    HorizontalLayout {
                        padding: 2px;
                        spacing: 2px;

                        // Summary button. We center the icon+text pair using a
                        // HorizontalLayout with leading and trailing spacer
                        // Rectangles — simpler than fighting Text's default
                        // horizontal-stretch, which would otherwise push the
                        // label right and leave the icon hugging the left edge.
                        Rectangle {
                            horizontal-stretch: 1;
                            border-radius: 3px;
                            background: root.is-summary ? #2e7d32 : transparent;

                            summary-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    if !root.is-summary {
                                        root.on-toggle-mode(root.active-tab);
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 4px;
                                Rectangle { horizontal-stretch: 1; }
                                Image {
                                    // Drop explicit height so the layout cell's
                                    // full height is the Image element bounds;
                                    // `image-fit: contain` + `vertical-alignment: center`
                                    // then center the glyph within that taller bound.
                                    width: 14px;
                                    source: @image-url("../../assets/icons/ui/summary.svg");
                                    image-fit: contain;
                                    vertical-alignment: center;
                                    colorize: root.is-summary ? white : #66bb6a;
                                }
                                Text {
                                    text: "Summary";
                                    font-size: 11px;
                                    color: root.is-summary ? white : #66bb6a;
                                    vertical-alignment: center;
                                    horizontal-stretch: 0;
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }
                        }

                        // Code button
                        Rectangle {
                            horizontal-stretch: 1;
                            border-radius: 3px;
                            background: !root.is-summary && root.is-soul-script ? #2e7d32 : transparent;

                            code-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    if root.is-summary {
                                        root.on-toggle-mode(root.active-tab);
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 4px;
                                Rectangle { horizontal-stretch: 1; }
                                Image {
                                    width: 14px;
                                    source: @image-url("../../assets/icons/script.svg");
                                    image-fit: contain;
                                    vertical-alignment: center;
                                    colorize: !root.is-summary && root.is-soul-script ? white : #66bb6a;
                                }
                                Text {
                                    text: "Code";
                                    font-size: 11px;
                                    color: !root.is-summary && root.is-soul-script ? white : #66bb6a;
                                    vertical-alignment: center;
                                    horizontal-stretch: 0;
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }
                        }
                    }
                }

                // Spacer pushes action buttons to the far right
                Rectangle { horizontal-stretch: 1; }

                // Build button — only in Summary mode (build generates code from summary)
                if root.is-summary && root.is-soul-script: Rectangle {
                    width: 70px;
                    height: 26px;
                    background: build-ta.has-hover ? #388e3c : #2e7d32;
                    border-radius: 4px;

                    build-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-build(); }
                    }

                    HorizontalLayout {
                        spacing: 4px;
                        Rectangle { horizontal-stretch: 1; }
                        Image {
                            width: 14px;
                            source: @image-url("../../assets/icons/ui/build.svg");
                            image-fit: contain;
                            vertical-alignment: center;
                            colorize: white;
                        }
                        Text {
                            text: "Build"; color: white;
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-stretch: 0;
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }
                }

                // Summarize button — only in Code mode (generates summary from code)
                if !root.is-summary && root.is-soul-script: Rectangle {
                    width: 105px;
                    height: 26px;
                    background: summarize-ta.has-hover ? #1a4a2a : #152a1e;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: summarize-ta.has-hover ? #4caf50 : #2a5a32;

                    summarize-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-summarize(); }
                    }

                    HorizontalLayout {
                        spacing: 4px;
                        Rectangle { horizontal-stretch: 1; }
                        Image {
                            width: 14px;
                            source: @image-url("../../assets/icons/ui/summary.svg");
                            image-fit: contain;
                            vertical-alignment: center;
                            colorize: summarize-ta.has-hover ? #a5d6a7 : #66bb6a;
                        }
                        Text {
                            text: "Summarize";
                            color: summarize-ta.has-hover ? #a5d6a7 : #66bb6a;
                            font-size: 11px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 0;
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }
                }

                // Save button — far right, only in code mode
                if !root.is-summary: Rectangle {
                    width: 60px;
                    height: 24px;
                    background: Theme.button-background;
                    border-radius: 4px;

                    TouchArea { clicked => { root.on-save(); } }

                    HorizontalBox {
                        padding: 4px;
                        spacing: 4px;
                        Image {
                            width: 14px; height: 14px;
                            source: @image-url("../../assets/icons/ui/save.svg");
                            image-fit: contain; vertical-alignment: center;
                        }
                        Text {
                            text: "Save"; color: Theme.text-primary;
                            font-size: 12px; vertical-alignment: center;
                        }
                    }
                }

                // Cursor position — rightmost, code mode only
                if !root.is-summary: Text {
                    text: "Ln " + root.cursor-line + ", Col " + root.cursor-column;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }

        // Empty state
        if root.tabs.length == 0: Rectangle {
            vertical-stretch: 1;
            background: Theme.viewport-background;

            VerticalBox {
                alignment: center;

                Image {
                    width: 48px; height: 48px;
                    source: @image-url("../../assets/icons/ui/new-file.svg");
                    image-fit: contain;
                    horizontal-alignment: center;
                }

                Text {
                    text: "No files open";
                    color: Theme.text-secondary;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Double-click a .rune, .soul, or .md file in the Explorer";
                    color: Theme.text-disabled;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
            }
        }

        // Summary / Markdown preview mode
        // Summary mode — full markdown editor (editable, monospace, line numbers)
        if root.tabs.length > 0 && root.is-summary: Rectangle {
            vertical-stretch: 1;
            background: #1a1a1a;

            HorizontalLayout {
                spacing: 0px;

                // Line number gutter — one Text per line, explicitly
                // positioned on the shared 18px grid.
                Rectangle {
                    width: 52px;
                    background: #141414;
                    clip: true;

                    for num[idx] in root.line-numbers-array: Text {
                        x: 0px;
                        y: idx * 18px + 5px;
                        width: parent.width - 10px;
                        height: 18px;
                        text: num;
                        color: Theme.text-secondary;
                        font-size: 13px;
                        font-family: "Consolas";
                        horizontal-alignment: right;
                        vertical-alignment: center;
                        wrap: no-wrap;
                    }
                }

                // Separator
                Rectangle { width: 1px; background: #2a2a2a; }

                // Editable markdown text area with per-token highlighting.
                //
                // Syntax-highlight overlay is pushed INTO the EustressTextEdit
                // via `token-spans` — the overlay then lives inside the
                // editor's own Flickable and scrolls atomically with the
                // text. A previous version sat an external overlay Rectangle
                // alongside this edit, which didn't share the scroll
                // parent and produced ghost-duplicate lines when the user
                // scrolled down. Mirror the Code-mode editor below, which
                // has the correct wiring.
                Rectangle {
                    horizontal-stretch: 1;
                    clip: true;

                    summary-edit := EustressTextEdit {
                        x: 0px; y: 0px; width: 100%; height: 100%;
                        text: root.current-content;
                        font-size: 13px;
                        font-family: "Consolas";
                        wrap: no-wrap;
                        token-spans: root.token-spans;
                        has-token-spans: root.has-token-spans;
                        // Keep the TextInput's own glyphs visible (dim)
                        // beneath the coloured overlay. If the overlay is
                        // ever stale during a scroll flush, the plain
                        // text still reads through instead of leaving
                        // ghost duplicates of old spans on screen.
                        foreground: Theme.text-primary;

                        edited(text) => {
                            root.current-content = text;
                            root.on-content-changed(text);
                        }
                    }
                }
            }
        }

        // Code mode — text editor with synchronized line number gutter.
        // The gutter shows a 3px colored left-accent strip per line derived
        // from the dominant token color when highlight-lines are available.
        if root.tabs.length > 0 && !root.is-summary: Rectangle {
            vertical-stretch: 1;
            background: Theme.viewport-background;

            HorizontalLayout {
                spacing: 0px;

                // Line numbers gutter — fixed 52px column
                Rectangle {
                    width: 52px;
                    background: Theme.background-secondary;
                    clip: true;

                    // Colored accent strips (one per line, 18px tall) when highlights active.
                    // Per-child `+ scroll-y` on each strip so they move in
                    // lockstep with the line numbers and code above. The
                    // outer Rectangle is just a scope holder — Slint
                    // doesn't allow `if … for …` in a single binding.
                    if root.has-highlights: Rectangle {
                        x: 0;
                        y: 0;
                        width: 3px;
                        height: 100%;

                        for hl[idx] in root.highlight-lines: Rectangle {
                            x: 0;
                            y: idx * 18px + 5px + editor-area.scroll-y;
                            width: 3px;
                            height: 18px;
                            background: rgba(hl.r, hl.g, hl.b, 0.55);
                        }
                    }

                    // Line number text — one Text per line on the same
                    // 18px grid as the code overlay. Per-child `+ scroll-y`
                    // keeps each number aligned with its matching code line
                    // as the Flickable viewport moves. Must mirror the token
                    // overlay's per-child approach exactly, or the gutter
                    // desyncs from code during fast scrolls.
                    Rectangle {
                        x: 0;
                        y: 0;
                        width: 100%;
                        height: 100%;
                        background: transparent;

                        for num[idx] in root.line-numbers-array: Text {
                            x: 0px;
                            y: idx * 18px + 5px + editor-area.scroll-y;
                            width: parent.width - 10px;
                            height: 18px;
                            text: num;
                            color: Theme.text-secondary;
                            font-size: 13px;
                            font-family: "Consolas";
                            horizontal-alignment: right;
                            vertical-alignment: center;
                            wrap: no-wrap;
                        }
                    }
                }

                // Separator
                Rectangle {
                    width: 1px;
                    background: #2a2a2a;
                }

                // Code editor. Syntax highlighting is rendered INSIDE the
                // EustressTextEdit's Flickable now, so there's no external
                // overlay to keep in sync with scroll — the editor and its
                // overlay move together atomically.
                Rectangle {
                    horizontal-stretch: 1;
                    clip: true;

                    // Diagnostic squiggles + hover tooltip. The squiggle is a
                    // thin colored bar under the offending range; the
                    // invisible TouchArea sits OVER the offending text to
                    // register hover. On hover, a floating tooltip renders
                    // the diagnostic message above the squiggle.
                    //
                    // Same translation trick as the token-span overlay above:
                    // `+ editor-area.scroll-x/y` keeps the squiggle locked to
                    // its underlying text as the user scrolls.
                    for diag in root.diagnostic-spans: Rectangle {
                        x: diag.x_start * 1px + 12px + editor-area.scroll-x;
                        y: diag.line * 18px + 5px + editor-area.scroll-y;
                        width: max(4px, (diag.x_end - diag.x_start) * 1px);
                        height: 18px;

                        // Underline bar (at the bottom of the hovered area).
                        Rectangle {
                            x: 0px;
                            y: 16px;
                            width: parent.width;
                            height: 2px;
                            background: diag.severity == "error"   ? #e53935
                                      : diag.severity == "warning" ? #fb8c00
                                      : diag.severity == "info"    ? #1e88e5
                                      :                               #757575;
                        }

                        diag-hover := TouchArea {
                            mouse-cursor: text;
                        }

                        // Tooltip — only renders on hover. Wraps long
                        // messages; sits above the squiggle so the line
                        // being annotated stays visible.
                        if diag-hover.has-hover: Rectangle {
                            x: 0px;
                            y: -6px - tooltip-text.preferred-height;
                            width: min(420px, max(160px, tooltip-text.preferred-width + 16px));
                            height: tooltip-text.preferred-height + 10px;
                            background: #1e1f2e;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: diag.severity == "error"   ? #e53935
                                        : diag.severity == "warning" ? #fb8c00
                                        : diag.severity == "info"    ? #1e88e5
                                        :                               #555;
                            drop-shadow-blur: 12px;
                            drop-shadow-color: #00000088;
                            z: 100;

                            tooltip-text := Text {
                                x: 8px;
                                y: 5px;
                                width: parent.width - 16px;
                                text: diag.message;
                                color: Theme.text-primary;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    // Editable EustressTextEdit — transparent when token spans
                    // are active so the syntax-highlight overlay above shows
                    // through. Owns its own right-click menu (Cut/Copy/Paste/
                    // Select All / Go to Def / Find References with icons).
                    editor-area := EustressTextEdit {
                        x: 0px; y: 0px; width: 100%; height: 100%;
                        text: root.current-content;
                        font-size: 13px;
                        font-family: "Consolas";
                        wrap: no-wrap;
                        // Feed the syntax-highlight overlay INTO the editor.
                        // The overlay now lives inside the editor's Flickable
                        // and scrolls atomically with the text — no more
                        // ghost-line duplication from external scroll chase.
                        token-spans: root.token-spans;
                        has-token-spans: root.has-token-spans;
                        // Keep the TextInput's own glyphs visible. When the
                        // coloured overlay draws on top, the user sees
                        // highlighted code; when the overlay is rebuilding
                        // (e.g. mid-scroll or right after an edit), the
                        // plain text stays readable instead of vanishing
                        // into blank space or showing stale spans on top
                        // of now-different content.
                        foreground: Theme.text-primary;

                        edited(text) => {
                            root.current-content = text;
                            root.on-content-changed(text);
                        }
                        go-to-definition(line, col) => {
                            root.on-go-to-definition(line, col);
                        }
                        find-references(line, col) => {
                            root.on-find-references(line, col);
                        }
                    }

                    // Invisible sentinel: scroll-to-top-trigger
                    if root.scroll-to-top-trigger: TouchArea {
                        width: 0px; height: 0px;
                        init => {
                            editor-area.set-selection-offsets(0, 0);
                            root.scroll-to-top-trigger = false;
                        }
                    }
                }
            }
        }
    }
}
