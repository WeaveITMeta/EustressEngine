// ============================================================================
// Eustress Data Platform — Data Grid
// ============================================================================
// The spreadsheet view of a Dataset, living as a bottom-panel tab beside
// Output / Timeline. Columns are GENERIC — driven by the selected Dataset's
// schema (headers) + a row model fed from Rust (`sync_data_grid_to_selection`
// in slint_ui.rs), so the grid reflects whatever Dataset is selected in the
// Explorer, with any number of columns. The standalone preview uses samples.
//
// Preview:  slint-viewer --auto-reload data_grid.slint
// ============================================================================

import { Theme } from "theme.slint";
import { ScrollView } from "std-widgets.slint";

// One row of the generic grid: a flat list of pre-stringified cells, one per
// column. Rust pads ragged rows to the column count so cells align 1:1 with
// the header. Replaces the old fixed 4-column GridRow.
export struct DataGridRow {
    cells: [string],
}

component HeaderCell inherits Rectangle {
    in property <string> label: "";
    background: Theme.header-background;
    border-width: 1px;
    border-color: Theme.border-color;
    HorizontalLayout {
        padding-left: 8px;
        Text {
            text: root.label;
            color: Theme.text-secondary;
            font-size: 11px;
            font-weight: 600;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

component DataCell inherits Rectangle {
    in property <string> text: "";
    in property <color> tint: Theme.text-primary;
    background: transparent;
    HorizontalLayout {
        padding-left: 8px;
        Text {
            text: root.text;
            color: root.tint;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

export component DataGrid inherits Rectangle {
    // Generic schema-driven model, fed from Rust:
    in property <[string]> columns: [];        // header labels
    in property <[DataGridRow]> rows: [];      // row cells (cells.length == columns.length)
    in property <string> dataset-name: "";     // selected Dataset name (shown in the bar)
    in property <string> formula: "";          // calculated-column expr (Columns verb, later)
    // Bottom-panel mode (shared with Output / Timeline) so the in-grid tab
    // buttons can switch back. Mirrors OutputConsole / TimelinePanel.
    in-out property <string> panel-mode: "datagrid";
    callback set-panel-mode(string);

    background: Theme.panel-background;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // ── Tab strip + selected-Dataset context ──────────────────────────
        Rectangle {
            height: 30px;
            background: Theme.header-background;
            Rectangle { y: parent.height - 1px; width: 100%; height: 1px; background: Theme.border-color; }
            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 14px;
                Rectangle {
                    width: 52px;
                    TouchArea { mouse-cursor: pointer; clicked => { root.panel-mode = "output"; root.set-panel-mode("output"); } }
                    Text { text: "Output"; color: root.panel-mode == "output" ? Theme.text-primary : Theme.text-secondary; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle {
                    width: 60px;
                    TouchArea { mouse-cursor: pointer; clicked => { root.panel-mode = "timeline"; root.set-panel-mode("timeline"); } }
                    Text { text: "Timeline"; color: root.panel-mode == "timeline" ? Theme.text-primary : Theme.text-secondary; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle {
                    width: 64px;
                    TouchArea { mouse-cursor: pointer; clicked => { root.panel-mode = "datagrid"; root.set-panel-mode("datagrid"); } }
                    Text { text: "Data Grid"; color: root.panel-mode == "datagrid" ? Theme.accent-cyan : Theme.text-secondary; font-weight: root.panel-mode == "datagrid" ? 600 : 400; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                }
                Rectangle { horizontal-stretch: 1; }

                // Context: selected Dataset name + dimensions (blank until fed).
                Text {
                    text: root.dataset-name == "" ? "" : root.dataset-name + "  ·  " + root.rows.length + " rows × " + root.columns.length + " cols";
                    color: Theme.accent-cyan;
                    font-size: 11px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        // ── Column header row (generic — one HeaderCell per column) ────────
        HorizontalLayout {
            height: 24px;
            spacing: 0px;
            for col in root.columns: HeaderCell {
                horizontal-stretch: 1;
                min-width: 60px;
                label: col;
            }
        }

        // ── Empty state OR data rows ──────────────────────────────────────
        if root.columns.length == 0: Rectangle {
            vertical-stretch: 1;
            Text {
                text: "Select a Dataset in the Explorer to view its data.";
                color: Theme.text-disabled;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
        if root.columns.length > 0: ScrollView {
            vertical-stretch: 1;
            VerticalLayout {
                alignment: start;
                for row in root.rows: Rectangle {
                    height: 24px;
                    HorizontalLayout {
                        spacing: 0px;
                        for cell in row.cells: DataCell {
                            horizontal-stretch: 1;
                            min-width: 60px;
                            text: cell;
                        }
                    }
                }
            }
        }
    }
}

// Standalone preview with sample generic data (real grid is fed from Rust).
export component DataGridPreview inherits Window {
    title: "Eustress · Data Grid";
    preferred-width: 560px;
    preferred-height: 320px;
    background: Theme.background-primary;
    DataGrid {
        dataset-name: "GlobalTemperature";
        columns: ["year", "temp_anomaly (°C)"];
        rows: [
            { cells: ["2021", "0.85"] },
            { cells: ["2022", "0.89"] },
            { cells: ["2023", "1.17"] },
            { cells: ["2024", "1.28"] },
            { cells: ["2025", "1.19"] },
        ];
    }
}
