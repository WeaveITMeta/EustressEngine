// ============================================================================
// Eustress Data Platform — Chart view (live, interactive, data-driven)
// ============================================================================
// The center "Chart" tab. `sync_data_chart_to_slint` (Rust) reads the selected
// Dataset's CSV and pushes the series + linear-fit polylines (SVG Path commands
// in a 0..1000 x 0..600 viewbox), per-point markers, axis ticks, and the fit
// equation. Domain-agnostic — no baked data, no hardcoded units.
//
//   Increment 1: live data + auto-scale + fit equation
//   Increment 2: hover — per-point (X,Y) + fit-line equation tooltips
//   Increment 3: clickable Chart/Grid/Split/3D view modes
//   (axis range/interval inputs are a follow-up)
// ============================================================================

import { Theme } from "theme.slint";

// One plotted sample, in viewbox space + formatted data values (for hover).
export struct ChartPoint {
    px: float,    // viewbox x, 0..1000
    py: float,    // viewbox y, 0..600 (y-down)
    xv: string,   // formatted data x
    yv: string,   // formatted data y
}

// One clickable chip in the view switcher.
component Chip inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    in property <bool> clickable: true;
    in property <color> accent: Theme.accent-cyan;
    callback clicked;
    height: 22px;
    border-radius: 6px;
    background: (root.clickable && ta.has-hover) ? #14323a : (root.active ? #0e3a44 : Theme.button-background);
    border-width: 1px;
    border-color: root.active ? root.accent : Theme.border-color;
    ta := TouchArea {
        enabled: root.clickable;
        clicked => { root.clicked(); }
    }
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: root.label;
            color: root.active ? #7fe3f5 : Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
        }
    }
}

// One legend entry: a colored swatch line + text.
component LegendItem inherits HorizontalLayout {
    in property <string> label;
    in property <color> swatch: Theme.accent-cyan;
    spacing: 5px;
    VerticalLayout {
        alignment: center;
        Rectangle { width: 14px; height: 3px; border-radius: 1.5px; background: root.swatch; }
    }
    Text { text: root.label; color: Theme.text-secondary; font-size: 11px; vertical-alignment: center; }
}

// The plot — reused by Chart + Split modes.
component PlotBox inherits Rectangle {
    in property <string> y-label;
    in property <string> series-path;
    in property <string> fit-path;
    in property <string> fit-label;
    in property <[string]> x-ticks;
    in property <[string]> y-ticks;
    in property <[ChartPoint]> points;
    background: Theme.viewport-background;
    border-width: 1px;
    border-color: Theme.border-color;
    border-radius: 4px;
    clip: true;
    property <length> ml: 46px;
    property <length> mr: 14px;
    property <length> mt: 10px;
    property <length> mb: 20px;
    // Aspect-lock the plot to the 1000x500 viewbox so Slint's aspect-preserving
    // Path fills it exactly — then the line, dots, and gridlines share one
    // mapping and align. (sc = fit scale; pw/ph = plot size; px0/py0 = centered.)
    property <length> aw: self.width - self.ml - self.mr;
    property <length> ah: self.height - self.mt - self.mb;
    property <length> sc: (self.aw / 1000 > self.ah / 500) ? (self.ah / 500) : (self.aw / 1000);
    property <length> pw: 1000 * self.sc;
    property <length> ph: 500 * self.sc;
    property <length> px0: self.ml + (self.aw - self.pw) / 2;
    property <length> py0: self.mt + (self.ah - self.ph) / 2;

    // Horizontal gridlines + Y labels (top → bottom = ymax → ymin)
    for t[i] in root.y-ticks: Rectangle {
        x: root.px0;
        y: root.py0 + root.ph * i / 4;
        width: root.pw;
        height: 1px;
        background: #ffffff10;
        Text {
            x: -42px; y: -7px; width: 38px;
            text: t; color: Theme.text-disabled; font-size: 9px;
            horizontal-alignment: right;
        }
    }
    // Vertical gridlines + X labels (left → right = xmin → xmax)
    for t[i] in root.x-ticks: Rectangle {
        x: root.px0 + root.pw * i / 4;
        y: root.py0;
        width: 1px;
        height: root.ph;
        background: #ffffff08;
        Text {
            x: -18px; y: parent.height + 3px; width: 36px;
            text: t; color: Theme.text-disabled; font-size: 9px;
            horizontal-alignment: center;
        }
    }

    // Inner plot area — paths, fit-hover, per-point markers + hover
    inner := Rectangle {
        x: root.px0; y: root.py0;
        width: root.pw;
        height: root.ph;

        Path {
            viewbox-x: 0; viewbox-y: 0; viewbox-width: 1000; viewbox-height: 500;
            width: 100%; height: 100%;
            commands: root.fit-path;
            fill: transparent; stroke: #f5a524; stroke-width: 1.5px;
        }
        Path {
            viewbox-x: 0; viewbox-y: 0; viewbox-width: 1000; viewbox-height: 500;
            width: 100%; height: 100%;
            commands: root.series-path;
            fill: transparent; stroke: #38bdf8; stroke-width: 1.6px;
        }

        // Plot-background hover → fit equation tooltip (under the point markers)
        plot-ta := TouchArea {}
        if plot-ta.has-hover && root.fit-label != "": Rectangle {
            x: plot-ta.mouse-x + 12px;
            y: plot-ta.mouse-y - 22px;
            width: 198px; height: 18px;
            background: #11161fee; border-radius: 4px;
            border-width: 1px; border-color: #f5a524;
            Text {
                x: 6px; width: parent.width - 10px; vertical-alignment: center;
                text: root.fit-label; color: #ffd9a0; font-size: 10px; overflow: elide;
            }
        }

        // Per-point markers + (X,Y) hover (on top, so they win over plot-ta)
        for p in root.points: Rectangle {
            x: inner.width * (p.px / 1000) - 5px;
            y: inner.height * (p.py / 500) - 5px;
            width: 10px; height: 10px;
            pta := TouchArea {}
            Rectangle {
                x: 3px; y: 3px; width: 4px; height: 4px; border-radius: 2px;
                background: pta.has-hover ? #ffffff : #38bdf8;
            }
            if pta.has-hover: Rectangle {
                x: 10px; y: -4px; width: 110px; height: 20px;
                background: #11161fee; border-radius: 4px;
                border-width: 1px; border-color: #38bdf8;
                Text {
                    x: 6px; width: parent.width - 10px; vertical-alignment: center;
                    text: "(" + p.xv + ", " + p.yv + ")";
                    color: #cfe8ff; font-size: 10px; overflow: elide;
                }
            }
        }
    }

    Text {
        x: 6px; y: 3px;
        text: root.y-label; color: Theme.text-disabled; font-size: 9px;
    }
    if root.series-path == "": Text {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        text: "Open a Dataset's chart to plot its series";
        color: Theme.text-disabled; font-size: 11px;
    }
}

// The plotted series as a table — reused by Grid + Split modes.
component SeriesTable inherits Rectangle {
    in property <string> x-label;
    in property <string> y-label;
    in property <[ChartPoint]> points;
    background: Theme.viewport-background;
    border-width: 1px;
    border-color: Theme.border-color;
    border-radius: 4px;
    clip: true;
    VerticalLayout {
        Rectangle {
            height: 22px; background: #0e3a44;
            HorizontalLayout {
                padding-left: 10px; spacing: 8px;
                Text { text: root.x-label == "" ? "x" : root.x-label; color: #7fe3f5; font-size: 10px; vertical-alignment: center; width: 45%; }
                Text { text: root.y-label == "" ? "y" : root.y-label; color: #7fe3f5; font-size: 10px; vertical-alignment: center; }
            }
        }
        Flickable {
            VerticalLayout {
                alignment: start;
                for p in root.points: Rectangle {
                    height: 18px;
                    HorizontalLayout {
                        padding-left: 10px; spacing: 8px;
                        Text { text: p.xv; color: Theme.text-secondary; font-size: 10px; vertical-alignment: center; width: 45%; }
                        Text { text: p.yv; color: Theme.text-primary; font-size: 10px; vertical-alignment: center; }
                    }
                }
            }
        }
    }
}

// One editable axis-bound field — Enter applies the value; empty = auto.
component AxisField inherits Rectangle {
    in property <string> placeholder;
    in property <string> value;
    callback applied(string);
    width: 50px;
    height: 18px;
    background: #0d1420;
    border-width: 1px;
    border-color: Theme.border-color;
    border-radius: 3px;
    clip: true;
    ti := TextInput {
        x: 4px;
        width: parent.width - 8px;
        height: 100%;
        text: root.value;
        color: Theme.text-primary;
        font-size: 10px;
        vertical-alignment: center;
        single-line: true;
        accepted => { root.applied(self.text); }
    }
    if root.value == "" && !ti.has-focus: Text {
        x: 4px;
        height: 100%;
        vertical-alignment: center;
        text: root.placeholder;
        color: Theme.text-disabled;
        font-size: 10px;
    }
}

export component DataChartView inherits Rectangle {
    in property <string> title;
    in property <string> x-label;
    in property <string> y-label;
    in property <string> series-path;
    in property <string> fit-path;
    in property <string> fit-label;
    in property <[string]> x-ticks;
    in property <[string]> y-ticks;
    in property <[ChartPoint]> points;
    in-out property <string> xmin-in;
    in-out property <string> xmax-in;
    in-out property <string> ymin-in;
    in-out property <string> ymax-in;
    property <string> view-mode: "chart";
    background: Theme.panel-background;

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        // ── View switcher (clickable) ─────────────────────────────────────
        HorizontalLayout {
            height: 24px;
            spacing: 6px;
            Chip { label: "Chart"; active: root.view-mode == "chart"; clicked => { root.view-mode = "chart"; } }
            Chip { label: "Grid";  active: root.view-mode == "grid";  clicked => { root.view-mode = "grid"; } }
            Chip { label: "Split"; active: root.view-mode == "split"; clicked => { root.view-mode = "split"; } }
            Chip { label: "3D";    active: root.view-mode == "3d";    clicked => { root.view-mode = "3d"; } }
            Rectangle { horizontal-stretch: 1; }
            Chip { label: "Color by: " + (root.title == "" ? "—" : root.title); clickable: false; }
        }

        // ── Legend (series + live fit equation) ───────────────────────────
        HorizontalLayout {
            height: 16px;
            spacing: 16px;
            alignment: start;
            LegendItem { label: root.title == "" ? "Series" : root.title; swatch: #38bdf8; }
            LegendItem { label: root.fit-label == "" ? "Linear fit" : root.fit-label; swatch: #f5a524; }
        }

        // ── Axis range controls (type a value + Enter to apply; empty = auto) ─
        HorizontalLayout {
            height: 20px;
            spacing: 4px;
            alignment: start;
            Text { text: "X"; color: Theme.text-disabled; font-size: 10px; vertical-alignment: center; }
            AxisField { placeholder: "min"; value: root.xmin-in; applied(v) => { root.xmin-in = v; } }
            AxisField { placeholder: "max"; value: root.xmax-in; applied(v) => { root.xmax-in = v; } }
            Rectangle { width: 10px; }
            Text { text: "Y"; color: Theme.text-disabled; font-size: 10px; vertical-alignment: center; }
            AxisField { placeholder: "min"; value: root.ymin-in; applied(v) => { root.ymin-in = v; } }
            AxisField { placeholder: "max"; value: root.ymax-in; applied(v) => { root.ymax-in = v; } }
        }

        // ── Content (switches on view mode) ───────────────────────────────
        if root.view-mode == "chart": PlotBox {
            vertical-stretch: 1;
            y-label: root.y-label; series-path: root.series-path; fit-path: root.fit-path;
            fit-label: root.fit-label; x-ticks: root.x-ticks; y-ticks: root.y-ticks; points: root.points;
        }
        if root.view-mode == "grid": SeriesTable {
            vertical-stretch: 1;
            x-label: root.x-label; y-label: root.y-label; points: root.points;
        }
        if root.view-mode == "split": HorizontalLayout {
            vertical-stretch: 1;
            spacing: 6px;
            PlotBox {
                horizontal-stretch: 1;
                y-label: root.y-label; series-path: root.series-path; fit-path: root.fit-path;
                fit-label: root.fit-label; x-ticks: root.x-ticks; y-ticks: root.y-ticks; points: root.points;
            }
            SeriesTable {
                width: 40%;
                x-label: root.x-label; y-label: root.y-label; points: root.points;
            }
        }
        if root.view-mode == "3d": Rectangle {
            vertical-stretch: 1;
            background: Theme.viewport-background;
            border-width: 1px; border-color: Theme.border-color; border-radius: 4px;
            Text {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                text: "3D scatter — coming soon";
                color: Theme.text-disabled; font-size: 12px;
            }
        }
    }
}

// Standalone preview (slint-viewer renders the last exported component).
export component DataChartPreview inherits Window {
    title: "Eustress · Data Chart view";
    preferred-width: 680px;
    preferred-height: 380px;
    background: Theme.background-primary;
    DataChartView {
        title: "temp_anomaly";
        y-label: "temp_anomaly (C)";
        x-label: "year";
        x-ticks: ["1880", "1916", "1952", "1988", "2025"];
        y-ticks: ["1.3", "0.8", "0.3", "-0.2", "-0.5"];
        series-path: "M 0 470 L 250 360 L 500 300 L 750 120 L 1000 40";
        fit-path: "M 0 470 L 1000 90";
        fit-label: "y = 0.0072x - 13.9 · R²=0.77";
        points: [
            { px: 0, py: 470, xv: "1880", yv: "-0.18" },
            { px: 500, py: 300, xv: "1952", yv: "0.01" },
            { px: 1000, py: 40, xv: "2025", yv: "1.28" },
        ];
    }
}
