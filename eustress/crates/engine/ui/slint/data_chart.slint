// ============================================================================
// Eustress Data Platform — Chart view (live, data-driven)
// ============================================================================
// The center "Chart" tab. `sync_data_chart_to_slint` (Rust) reads the selected
// Dataset's CSV and pushes the series + linear-fit polylines (as SVG Path
// commands in a 0..1000 x 0..600 viewbox), axis tick labels, and the fit
// equation. This component is pure CHROME + a responsive plot: it auto-scales
// to the tab and is domain-agnostic — no baked data, no hardcoded units.
//
// Preview:  slint-viewer --auto-reload data_chart.slint
// ============================================================================

import { Theme } from "theme.slint";

// One chip in the view switcher / status strip.
component Chip inherits Rectangle {
    in property <string> label: "";
    in property <bool> active: false;
    in property <color> accent: Theme.accent-cyan;
    height: 22px;
    border-radius: 6px;
    background: root.active ? #0e3a44 : Theme.button-background;
    border-width: 1px;
    border-color: root.active ? root.accent : Theme.border-color;
    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: root.label;
            color: root.active ? #7fe3f5 : Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
        }
    }
}

// One legend entry: a colored swatch line + text.
component LegendItem inherits HorizontalLayout {
    in property <string> label: "";
    in property <color> swatch: Theme.accent-cyan;
    in property <bool> dot: false;
    spacing: 5px;
    VerticalLayout {
        alignment: center;
        Rectangle {
            width: root.dot ? 8px : 14px;
            height: root.dot ? 8px : 3px;
            border-radius: root.dot ? 4px : 1.5px;
            background: root.swatch;
        }
    }
    Text {
        text: root.label;
        color: Theme.text-secondary;
        font-size: 11px;
        vertical-alignment: center;
    }
}

export component DataChartView inherits Rectangle {
    in property <string> title: "";
    in property <string> x-label: "";
    in property <string> y-label: "";
    in property <string> series-path: "";   // SVG commands, viewbox 0 0 1000 600
    in property <string> fit-path: "";       // fit line, same viewbox
    in property <string> fit-label: "";      // e.g. "y = 0.0072x - 13.8 · R²=0.77"
    in property <[string]> x-ticks: [];      // 5 labels, left → right
    in property <[string]> y-ticks: [];      // 5 labels, top → bottom
    background: Theme.panel-background;

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        // ── View switcher + status strip ──────────────────────────────────
        HorizontalLayout {
            height: 24px;
            spacing: 6px;
            Chip { label: "Chart  ▾"; active: true; }
            Text {
                text: "3D · Split · Grid";
                color: Theme.text-disabled;
                font-size: 11px;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            Chip { label: "Color by: " + (root.title == "" ? "—" : root.title); }
        }

        // ── Legend (series + live fit equation) ───────────────────────────
        HorizontalLayout {
            height: 16px;
            spacing: 16px;
            alignment: start;
            LegendItem { label: root.title == "" ? "Series" : root.title; swatch: #38bdf8; }
            LegendItem { label: root.fit-label == "" ? "Linear fit" : root.fit-label; swatch: #f5a524; }
        }

        // ── Plot box — fills the rest of the tab (auto-scale) ─────────────
        Rectangle {
            vertical-stretch: 1;
            background: Theme.viewport-background;
            border-width: 1px;
            border-color: Theme.border-color;
            border-radius: 4px;
            clip: true;

            property <length> ml: 46px;   // left margin (y labels)
            property <length> mr: 14px;   // right margin
            property <length> mt: 10px;   // top margin
            property <length> mb: 20px;   // bottom margin (x labels)

            // Horizontal gridlines + Y labels (top → bottom = ymax → ymin)
            for t[i] in root.y-ticks: Rectangle {
                x: parent.ml;
                y: parent.mt + (parent.height - parent.mt - parent.mb) * i / 4;
                width: parent.width - parent.ml - parent.mr;
                height: 1px;
                background: #ffffff10;
                Text {
                    x: -42px;
                    y: -7px;
                    width: 38px;
                    text: t;
                    color: Theme.text-disabled;
                    font-size: 9px;
                    horizontal-alignment: right;
                }
            }

            // Vertical gridlines + X labels (left → right = xmin → xmax)
            for t[i] in root.x-ticks: Rectangle {
                x: parent.ml + (parent.width - parent.ml - parent.mr) * i / 4;
                y: parent.mt;
                width: 1px;
                height: parent.height - parent.mt - parent.mb;
                background: #ffffff08;
                Text {
                    x: -18px;
                    y: parent.height + 3px;
                    width: 36px;
                    text: t;
                    color: Theme.text-disabled;
                    font-size: 9px;
                    horizontal-alignment: center;
                }
            }

            // Inner plot area — the two polylines, scaled from the 1000x600 viewbox
            Rectangle {
                x: parent.ml;
                y: parent.mt;
                width: parent.width - parent.ml - parent.mr;
                height: parent.height - parent.mt - parent.mb;

                // Linear fit (amber, under the series)
                Path {
                    viewbox-x: 0; viewbox-y: 0; viewbox-width: 1000; viewbox-height: 600;
                    width: 100%; height: 100%;
                    commands: root.fit-path;
                    fill: transparent;
                    stroke: #f5a524;
                    stroke-width: 1.5px;
                }
                // Series (cyan, on top)
                Path {
                    viewbox-x: 0; viewbox-y: 0; viewbox-width: 1000; viewbox-height: 600;
                    width: 100%; height: 100%;
                    commands: root.series-path;
                    fill: transparent;
                    stroke: #38bdf8;
                    stroke-width: 1.6px;
                }
            }

            // Y-axis caption
            Text {
                x: 6px;
                y: 3px;
                text: root.y-label;
                color: Theme.text-disabled;
                font-size: 9px;
            }

            // Empty-state hint when no data has been fed yet
            if root.series-path == "": Text {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                text: "Open a Dataset's chart to plot its series";
                color: Theme.text-disabled;
                font-size: 11px;
            }
        }
    }
}

// Standalone preview entry (slint-viewer renders the last exported component).
export component DataChartPreview inherits Window {
    title: "Eustress · Data Chart view";
    preferred-width: 680px;
    preferred-height: 380px;
    background: Theme.background-primary;
    DataChartView {
        title: "temp_anomaly";
        y-label: "temp_anomaly (C)";
        x-label: "year";
        x-ticks: ["1880", "1916", "1952", "1988", "2025"];
        y-ticks: ["1.3", "0.8", "0.3", "-0.2", "-0.5"];
        series-path: "M 0 470 L 250 360 L 500 300 L 750 120 L 1000 40";
        fit-path: "M 0 470 L 1000 90";
        fit-label: "y = 0.0072x - 13.9 · R²=0.77";
    }
}
