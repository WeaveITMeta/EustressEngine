// ============================================================================
// Eustress Engine - Data Sources Dialog
// Manage global data sources (REST, GraphQL, PostgreSQL, etc.)
// ============================================================================

import { VerticalBox, HorizontalBox, LineEdit, ScrollView, ComboBox } from "std-widgets.slint";
import { Theme } from "theme.slint";

// Data source entry
export struct DataSourceEntry {
    id: int,
    name: string,
    source-type: string, // "REST", "GraphQL", "PostgreSQL", "CSV", etc.
    url: string,
    status: string, // "connected", "disconnected", "error"
}

component DSSection inherits Rectangle {
    in property <string> title: "";
    height: 28px;
    background: transparent;

    Rectangle {
        x: 0px; y: 6px;
        width: 3px; height: 16px;
        border-radius: 1.5px;
        background: Theme.accent-blue;
    }

    Text {
        x: 10px;
        text: root.title;
        color: Theme.text-primary;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.5px;
        vertical-alignment: center;
    }
}

export component DataSourcesDialog inherits Rectangle {
    // Properties
    in property <[DataSourceEntry]> sources: [];
    in-out property <int> selected-source: -1;
    in-out property <string> new-source-name: "";
    in-out property <string> new-source-type: "REST";
    in-out property <string> new-source-url: "";
    in-out property <bool> adding-source: false;

    // Callbacks
    callback on-add-source();
    callback on-remove-source(int);
    callback on-edit-source(int);
    callback on-test-source(int);
    callback on-close();

    width: 100%;
    height: 100%;
    background: Theme.modal-backdrop;

    TouchArea {
        clicked => { root.on-close(); }
        scroll-event(event) => { return accept; }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 580px;
        height: min(parent.height - 80px, 520px);
        background: Theme.background-secondary;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.border-color;
        drop-shadow-blur: 28px;
        drop-shadow-color: #000000a0;

        TouchArea {
            scroll-event(event) => { return accept; }
        }

        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            // ── Title bar ──
            Rectangle {
                height: 46px;
                background: #13131f;
                border-radius: 8px;

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: "Data Sources";
                    color: Theme.text-primary;
                    font-size: 13px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Rectangle {
                    x: parent.width - 36px;
                    y: (parent.height - self.height) / 2;
                    width: 28px; height: 28px;
                    border-radius: 5px;
                    background: close-ta.has-hover ? #3d1515 : transparent;

                    close-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-close(); }
                    }

                    Text {
                        text: "×";
                        color: close-ta.has-hover ? #ef5350 : Theme.text-secondary;
                        font-size: 17px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    y: parent.height - 1px;
                    width: 100%; height: 1px;
                    background: Theme.border-color;
                }
            }

            // ── Content ──
            ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    padding: 20px;
                    spacing: 4px;
                    alignment: start;

                    // Add new source form
                    if root.adding-source: VerticalLayout {
                        spacing: 4px;

                        DSSection { title: "NEW SOURCE"; }

                        Rectangle {
                            height: 28px;
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    width: 110px;
                                    text: "Name";
                                    color: Theme.text-secondary;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    height: 22px;
                                    background: Theme.input-background;
                                    border-radius: 3px;
                                    border-width: 1px;
                                    border-color: Theme.input-border;

                                    LineEdit {
                                        width: 100%; height: 100%;
                                        text <=> root.new-source-name;
                                    }
                                }
                            }
                        }

                        Rectangle {
                            height: 28px;
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    width: 110px;
                                    text: "Type";
                                    color: Theme.text-secondary;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                                ComboBox {
                                    horizontal-stretch: 1;
                                    model: ["REST", "GraphQL", "PostgreSQL", "CSV", "Firebase", "Supabase"];
                                    current-value <=> root.new-source-type;
                                }
                            }
                        }

                        Rectangle {
                            height: 28px;
                            HorizontalLayout {
                                spacing: 8px;
                                Text {
                                    width: 110px;
                                    text: "URL";
                                    color: Theme.text-secondary;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    height: 22px;
                                    background: Theme.input-background;
                                    border-radius: 3px;
                                    border-width: 1px;
                                    border-color: Theme.input-border;

                                    LineEdit {
                                        width: 100%; height: 100%;
                                        text <=> root.new-source-url;
                                    }
                                }
                            }
                        }

                        Rectangle { height: 4px; }

                        HorizontalLayout {
                            spacing: 8px;
                            alignment: end;

                            Rectangle {
                                width: 70px; height: 28px;
                                border-radius: 4px;
                                background: cancel-add-ta.has-hover ? #1a1a2e : Theme.button-background;
                                border-width: 1px;
                                border-color: Theme.border-color;

                                cancel-add-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.adding-source = false; }
                                }

                                Text {
                                    text: "Cancel";
                                    color: Theme.text-primary;
                                    font-size: 11px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                width: 70px; height: 28px;
                                border-radius: 4px;
                                background: add-ta.has-hover ? #1a4a2a : #152a1e;
                                border-width: 1px;
                                border-color: add-ta.has-hover ? #4caf50 : #2a5a32;

                                add-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.on-add-source(); }
                                }

                                Text {
                                    text: "Add";
                                    color: add-ta.has-hover ? #a5d6a7 : #66bb6a;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }

                        Rectangle { height: 8px; }
                    }

                    DSSection { title: "CONFIGURED SOURCES"; }

                    // Add button
                    if !root.adding-source: Rectangle {
                        height: 28px;
                        HorizontalLayout {
                            alignment: start;

                            Rectangle {
                                width: 100px; height: 24px;
                                border-radius: 4px;
                                background: add-src-ta.has-hover ? #1a4a2a : #152a1e;
                                border-width: 1px;
                                border-color: add-src-ta.has-hover ? #4caf50 : #2a5a32;

                                add-src-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.adding-source = true; }
                                }

                                Text {
                                    text: "+ Add Source";
                                    color: add-src-ta.has-hover ? #a5d6a7 : #66bb6a;
                                    font-size: 11px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Rectangle { height: 4px; }

                    // Empty state
                    if root.sources.length == 0: Rectangle {
                        height: 120px;

                        VerticalLayout {
                            alignment: center;
                            spacing: 6px;

                            Text {
                                text: "No data sources configured";
                                color: Theme.text-secondary;
                                font-size: 12px;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: "Add a source to connect to external APIs and databases";
                                color: Theme.text-disabled;
                                font-size: 10px;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    // Sources list
                    for source in root.sources: Rectangle {
                        height: 52px;
                        background: source.id == root.selected-source ? Theme.selection-background :
                                    source-touch.has-hover ? Theme.explorer-item-hover : transparent;
                        border-radius: 4px;

                        source-touch := TouchArea {
                            clicked => { root.selected-source = source.id; }
                        }

                        HorizontalLayout {
                            padding: 10px;
                            spacing: 10px;

                            // Status indicator
                            Rectangle {
                                width: 8px; height: 8px;
                                y: (parent.height - self.height) / 2;
                                background: source.status == "connected" ? #66bb6a :
                                           source.status == "error" ? #ef5350 :
                                           Theme.text-secondary;
                                border-radius: 4px;
                            }

                            // Info
                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 2px;
                                alignment: center;

                                Text {
                                    text: source.name;
                                    color: Theme.text-primary;
                                    font-size: 11px;
                                    font-weight: 500;
                                }

                                Text {
                                    text: source.source-type + " · " + source.url;
                                    color: Theme.text-secondary;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            // Actions
                            Rectangle {
                                width: 40px; height: 24px;
                                border-radius: 3px;
                                background: test-ta.has-hover ? #1a1a2e : Theme.button-background;
                                border-width: 1px;
                                border-color: Theme.border-color;

                                test-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.on-test-source(source.id); }
                                }

                                Text {
                                    text: "Test";
                                    color: Theme.text-primary;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                width: 40px; height: 24px;
                                border-radius: 3px;
                                background: edit-ta.has-hover ? #1a1a2e : Theme.button-background;
                                border-width: 1px;
                                border-color: Theme.border-color;

                                edit-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.on-edit-source(source.id); }
                                }

                                Text {
                                    text: "Edit";
                                    color: Theme.text-primary;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Rectangle {
                                width: 24px; height: 24px;
                                border-radius: 3px;
                                background: del-ta.has-hover ? #3d1515 : Theme.button-background;
                                border-width: 1px;
                                border-color: del-ta.has-hover ? #5a2020 : Theme.border-color;

                                del-ta := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.on-remove-source(source.id); }
                                }

                                Text {
                                    text: "×";
                                    color: del-ta.has-hover ? #ef5350 : Theme.text-secondary;
                                    font-size: 14px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
            }

            // ── Footer ──
            Rectangle {
                height: 1px; background: Theme.border-color;
            }
            Rectangle {
                height: 52px;
                background: #0f0f1a;
                border-radius: 8px;

                HorizontalLayout {
                    alignment: center;

                    Rectangle {
                        width: 80px; height: 32px;
                        border-radius: 5px;
                        background: close-btn.has-hover ? #1a1a2e : Theme.button-background;
                        border-width: 1px;
                        border-color: Theme.border-color;

                        close-btn := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.on-close(); }
                        }

                        Text {
                            text: "Close";
                            color: Theme.text-primary;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
