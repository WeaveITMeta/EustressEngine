// ============================================================================
// Edit Label Text dialog — triggered by Enter on a selected part that has a
// TextLabel descendant. Window-root modal (same proven pattern as NewSpace /
// RenameTag), so it never mutates the 3D billboard / part subtree.
// ============================================================================

import { LineEdit, Button } from "std-widgets.slint";
import { Theme } from "theme.slint";

export component EditLabelDialog inherits Rectangle {
    in-out property <string> label-text: "";

    callback on-confirm(/* new-text */ string);
    callback on-cancel();

    width: 100%;
    height: 100%;
    background: Theme.modal-backdrop;

    TouchArea {
        clicked => { root.on-cancel(); }
        scroll-event(event) => { return accept; }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 440px;
        height: 230px;
        background: Theme.background-secondary;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.border-color;
        drop-shadow-blur: 28px;
        drop-shadow-color: #000000a0;

        TouchArea { scroll-event(event) => { return accept; } }

        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            // Title bar
            Rectangle {
                height: 46px;
                background: #13131f;
                border-radius: 8px;
                Text {
                    width: parent.width; height: parent.height;
                    text: "Edit Text";
                    color: Theme.text-primary;
                    font-size: 13px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                Rectangle {
                    x: parent.width - 36px;
                    y: (parent.height - self.height) / 2;
                    width: 28px; height: 28px;
                    border-radius: 5px;
                    background: close-ta.has-hover ? #3d1515 : transparent;
                    Text {
                        text: "×";
                        color: close-ta.has-hover ? #ef5350 : Theme.text-secondary;
                        font-size: 17px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    close-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-cancel(); }
                    }
                }
                Rectangle {
                    y: parent.height - 1px;
                    width: 100%; height: 1px;
                    background: Theme.border-color;
                }
            }

            // Body
            VerticalLayout {
                padding: 20px;
                spacing: 12px;

                Text {
                    text: "Edit label text — Enter to commit, Escape to cancel:";
                    color: Theme.text-secondary;
                    font-size: 11px;
                    wrap: word-wrap;
                }

                Rectangle {
                    height: 32px;
                    background: Theme.input-background;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Theme.input-border;
                    text-edit := LineEdit {
                        x: 0px; y: 0px; width: 100%; height: 100%;
                        text <=> root.label-text;
                        placeholder-text: "Label text";
                        accepted(t) => { root.on-confirm(t); }
                    }
                }

                Rectangle { height: 2px; }

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; }
                    Button {
                        text: "Cancel";
                        width: 84px;
                        clicked => { root.on-cancel(); }
                    }
                    Button {
                        text: "Save";
                        primary: true;
                        width: 84px;
                        clicked => { root.on-confirm(root.label-text); }
                    }
                }
            }
        }
    }
}
