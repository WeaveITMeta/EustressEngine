// ============================================================================
// Eustress Engine Studio - Context Menu
// Right-click context menu with proper positioning and scrollable submenus
// ============================================================================

import { VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";

// Menu item data
export struct MenuItem {
    id: string,
    label: string,
    shortcut: string,
    icon: image,
    enabled: bool,
    separator-after: bool,
}

// ── Menu Item Row ─────────────────────────────────────────────────────────

component MenuItemRow inherits Rectangle {
    in property <string> label: "";
    in property <string> shortcut: "";
    in property <image> icon;
    in property <bool> enabled: true;

    callback clicked();

    height: 26px;
    background: self.enabled && touch.has-hover ? #2a2d3a : transparent;
    border-radius: 3px;

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 8px;

        Image {
            width: 14px;
            height: 14px;
            source: root.icon;
            image-fit: contain;
            colorize: root.enabled ? Theme.text-secondary : Theme.text-disabled;
            vertical-alignment: center;
        }

        Text {
            horizontal-stretch: 1;
            text: root.label;
            color: root.enabled ? Theme.text-primary : Theme.text-disabled;
            font-size: 12px;
            vertical-alignment: center;
        }

        if root.shortcut != "": Text {
            text: root.shortcut;
            color: #555;
            font-size: 10px;
            vertical-alignment: center;
        }
    }
}

// ── Separator ─────────────────────────────────────────────────────────────

component MenuSeparator inherits Rectangle {
    height: 5px;

    Rectangle {
        y: 2px;
        height: 1px;
        x: 8px;
        width: parent.width - 16px;
        background: #333;
    }
}

// ============================================================================
// Context Menu — main component
// ============================================================================

export component ContextMenu inherits Rectangle {
    in property <[MenuItem]> items: [];

    callback on-action(string);
    callback on-close();

    width: 220px;
    // Height hugs content via the inner layout's `min-height` (sum of
    // children, independent of parent). `preferred-height` creates a
    // circular binding when the parent height drives the child, which
    // can resolve to 0 and hide the menu entirely.
    height: body.min-height;
    clip: true;
    background: #1e1f2e;
    border-radius: 6px;
    border-width: 1px;
    border-color: #333;
    drop-shadow-blur: 16px;
    drop-shadow-color: #000000a0;

    // Absorb clicks on the menu body
    TouchArea {
        scroll-event(event) => { return accept; }
    }

    body := VerticalLayout {
        padding: 4px;
        spacing: 1px;

        // ── Dynamic items (file menu) ──
        if root.items.length > 0: VerticalLayout {
                spacing: 1px;

                for item in root.items: VerticalLayout {
                    spacing: 0px;

                    MenuItemRow {
                        icon: item.icon;
                        label: item.label;
                        shortcut: item.shortcut;
                        enabled: item.enabled;
                        clicked => { root.on-action(item.id); }
                    }

                    if item.separator-after: MenuSeparator {}
                }
            }

            // ── Default entity menu ──
            //
            // Order: edit clipboard ops → identity ops → structure ops →
            // destructive (Delete) last so a misclick can't nuke the node.
            // "Insert Object..." lives in the File menu; we don't duplicate
            // it here.
            if root.items.length == 0: VerticalLayout {
                spacing: 1px;

                MenuItemRow {
                    icon: @image-url("../../assets/icons/ui/cut.svg");
                    label: "Cut"; shortcut: "Ctrl+X";
                    clicked => { root.on-action("cut"); }
                }
                MenuItemRow {
                    icon: @image-url("../../assets/icons/ui/copy.svg");
                    label: "Copy"; shortcut: "Ctrl+C";
                    clicked => { root.on-action("copy"); }
                }
                MenuItemRow {
                    icon: @image-url("../../assets/icons/ui/paste.svg");
                    label: "Paste"; shortcut: "Ctrl+V";
                    clicked => { root.on-action("paste"); }
                }
                MenuItemRow {
                    icon: @image-url("../../assets/icons/ui/duplicate.svg");
                    label: "Duplicate"; shortcut: "Ctrl+D";
                    clicked => { root.on-action("duplicate"); }
                }

                MenuSeparator {}

                MenuItemRow {
                    icon: @image-url("../../assets/icons/ui/rename.svg");
                    label: "Rename"; shortcut: "F2";
                    clicked => { root.on-action("rename"); }
                }
                // Copy Path — yields the `@entity:Space/Name` canonical handle
                // so the user can paste it straight into the Workshop chat
                // and @reference the selected entity.
                MenuItemRow {
                    icon: @image-url("../../assets/icons/ui/link.svg");
                    label: "Copy Path"; shortcut: "";
                    clicked => { root.on-action("copy-path"); }
                }

                MenuSeparator {}

                MenuItemRow {
                    icon: @image-url("../../assets/icons/ui/group.svg");
                    label: "Group"; shortcut: "Ctrl+G";
                    clicked => { root.on-action("group"); }
                }
                MenuItemRow {
                    icon: @image-url("../../assets/icons/ui/ungroup.svg");
                    label: "Ungroup"; shortcut: "Ctrl+Shift+G";
                    clicked => { root.on-action("ungroup"); }
                }

                MenuSeparator {}

                MenuItemRow {
                    icon: @image-url("../../assets/icons/ui/delete.svg");
                    label: "Delete"; shortcut: "Del";
                    clicked => { root.on-action("delete"); }
                }
            }
        }
    }
