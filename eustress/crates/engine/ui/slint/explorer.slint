// ============================================================================
// Eustress Engine Studio - Explorer Panel
// Hierarchical entity tree view with services
// ============================================================================

import { LineEdit, ScrollView } from "std-widgets.slint";
import { Theme, TreeItem } from "theme.slint";

// Unified tree node for both ECS entities and filesystem items
export struct TreeNode {
    // Common fields
    id: int,
    name: string,
    icon: image,
    depth: int,
    expandable: bool,
    expanded: bool,
    selected: bool,
    visible: bool,
    
    // Type discriminator
    node-type: string,
    
    // Entity-specific (when node-type == "entity")
    class-name: string,
    
    // File-specific (when node-type == "file")
    path: string,
    is-directory: bool,
    extension: string,
    size: string,
    modified: bool,
}

export component ExplorerPanel inherits Rectangle {
    // Properties
    in property <[TreeNode]> tree-nodes: [];
    // Parallel array of node ids for ONLY the currently-visible rows, in
    // the same order as they're laid out. Drives drag-target resolution
    // by row-index — see drag-moved on TreeItem below. Maintained Rust-side
    // alongside `tree-nodes` so we don't have to filter+count in Slint.
    in property <[int]> visible-node-ids: [];
    in-out property <string> search-text: "";

    // Programmatic scroll target — used by 3D-viewport selection to
    // bring the corresponding tree row to the top of the visible area.
    // Rust drives this by setting `scroll-target-y` to the desired
    // viewport offset (in pixels, relative to the top of the content)
    // and bumping `scroll-pulse` (a one-shot counter) — the `changed`
    // handler below jumps the ScrollView once per pulse, leaving
    // subsequent user scrolling untouched.
    in property <int> scroll-pulse: 0;
    in property <length> scroll-target-y: 0px;
    changed scroll-pulse => {
        tree-scroll.viewport-y = -root.scroll-target-y;
    }
    
    // Callbacks — ctrl/shift booleans for multi-select
    callback on-select-node(int, string, /* ctrl */ bool, /* shift */ bool);
    callback on-expand-node(int, string);
    callback on-collapse-node(int, string);
    callback on-open-node(int, string);
    callback on-context-menu(length, length, int, string); // x, y, node-id, node-type
    callback on-search-changed(string);
    callback on-rename-node(int, string, string);
    /// Fired when inline rename should start for the given node id.
    /// Handled by main.slint which sets explorer-renaming-node-id.
    callback on-start-rename(int);
    /// Fired when rename is committed or cancelled — main.slint clears the id.
    callback on-cancel-rename();
    callback on-add-service();  // (+) button to add a new service
    callback on-expand-all();   // Expand all tree nodes
    callback on-collapse-all(); // Collapse all tree nodes
    callback on-deselect();     // Click on empty space deselects
    callback navigate-up();     // Arrow up — select previous visible node
    callback navigate-down();   // Arrow down — select next visible node
    callback navigate-collapse(); // Arrow left — collapse current node
    callback navigate-expand();   // Arrow right — expand current node
    // Drag-and-drop reparenting: source node dragged onto target node
    callback on-reparent-node(/* source-id */ int, /* target-id */ int);

    /// Node id currently being inline-renamed (-1 = none). Driven by
    /// main.slint via the on-start-rename / on-cancel-rename callbacks.
    in property <int> renaming-node-id: -1;

    /// Last node that received a clicked() — used by F2 to know which
    /// node to rename without requiring a Slint array search in a callback.
    property <int> last-selected-id: -1;

    // Drag state
    in-out property <bool> drag-active: false;
    in-out property <int> drag-source-id: -1;
    in-out property <int> drag-target-id: -1;
    in-out property <string> drag-source-name: "";
    in-out property <image> drag-source-icon;
    in-out property <length> drag-mouse-x: 0px;
    in-out property <length> drag-mouse-y: 0px;
    
    background: Theme.panel-background;
    
    VerticalLayout {
        padding: 0px;
        spacing: 0px;
        
        // Search bar + toolbar buttons
        Rectangle {
            height: 30px;
            background: Theme.header-background;
            
            HorizontalLayout {
                padding: 4px;
                spacing: 4px;
                
                // Search icon (decorative, inside the search area)
                Rectangle {
                    width: 22px;
                    height: 22px;
                    
                    Image {
                        width: 14px;
                        height: 14px;
                        source: @image-url("../../assets/icons/ui/search.svg");
                        image-fit: contain;
                        colorize: Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                
                search-input := LineEdit {
                    horizontal-stretch: 1;
                    placeholder-text: "Search...";
                    text <=> root.search-text;
                    edited(text) => { root.on-search-changed(text); }
                }
                
                // Filter / clear search button (visible when search has text)
                if root.search-text != "": Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 3px;
                    background: clear-btn-ta.has-hover ? Theme.button-hover : transparent;
                    
                    Image {
                        width: 14px;
                        height: 14px;
                        source: @image-url("../../assets/icons/ui/close.svg");
                        image-fit: contain;
                        colorize: Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    
                    clear-btn-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.search-text = "";
                            root.on-search-changed("");
                        }
                    }
                }
                
                // Expand All button
                Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 3px;
                    background: expand-all-ta.has-hover ? Theme.button-hover : transparent;
                    
                    Image {
                        width: 14px;
                        height: 14px;
                        source: @image-url("../../assets/icons/ui/expand-all.svg");
                        image-fit: contain;
                        colorize: Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    
                    expand-all-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-expand-all(); }
                    }
                }
                
                // Collapse All button
                Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 3px;
                    background: collapse-all-ta.has-hover ? Theme.button-hover : transparent;
                    
                    Image {
                        width: 14px;
                        height: 14px;
                        source: @image-url("../../assets/icons/ui/collapse-all.svg");
                        image-fit: contain;
                        colorize: Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    
                    collapse-all-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-collapse-all(); }
                    }
                }
                
                // (+) Add Service button
                Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 3px;
                    background: add-btn-ta.has-hover ? Theme.button-hover : transparent;
                    
                    Text {
                        text: "+";
                        color: Theme.text-primary;
                        font-size: 16px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    
                    add-btn-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-add-service(); }
                    }
                }
            }
        }
        
        // Entity tree with keyboard navigation + modifier tracking
        explorer-keys := FocusScope {
            vertical-stretch: 1;

            key-pressed(event) => {
                if event.text == Key.F2 {
                    if root.last-selected-id >= 0 {
                        root.on-start-rename(root.last-selected-id);
                    }
                    return accept;
                }
                if event.text == Key.UpArrow   { root.navigate-up();       return accept; }
                if event.text == Key.DownArrow  { root.navigate-down();     return accept; }
                if event.text == Key.LeftArrow  { root.navigate-collapse(); return accept; }
                if event.text == Key.RightArrow { root.navigate-expand();   return accept; }
                return reject;
            }

        tree-scroll-area := Rectangle {
            vertical-stretch: 1;
            clip: true;

            tree-scroll := ScrollView {
                horizontal-scrollbar-policy: always-off;

                VerticalLayout {
                    spacing: 0px;

                    for node[index] in root.tree-nodes: TreeItem {
                        depth: node.depth;
                        icon: node.icon;
                        label: node.name;
                        expandable: node.expandable;
                        expanded: node.expanded;
                        selected: node.selected;
                        show: node.visible;
                        node-id: node.id;
                        // drop-target is driven by drag-target-id which is
                        // set in drag-moved below (math-based row resolver
                        // using visible-node-ids + scroll offset). No
                        // absolute-position read here, so no property cycle.
                        drop-target: root.drag-active
                            && node.id == root.drag-target-id
                            && node.id != root.drag-source-id
                            && node.visible;
                        renaming: node.id == root.renaming-node-id;

                        clicked(ctrl, shift) => {
                            explorer-keys.focus();
                            root.last-selected-id = node.id;
                            root.on-select-node(node.id, node.node-type, ctrl, shift);
                        }
                        double-clicked => {
                            root.on-select-node(node.id, node.node-type, false, false);
                            if node.expandable {
                                if node.expanded { root.on-collapse-node(node.id, node.node-type); }
                                else { root.on-expand-node(node.id, node.node-type); }
                            } else {
                                root.on-open-node(node.id, node.node-type);
                            }
                        }
                        toggle-expanded => {
                            if node.expanded { root.on-collapse-node(node.id, node.node-type); }
                            else { root.on-expand-node(node.id, node.node-type); }
                        }
                        context-menu(x, y) => {
                            // If the right-clicked node isn't already in
                            // the selection, select just it first — this
                            // matches Windows Explorer / Finder / VSCode
                            // behaviour where right-clicking a
                            // non-selected row selects it before showing
                            // the menu. Right-clicking a node that IS
                            // already part of a multi-selection leaves
                            // the existing selection intact so group
                            // actions (Cut/Copy/Delete, Select Children
                            // across multiple parents) keep working.
                            if !node.selected {
                                root.on-select-node(node.id, node.node-type, false, false);
                            }
                            root.on-context-menu(x, y, node.id, node.node-type);
                        }
                        rename-committed(new-name) => {
                            root.on-rename-node(node.id, new-name, node.node-type);
                            root.on-cancel-rename();
                        }
                        rename-cancelled() => {
                            root.on-cancel-rename();
                        }

                        drag-started(id, abs-x, abs-y) => {
                            root.drag-active = true;
                            root.drag-source-id = id;
                            root.drag-source-name = node.name;
                            root.drag-source-icon = node.icon;
                            root.drag-target-id = -1;
                            root.drag-mouse-x = abs-x;
                            root.drag-mouse-y = abs-y;
                        }
                        drag-moved(abs-x, abs-y) => {
                            root.drag-mouse-x = abs-x;
                            root.drag-mouse-y = abs-y;
                            // Resolve the row under the cursor using the
                            // visible-only id array so collapsed siblings
                            // don't shift the index. Account for the
                            // ScrollView's vertical scroll offset.
                            // NOTE: row-touch keeps the mouse grab while
                            // LMB is held, so OTHER TreeItems can't fire
                            // hover events — we MUST resolve from the
                            // source's drag-moved callback.
                            if root.visible-node-ids.length > 0 {
                                let local-y = abs-y - tree-scroll-area.absolute-position.y - tree-scroll.viewport-y;
                                let row-idx = floor(local-y / 22px);
                                if row-idx >= 0 && row-idx < root.visible-node-ids.length {
                                    let candidate = root.visible-node-ids[row-idx];
                                    if candidate != root.drag-source-id {
                                        root.drag-target-id = candidate;
                                    } else {
                                        root.drag-target-id = -1;
                                    }
                                } else {
                                    root.drag-target-id = -1;
                                }
                            }
                        }
                        drag-ended => {
                            if root.drag-active && root.drag-source-id >= 0 && root.drag-target-id >= 0
                                && root.drag-source-id != root.drag-target-id {
                                root.on-reparent-node(root.drag-source-id, root.drag-target-id);
                            }
                            root.drag-active = false;
                            root.drag-source-id = -1;
                            root.drag-target-id = -1;
                            root.drag-source-name = "";
                        }
                    }

                    // Empty space fill below the tree — click to deselect.
                    // NOTE: deliberately NO `vertical-stretch` here. A stretch
                    // element inside a ScrollView pins the content height to the
                    // viewport, which silently kills wheel scrolling the moment
                    // the tree outgrows the panel (the "Explorer scrolling broke"
                    // bug — surfaced once disk SoulScripts filled the tree).
                    Rectangle {
                        min-height: 100px;
                        background: transparent;
                        TouchArea {
                            clicked => { root.on-deselect(); }
                            scroll-event(e) => { return reject; }
                        }
                    }
                }
            }

        }
        } // close FocusScope
    }

    // Ghost — placed at the ExplorerPanel root level (sibling of the
    // VerticalLayout, NOT inside `tree-scroll-area`) so the panel doesn't
    // clip it when the cursor approaches the panel edges. drag-mouse-x/y
    // are absolute screen coords; subtract this rect's absolute-position
    // to get panel-local coords. Small +10/+4 nudge keeps the cursor
    // arrow visible AT the pill rather than swallowed by it.
    if root.drag-active: ghost-anchor := Rectangle {
        x: 0px; y: 0px; width: 100%; height: 100%;
        background: transparent;
        Rectangle {
            x: root.drag-mouse-x - ghost-anchor.absolute-position.x + 10px;
            y: root.drag-mouse-y - ghost-anchor.absolute-position.y + 4px;
            width: drag-ghost-text.preferred-width + 40px;
            height: 22px;
            background: Theme.accent-blue;
            opacity: 0.9;
            border-radius: 4px;
            drop-shadow-blur: 4px;
            drop-shadow-color: #00000060;

            drag-ghost-icon := Image {
                x: 6px;
                y: 4px;
                width: 14px;
                height: 14px;
                source: root.drag-source-icon;
                image-fit: contain;
            }

            drag-ghost-text := Text {
                x: 24px;
                y: 0px;
                height: 22px;
                text: root.drag-source-name;
                color: white;
                font-size: 11px;
                font-weight: 500;
                vertical-alignment: center;
            }
        }
    }
}
