// ============================================================================
// Eustress Engine Studio - Explorer Panel
// Hierarchical entity tree view with services
// ============================================================================

import { LineEdit, ScrollView } from "std-widgets.slint";
import { Theme, TreeItem } from "theme.slint";

// Unified tree node for both ECS entities and filesystem items
export struct TreeNode {
    // Common fields
    id: int,
    name: string,
    icon: image,
    depth: int,
    expandable: bool,
    expanded: bool,
    selected: bool,
    visible: bool,
    
    // Type discriminator
    node-type: string,
    
    // Entity-specific (when node-type == "entity")
    class-name: string,
    
    // File-specific (when node-type == "file")
    path: string,
    is-directory: bool,
    extension: string,
    size: string,
    modified: bool,
}

export component ExplorerPanel inherits Rectangle {
    // Properties
    in property <[TreeNode]> tree-nodes: [];
    in-out property <string> search-text: "";
    
    // Callbacks — ctrl/shift booleans for multi-select
    callback on-select-node(int, string, /* ctrl */ bool, /* shift */ bool);
    callback on-expand-node(int, string);
    callback on-collapse-node(int, string);
    callback on-open-node(int, string);
    callback on-context-menu(length, length, int, string); // x, y, node-id, node-type
    callback on-search-changed(string);
    callback on-rename-node(int, string, string);
    callback on-add-service();  // (+) button to add a new service
    callback on-expand-all();   // Expand all tree nodes
    callback on-collapse-all(); // Collapse all tree nodes
    callback on-deselect();     // Click on empty space deselects
    callback navigate-up();     // Arrow up — select previous visible node
    callback navigate-down();   // Arrow down — select next visible node
    callback navigate-collapse(); // Arrow left — collapse current node
    callback navigate-expand();   // Arrow right — expand current node
    // Drag-and-drop reparenting: source node dragged onto target node
    callback on-reparent-node(/* source-id */ int, /* target-id */ int);

    // Drag state
    in-out property <bool> drag-active: false;
    in-out property <int> drag-source-id: -1;
    in-out property <int> drag-target-id: -1;
    in-out property <string> drag-source-name: "";
    in-out property <image> drag-source-icon;
    in-out property <length> drag-mouse-x: 0px;
    in-out property <length> drag-mouse-y: 0px;
    
    background: Theme.panel-background;
    
    VerticalLayout {
        padding: 0px;
        spacing: 0px;
        
        // Search bar + toolbar buttons
        Rectangle {
            height: 30px;
            background: Theme.header-background;
            
            HorizontalLayout {
                padding: 4px;
                spacing: 4px;
                
                // Search icon (decorative, inside the search area)
                Rectangle {
                    width: 22px;
                    height: 22px;
                    
                    Image {
                        width: 14px;
                        height: 14px;
                        source: @image-url("../../assets/icons/ui/search.svg");
                        image-fit: contain;
                        colorize: Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                
                search-input := LineEdit {
                    horizontal-stretch: 1;
                    placeholder-text: "Search...";
                    text <=> root.search-text;
                    edited(text) => { root.on-search-changed(text); }
                }
                
                // Filter / clear search button (visible when search has text)
                if root.search-text != "": Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 3px;
                    background: clear-btn-ta.has-hover ? Theme.button-hover : transparent;
                    
                    Image {
                        width: 14px;
                        height: 14px;
                        source: @image-url("../../assets/icons/ui/close.svg");
                        image-fit: contain;
                        colorize: Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    
                    clear-btn-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.search-text = "";
                            root.on-search-changed("");
                        }
                    }
                }
                
                // Expand All button
                Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 3px;
                    background: expand-all-ta.has-hover ? Theme.button-hover : transparent;
                    
                    Image {
                        width: 14px;
                        height: 14px;
                        source: @image-url("../../assets/icons/ui/expand-all.svg");
                        image-fit: contain;
                        colorize: Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    
                    expand-all-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-expand-all(); }
                    }
                }
                
                // Collapse All button
                Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 3px;
                    background: collapse-all-ta.has-hover ? Theme.button-hover : transparent;
                    
                    Image {
                        width: 14px;
                        height: 14px;
                        source: @image-url("../../assets/icons/ui/collapse-all.svg");
                        image-fit: contain;
                        colorize: Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    
                    collapse-all-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-collapse-all(); }
                    }
                }
                
                // (+) Add Service button
                Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 3px;
                    background: add-btn-ta.has-hover ? Theme.button-hover : transparent;
                    
                    Text {
                        text: "+";
                        color: Theme.text-primary;
                        font-size: 16px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    
                    add-btn-ta := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-add-service(); }
                    }
                }
            }
        }
        
        // Entity tree with keyboard navigation + modifier tracking
        explorer-keys := FocusScope {
            vertical-stretch: 1;

            // Track Ctrl/Shift state via key press/release for multi-select
            property <bool> ctrl-held: false;
            property <bool> shift-held: false;

            key-pressed(event) => {
                if event.text == Key.Control { self.ctrl-held = true; return accept; }
                if event.text == Key.Shift { self.shift-held = true; return accept; }
                if event.text == Key.UpArrow   { root.navigate-up();       return accept; }
                if event.text == Key.DownArrow  { root.navigate-down();     return accept; }
                if event.text == Key.LeftArrow  { root.navigate-collapse(); return accept; }
                if event.text == Key.RightArrow { root.navigate-expand();   return accept; }
                return reject;
            }
            key-released(event) => {
                if event.text == Key.Control { self.ctrl-held = false; return accept; }
                if event.text == Key.Shift { self.shift-held = false; return accept; }
                return reject;
            }

        ScrollView {
            horizontal-scrollbar-policy: always-off;

            VerticalLayout {
                spacing: 0px;

                for node[index] in root.tree-nodes: TreeItem {
                    depth: node.depth;
                    icon: node.icon;
                    label: node.name;
                    expandable: node.expandable;
                    expanded: node.expanded;
                    selected: node.selected;
                    show: node.visible;
                    node-id: node.id;
                    // Highlight as drop target when mouse Y is within this row's bounds
                    drop-target: root.drag-active
                        && node.id != root.drag-source-id
                        && root.drag-mouse-y >= self.absolute-position.y
                        && root.drag-mouse-y < self.absolute-position.y + self.height
                        && node.visible;
                    ctrl-held: explorer-keys.ctrl-held;
                    shift-held: explorer-keys.shift-held;

                    clicked(ctrl, shift) => {
                        explorer-keys.focus();
                        root.on-select-node(node.id, node.node-type, ctrl, shift);
                    }
                    double-clicked => {
                        root.on-select-node(node.id, node.node-type, false, false);
                        if node.expandable {
                            if node.expanded {
                                root.on-collapse-node(node.id, node.node-type);
                            } else {
                                root.on-expand-node(node.id, node.node-type);
                            }
                        } else {
                            root.on-open-node(node.id, node.node-type);
                        }
                    }
                    toggle-expanded => {
                        if node.expanded {
                            root.on-collapse-node(node.id, node.node-type);
                        } else {
                            root.on-expand-node(node.id, node.node-type);
                        }
                    }
                    context-menu(x, y) => { root.on-context-menu(x, y, node.id, node.node-type); }

                    // Drag initiation
                    drag-started(id) => {
                        root.drag-active = true;
                        root.drag-source-id = id;
                        root.drag-source-name = node.name;
                        root.drag-source-icon = node.icon;
                        root.drag-target-id = -1;
                    }
                    drag-moved(abs-y) => {
                        root.drag-mouse-y = abs-y;
                    }
                    drag-ended => {
                        if root.drag-active && root.drag-source-id >= 0 && root.drag-target-id >= 0
                            && root.drag-source-id != root.drag-target-id {
                            root.on-reparent-node(root.drag-source-id, root.drag-target-id);
                        }
                        root.drag-active = false;
                        root.drag-source-id = -1;
                        root.drag-target-id = -1;
                        root.drag-source-name = "";
                    }
                }

                // Empty space fill — click to deselect
                Rectangle {
                    vertical-stretch: 1;
                    min-height: 100px;
                    background: transparent;
                    TouchArea {
                        clicked => { root.on-deselect(); }
                        scroll-event(e) => { return reject; }
                    }
                }
            }

            // Drag overlay — covers full panel, tracks mouse for drop target + ghost
            if root.drag-active: drag-overlay-rect := Rectangle {
                x: 0px; y: 0px; width: 100%; height: 100%;
                background: #00000020; // subtle dimming to indicate drag mode

                drag-overlay := TouchArea {
                    mouse-cursor: grabbing;
                    moved => {
                        root.drag-mouse-x = self.mouse-x;
                        root.drag-mouse-y = self.absolute-position.y + self.mouse-y;
                        // The per-row drop-target binding handles highlighting.
                        // Set drag-target-id by row index approximation (22px per visible row).
                        let row-idx = floor(self.mouse-y / 22px);
                        let clamped = max(0, min(row-idx, root.tree-nodes.length - 1));
                        root.drag-target-id = root.tree-nodes[clamped].id;
                    }
                    pointer-event(event) => {
                        if event.kind == PointerEventKind.up && event.button == PointerEventButton.left {
                            if root.drag-source-id >= 0 && root.drag-target-id >= 0
                                && root.drag-source-id != root.drag-target-id {
                                root.on-reparent-node(root.drag-source-id, root.drag-target-id);
                            }
                            root.drag-active = false;
                            root.drag-source-id = -1;
                            root.drag-target-id = -1;
                            root.drag-source-name = "";
                        }
                    }
                }

                // Ghost preview — icon + name, follows mouse exactly
                Rectangle {
                    x: drag-overlay.mouse-x + 12px;
                    y: drag-overlay.mouse-y - 11px;
                    width: drag-ghost-icon.width + drag-ghost-text.preferred-width + 16px;
                    height: 22px;
                    background: Theme.accent-blue;
                    opacity: 0.9;
                    border-radius: 4px;
                    drop-shadow-blur: 4px;
                    drop-shadow-color: #00000060;

                    HorizontalLayout {
                        padding-left: 4px;
                        padding-right: 8px;
                        spacing: 4px;
                        alignment: start;

                        drag-ghost-icon := Image {
                            width: 14px;
                            height: 14px;
                            source: root.drag-source-icon;
                            image-fit: contain;
                            vertical-alignment: center;
                        }

                        drag-ghost-text := Text {
                            text: root.drag-source-name;
                            color: white;
                            font-size: 11px;
                            font-weight: 500;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
        } // close FocusScope
    }
}
