// ============================================================================
// TimelineFilterModal — checkbox-list modal for choosing which tag
// tracks are visible on the Timeline panel.
// ============================================================================
//
// Opened by the Filter button in the Timeline panel title bar.
// Shows every distinct tag in the current timeline with a checkbox,
// plus Select All / Deselect All shortcuts. Closes on backdrop click
// or explicit Close button.

import { Theme } from "theme.slint";

export struct TimelineTagRow {
    tag: string,
    visible: bool,
    count: int,
}

export component TimelineFilterModal inherits Rectangle {
    in property <[TimelineTagRow]> rows;
    in property <bool>             visible-when: false;

    callback row-toggled(string);  // tag name
    callback select-all();
    callback deselect-all();
    callback close-clicked();

    visible: root.visible-when;
    background: #00000080;        // full-screen backdrop dim
    width: 100%;
    height: 100%;

    // Click on the backdrop (outside the dialog) dismisses.
    TouchArea {
        clicked => { root.close-clicked(); }
    }

    // The dialog itself.
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 360px;
        height: Math.min(420px, 64px + rows.length * 26px + 64px);

        background:        Theme.panel-glass;
        border-radius:     Theme.radius-xl;
        border-width:      1px;
        border-color:      Theme.border-color;
        drop-shadow-blur:  40px;
        drop-shadow-color: #000000a0;

        // Swallow clicks inside the dialog so they don't dismiss.
        TouchArea {}

        VerticalLayout {
            padding: 16px;
            spacing: 12px;

            // Header row.
            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: "Timeline Filter";
                    color: Theme.text-primary;
                    font-size: Theme.font-xl;
                    font-weight: 500;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
                // Close ×
                close-btn := Rectangle {
                    width: 24px; height: 24px;
                    background: close-touch.has-hover ? #ffffff15 : transparent;
                    border-radius: Theme.radius-md;
                    Text {
                        text: "×";
                        color: Theme.text-secondary;
                        font-size: 20px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    close-touch := TouchArea {
                        clicked => { root.close-clicked(); }
                    }
                }
            }

            // Select-all / deselect-all buttons.
            HorizontalLayout {
                spacing: 6px;
                TouchArea {
                    width: 90px; height: 24px;
                    clicked => { root.select-all(); }
                    Rectangle {
                        background: parent.has-hover ? #ffffff15 : transparent;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.accent-blue;
                        Text {
                            text: "Select All";
                            color: Theme.accent-blue;
                            font-size: Theme.font-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
                TouchArea {
                    width: 100px; height: 24px;
                    clicked => { root.deselect-all(); }
                    Rectangle {
                        background: parent.has-hover ? #ffffff15 : transparent;
                        border-radius: Theme.radius-md;
                        border-width: 1px;
                        border-color: Theme.border-color;
                        Text {
                            text: "Deselect All";
                            color: Theme.text-secondary;
                            font-size: Theme.font-sm;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
            }

            // Checkbox list — one row per tag.
            Rectangle {
                background: #00000030;
                border-radius: Theme.radius-md;
                border-width: 1px;
                border-color: Theme.border-color;
                vertical-stretch: 1;

                Flickable {
                    x: 0; y: 0;
                    width: parent.width;
                    height: parent.height;
                    viewport-height: rows.length * 26px + 8px;
                    VerticalLayout {
                        x: 8px; y: 4px;
                        width: parent.width - 16px;
                        spacing: 2px;

                        for row[i] in root.rows: Rectangle {
                            height: 24px;
                            background: row-touch.has-hover ? #ffffff08 : transparent;
                            border-radius: Theme.radius-sm;

                            HorizontalLayout {
                                spacing: 8px;
                                padding-left: 4px;

                                // Checkbox.
                                Rectangle {
                                    y: (parent.height - self.height) / 2;
                                    width: 14px; height: 14px;
                                    background: row.visible ? Theme.accent-blue : transparent;
                                    border-width: 1px;
                                    border-color: row.visible ? Theme.accent-blue : Theme.border-color;
                                    border-radius: 2px;
                                    if row.visible: Text {
                                        text: "✓";
                                        color: #ffffff;
                                        font-size: 11px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                // Tag name.
                                Text {
                                    text: row.tag;
                                    color: row.visible ? Theme.text-primary : Theme.text-secondary;
                                    font-size: Theme.font-sm;
                                    vertical-alignment: center;
                                }

                                Rectangle { horizontal-stretch: 1; }

                                // Event count.
                                Text {
                                    text: "(" + row.count + ")";
                                    color: Theme.text-secondary;
                                    font-size: Theme.font-xs;
                                    vertical-alignment: center;
                                }
                            }

                            row-touch := TouchArea {
                                clicked => { root.row-toggled(row.tag); }
                            }
                        }
                    }
                }
            }
        }
    }
}
