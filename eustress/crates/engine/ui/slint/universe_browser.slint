// ============================================================================
// Universe Browser — sidebar panel listing all Universes and their Spaces
// ============================================================================

import { ScrollView, Button } from "std-widgets.slint";
import { Theme } from "theme.slint";

// ── Data types ───────────────────────────────────────────────────────────────

export struct SpaceItem {
    name: string,
    path: string,
    is-active: bool,
}

export struct UniverseItem {
    name: string,
    path: string,
    spaces: [SpaceItem],
    is-expanded: bool,
}

// ── Component ────────────────────────────────────────────────────────────────

export component UniverseBrowser inherits Rectangle {
    // Input: data from Bevy via bridge
    in property <[UniverseItem]> universe-items;
    in property <string> active-space-path;

    // Output: user clicked a Space entry
    callback space-selected(/* path */ string);

    background: Theme.panel-background;
    min-width: 200px;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Header bar — matches Explorer header style
        Rectangle {
            height: 32px;
            background: Theme.header-background;
            border-width: 0px;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                alignment: start;

                Text {
                    text: "Universes";
                    color: Theme.text-primary;
                    font-size: 12px;
                    font-weight: 600;
                    vertical-alignment: center;
                }
            }
        }

        // Thin separator line
        Rectangle {
            height: 1px;
            background: Theme.input-border;
        }

        // Scrollable list
        ScrollView {
            VerticalLayout {
                padding: 4px;
                spacing: 2px;
                alignment: start;

                for universe in universe-items: VerticalLayout {
                    spacing: 0px;

                    // Universe row
                    uni-row := Rectangle {
                        height: 28px;
                        border-radius: 3px;
                        background: uni-touch.has-hover ? Theme.explorer-item-hover : transparent;

                        uni-touch := TouchArea {
                            mouse-cursor: pointer;
                        }

                        HorizontalLayout {
                            padding-left: 8px;
                            spacing: 6px;
                            alignment: start;

                            // Expand/collapse chevron
                            Text {
                                text: universe.is-expanded ? "▾" : "▸";
                                color: Theme.text-secondary;
                                font-size: 10px;
                                vertical-alignment: center;
                                width: 12px;
                            }

                            // Universe icon
                            Text {
                                text: "◆";
                                color: Theme.accent-blue;
                                font-size: 10px;
                                vertical-alignment: center;
                                width: 14px;
                            }

                            Text {
                                text: universe.name;
                                color: Theme.text-primary;
                                font-size: 12px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Space rows — shown when universe.is-expanded
                    if universe.is-expanded: VerticalLayout {
                        spacing: 0px;

                        for space in universe.spaces: Rectangle {
                            height: 26px;
                            border-radius: 3px;
                            background: space.is-active ? Theme.explorer-item-selected :
                                        space-touch.has-hover ? Theme.explorer-item-hover : transparent;

                            space-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.space-selected(space.path); }
                            }

                            HorizontalLayout {
                                padding-left: 30px;
                                spacing: 6px;
                                alignment: start;

                                // Space icon — hexagon
                                Text {
                                    text: "⬡";
                                    color: space.is-active ? Theme.accent-blue : Theme.text-secondary;
                                    font-size: 10px;
                                    vertical-alignment: center;
                                    width: 14px;
                                }

                                Text {
                                    text: space.name;
                                    color: space.is-active ? #ffffff : Theme.text-primary;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
