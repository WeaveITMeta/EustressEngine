// ============================================================================
// Universe Browser — sidebar panel listing all Universes and their Spaces
// ============================================================================

import { ScrollView, Button } from "std-widgets.slint";
import { Theme } from "theme.slint";

// ── Data types ───────────────────────────────────────────────────────────────

export struct SpaceItem {
    name: string,
    path: string,
    is-active: bool,
}

export struct UniverseItem {
    name: string,
    path: string,
    spaces: [SpaceItem],
    is-expanded: bool,
}

// ── Component ────────────────────────────────────────────────────────────────

export component UniverseBrowser inherits Rectangle {
    // Input: data from Bevy via bridge
    in property <[UniverseItem]> universe-items;
    in property <string> active-space-path;

    // Output: user clicked a Space entry
    callback space-selected(/* path */ string);

    background: #1e1e1e;
    min-width: 200px;

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Header bar
        Rectangle {
            height: 32px;
            background: #2d2d2d;

            Text {
                x: 10px;
                text: "Universes";
                color: #cccccc;
                font-size: 12px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }

        // Scrollable list
        ScrollView {
            VerticalLayout {
                padding: 4px;
                spacing: 0px;
                alignment: start;

                for universe in universe-items: VerticalLayout {
                    spacing: 0px;

                    // Universe row
                    Rectangle {
                        height: 28px;
                        background: transparent;

                        HorizontalLayout {
                            padding-left: 8px;
                            spacing: 4px;
                            alignment: start;

                            // Expand/collapse chevron (static — Bevy controls is-expanded)
                            Text {
                                text: universe.is-expanded ? "▾" : "▸";
                                color: #888888;
                                font-size: 11px;
                                vertical-alignment: center;
                                width: 14px;
                            }

                            Text {
                                text: universe.name;
                                color: #d0d0d0;
                                font-size: 12px;
                                font-weight: 700;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Space rows — shown when universe.is-expanded
                    if universe.is-expanded: VerticalLayout {
                        spacing: 0px;

                        for space in universe.spaces: Rectangle {
                            height: 26px;
                            background: space.is-active ? #094771 : transparent;

                            HorizontalLayout {
                                padding-left: 28px;
                                spacing: 4px;
                                alignment: start;

                                Text {
                                    text: "⬡";
                                    color: space.is-active ? #ffffff : #888888;
                                    font-size: 10px;
                                    vertical-alignment: center;
                                    width: 14px;
                                }

                                Text {
                                    text: space.name;
                                    color: space.is-active ? #ffffff : #c0c0c0;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                            }

                            // Click handler
                            TouchArea {
                                clicked => { root.space-selected(space.path); }
                            }

                            // Hover highlight
                            states [
                                hovered when !space.is-active: {
                                    background: #2a2a2a;
                                }
                            ]
                        }
                    }
                }
            }
        }
    }
}
