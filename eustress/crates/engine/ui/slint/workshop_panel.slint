// ============================================================================
// Eustress Engine Studio - Workshop Panel
// Conversational ideation interface for product creation (System 0)
//
// Table of Contents:
//   1. Data Structures — ChatMessage, MCP command card, pipeline step
//   2. ChatBubble — message display (user, system, MCP command, approval gate)
//   3. MCPCommandCard — inline MCP endpoint display with approve/edit/skip
//   4. PipelineStep — compact step status indicator
//   5. WorkshopPanel — main panel with chat scroll, input, pipeline sidebar
// ============================================================================

import { VerticalBox, HorizontalBox, ScrollView, Button, LineEdit, TextEdit } from "std-widgets.slint";
import { Theme, PanelHeader, SidePanelHeader } from "theme.slint";
import { MentionPopup, MentionItemData } from "mention_popup.slint";

export { MentionItemData }

// ============================================================================
// 1. Data Structures
// ============================================================================

// A single message in the ideation conversation
export struct ChatMessage {
    id: int,
    role: string,           // "user" | "system" | "mcp" | "approval" | "artifact" | "error"
    content: string,        // Message text (markdown-ish)
    timestamp: string,      // Display timestamp
    mcp-endpoint: string,   // For role="mcp": the MCP endpoint being called
    mcp-method: string,     // For role="mcp": GET/POST
    mcp-status: string,     // For role="mcp": "pending" | "approved" | "running" | "done" | "skipped" | "error"
    artifact-path: string,  // For role="artifact": file path of generated artifact
    artifact-type: string,  // For role="artifact": "patent" | "sota" | "requirements" | "mesh" | "toml" | "readme" | "catalog"
    // Entity-affordance fields — populated by `sync_workshop_to_slint`
    // when the tool call created or targeted a scene entity (e.g.
    // create_entity, update_entity). When `entity-name` is non-empty
    // the chat bubble renders a clickable entity chip with class icon
    // + name, and `select-entity(name)` fires when clicked so the
    // Explorer jumps to that entity.
    entity-class: string,   // class_name, e.g. "Part" | "SoulScript" | "BillboardGui"
    entity-name: string,    // human-readable entity name
    entity-icon: image,     // pre-loaded class icon (same source the Explorer uses)
}

// Past conversation summary for history browser
export struct ConversationSummary {
    session-id: string,
    /// Human-readable short label. Generated by Claude Haiku from the
    /// first user message when available; falls back to product_name,
    /// first-message preview, or a short session id otherwise. Always
    /// non-empty — safe to use directly in tab labels and list rows.
    title: string,
    product-name: string,     // e.g. "V-Cell 4680" or "Untitled"
    state: string,            // "idle" | "running" | "complete" etc.
    message-count: int,
    cost: string,             // formatted: "$1.23"
    last-active: string,      // formatted date: "Apr 11, 2026"
    preview: string,          // first user message (truncated)
}

// Pipeline step status for the compact sidebar
export struct PipelineStepData {
    index: int,
    label: string,
    status: string,         // "waiting" | "active" | "done" | "error" | "skipped"
    artifact-count: int,    // Number of files generated in this step
}

// ============================================================================
// 2. ChatBubble — renders a single conversation message
// ============================================================================

component ChatBubble inherits Rectangle {
    in property <string> role: "system";
    in property <string> content: "";
    in property <string> timestamp: "";
    in property <string> mcp-endpoint: "";
    in property <string> mcp-method: "";
    in property <string> mcp-status: "pending";
    in property <string> artifact-path: "";
    in property <string> artifact-type: "";

    // Entity affordances (see ChatMessage struct comments)
    in property <string> entity-class: "";
    in property <string> entity-name: "";
    in property <image>  entity-icon;

    callback approve-mcp(int);
    callback skip-mcp(int);
    callback edit-mcp(int);
    callback open-artifact(string);
    callback select-entity(string);

    in property <int> message-id: 0;

    // User messages align right, everything else left
    height: bubble.preferred-height + 8px;

    HorizontalLayout {
        padding-left: root.role == "user" ? 40px : 8px;
        padding-right: root.role == "user" ? 8px : 40px;
        padding-top: 4px;
        padding-bottom: 4px;

        bubble := Rectangle {
            background: root.role == "user" ? #1a5276 :
                        root.role == "mcp" ? #2c2c3e :
                        root.role == "approval" ? #3e2c1a :
                        root.role == "artifact" ? #1a3e2c :
                        root.role == "error" ? #4a2020 :
                        Theme.background-tertiary;
            border-radius: 8px;
            border-width: root.role == "mcp" ? 1px : 0px;
            border-color: root.role == "mcp" ? #4a4a6a : transparent;

            VerticalLayout {
                padding: 10px;
                spacing: 6px;

                // Role label (not for user messages)
                if root.role != "user": Text {
                    text: root.role == "system" ? "Workshop" :
                          root.role == "mcp" ? "MCP Command" :
                          root.role == "approval" ? "Approval Required" :
                          root.role == "artifact" ? "Artifact Generated" :
                          "Error";
                    color: root.role == "mcp" ? #8888cc :
                           root.role == "approval" ? #cc8844 :
                           root.role == "artifact" ? #44cc88 :
                           root.role == "error" ? #cc4444 :
                           Theme.accent-blue;
                    font-size: 10px;
                    font-weight: 600;
                }

                // MCP tool-call badge — a terminal-style chip showing
                // the tool name. We used to render an HTTP method badge
                // (POST/GET) which looked like a mystery image when the
                // method string was empty (most tools don't have one).
                // A small "›_" glyph + monospace name reads as "tool
                // call" without the HTTP metaphor.
                //
                // NOTE: absolute positioning (explicit x/y) rather than
                // a HorizontalLayout. HL was top-aligning the fixed-
                // height children so the glyph + name read as "flush
                // with the top of the badge strip" instead of centered.
                // `y: (parent.height - self.height) / 2` on each piece
                // guarantees every element is vertical-middle regardless
                // of font metrics or Slint's layout defaults.
                if root.role == "mcp": Rectangle {
                    height: 28px;
                    background: #1a1a2e;
                    border-radius: 4px;

                    // Tool-call glyph — minimal "terminal prompt" feel
                    // using two text characters so we don't depend on
                    // an icon asset.
                    glyph := Text {
                        x: 10px;
                        y: (parent.height - self.height) / 2;
                        text: "›_";
                        color: #8888cc;
                        font-size: 12px;
                        font-weight: 700;
                        font-family: "Consolas";
                    }

                    // Optional HTTP method pill — only rendered when
                    // the tool actually carries a method (legacy
                    // MCP-over-HTTP path). Hidden for local tool
                    // calls so the badge isn't an empty rectangle.
                    method-pill := Rectangle {
                        x: glyph.x + glyph.width + 8px;
                        y: (parent.height - self.height) / 2;
                        width: root.mcp-method != "" ? 40px : 0px;
                        height: 18px;
                        visible: root.mcp-method != "";
                        background: root.mcp-method == "POST" ? #2d5a27 : #27455a;
                        border-radius: 3px;

                        Text {
                            width: 100%;
                            height: 100%;
                            text: root.mcp-method;
                            color: white;
                            font-size: 9px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // Tool name — sits flush against the glyph when the
                    // method pill is hidden, or after the pill + 8px
                    // gap when it's visible. Uses elide so long tool
                    // names don't overflow the badge.
                    Text {
                        x: method-pill.visible
                            ? method-pill.x + method-pill.width + 8px
                            : glyph.x + glyph.width + 8px;
                        y: (parent.height - self.height) / 2;
                        width: parent.width - self.x - 10px;
                        text: root.mcp-endpoint;
                        color: #ccccee;
                        font-size: 11px;
                        font-weight: 600;
                        font-family: "Consolas";
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                // Entity chip — rendered when the tool call produced or
                // targeted a scene entity. Clicking jumps the Explorer
                // to that entity. Icon is y-centered with the name via
                // explicit `y: (parent.height - self.height) / 2`
                // arithmetic (HorizontalLayout was top-aligning fixed-
                // height children in the same way it did on the tool
                // badge above). The whole chip is a single TouchArea
                // so the click target covers icon + name.
                if root.entity-name != "": Rectangle {
                    height: 30px;
                    background: entity-touch.has-hover ? #1a3050 : #162638;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: entity-touch.has-hover ? Theme.accent-blue : #25405a;

                    entity-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.select-entity(root.entity-name); }
                    }

                    entity-icon-img := Image {
                        x: 8px;
                        y: (parent.height - self.height) / 2;
                        width: 16px;
                        height: 16px;
                        source: root.entity-icon;
                        image-fit: contain;
                    }

                    entity-name-text := Text {
                        x: entity-icon-img.x + entity-icon-img.width + 8px;
                        y: (parent.height - self.height) / 2;
                        width: parent.width - self.x - entity-class-text.width - 16px;
                        text: root.entity-name;
                        color: Theme.text-primary;
                        font-size: 11px;
                        font-weight: 600;
                        font-family: "Consolas";
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    entity-class-text := Text {
                        x: parent.width - self.width - 8px;
                        y: (parent.height - self.height) / 2;
                        text: root.entity-class;
                        color: Theme.text-secondary;
                        font-size: 10px;
                        vertical-alignment: center;
                    }
                }

                // Message content
                Text {
                    text: root.content;
                    color: root.role == "error" ? #ff8888 : Theme.text-primary;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                // Artifact file path (clickable)
                if root.role == "artifact": Rectangle {
                    height: 24px;
                    background: #0a2a1a;
                    border-radius: 4px;

                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.open-artifact(root.artifact-path); }
                    }

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 4px;

                        Image {
                            width: 12px;
                            height: 12px;
                            source: @image-url("../../assets/icons/ui/new-file.svg");
                            image-fit: contain;
                            colorize: #44cc88;
                            vertical-alignment: center;
                        }

                        Text {
                            text: root.artifact-path;
                            color: #44cc88;
                            font-size: 11px;
                            font-family: "Consolas";
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }

                // Approval buttons (for MCP commands pending approval)
                if root.role == "mcp" && root.mcp-status == "pending": HorizontalLayout {
                    spacing: 6px;
                    padding-top: 4px;

                    // Approve button
                    Rectangle {
                        width: 70px;
                        height: 26px;
                        background: approve-touch.has-hover ? #2d7d46 : #245a36;
                        border-radius: 4px;

                        approve-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.approve-mcp(root.message-id); }
                        }

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 4px;

                            Image {
                                width: 12px;
                                height: 12px;
                                source: @image-url("../../assets/icons/ui/check.svg");
                                image-fit: contain;
                                colorize: white;
                                vertical-alignment: center;
                            }

                            Text {
                                text: "Run";
                                color: white;
                                font-size: 11px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Edit button (lets user modify before running)
                    Rectangle {
                        width: 60px;
                        height: 26px;
                        background: edit-touch.has-hover ? #5a5a2d : #3e3e20;
                        border-radius: 4px;

                        edit-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.edit-mcp(root.message-id); }
                        }

                        Text {
                            text: "Edit";
                            color: #cccc88;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // Skip button
                    Rectangle {
                        width: 60px;
                        height: 26px;
                        background: skip-touch.has-hover ? #5a2d2d : #3e2020;
                        border-radius: 4px;

                        skip-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.skip-mcp(root.message-id); }
                        }

                        Text {
                            text: "Skip";
                            color: #cc8888;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // MCP status indicator (after approval)
                if root.role == "mcp" && root.mcp-status != "pending": HorizontalLayout {
                    spacing: 4px;
                    padding-top: 2px;

                    VerticalLayout {
                        alignment: center;
                        width: 8px;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: root.mcp-status == "running" ? Theme.accent-blue :
                                        root.mcp-status == "done" ? Theme.accent-green :
                                        root.mcp-status == "skipped" ? Theme.text-secondary :
                                        root.mcp-status == "error" ? Theme.accent-red :
                                        Theme.accent-blue;
                        }
                    }

                    Text {
                        text: root.mcp-status == "running" ? "Running..." :
                              root.mcp-status == "done" ? "Complete" :
                              root.mcp-status == "skipped" ? "Skipped" :
                              root.mcp-status == "approved" ? "Queued" :
                              root.mcp-status == "error" ? "Failed" : "";
                        color: Theme.text-secondary;
                        font-size: 10px;
                        vertical-alignment: center;
                    }
                }

                // Timestamp. On user bubbles (blue accent background)
                // the `Theme.text-disabled` grey disappeared against the
                // fill — use a semi-transparent white instead so it's
                // legible on the coloured bubble and still reads as a
                // muted caption on the assistant's darker background.
                Text {
                    text: root.timestamp;
                    color: root.role == "user" ? #ffffffb0 : Theme.text-secondary;
                    font-size: 9px;
                    horizontal-alignment: root.role == "user" ? right : left;
                }
            }
        }
    }
}

// ============================================================================
// 3. PipelineStep — compact step indicator in sidebar
// ============================================================================

component PipelineStep inherits Rectangle {
    in property <int> index: 0;
    in property <string> label: "";
    in property <string> status: "waiting";
    in property <int> artifact-count: 0;

    height: 28px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;

        // Status dot
        VerticalLayout {
            alignment: center;
            width: 10px;
            Rectangle {
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: root.status == "done" ? Theme.accent-green :
                            root.status == "active" ? Theme.accent-blue :
                            root.status == "error" ? Theme.accent-red :
                            root.status == "skipped" ? Theme.text-disabled :
                            #333344;
            }
        }

        // Step label
        Text {
            horizontal-stretch: 1;
            text: root.label;
            color: root.status == "active" ? Theme.text-primary :
                   root.status == "done" ? Theme.text-success :
                   root.status == "error" ? Theme.text-error :
                   Theme.text-secondary;
            font-size: 11px;
            font-weight: root.status == "active" ? 600 : 400;
            vertical-alignment: center;
            overflow: elide;
        }

        // Artifact count badge
        if root.artifact-count > 0: Rectangle {
            width: 18px;
            height: 16px;
            background: #1a3e2c;
            border-radius: 8px;

            Text {
                text: root.artifact-count;
                color: #44cc88;
                font-size: 9px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

// ============================================================================
// 4. WorkshopPanel — main conversational ideation panel
// ============================================================================

export component WorkshopPanel inherits Rectangle {
    // ---- Properties ----
    in property <[ChatMessage]> messages: [];
    in-out property <string> input-text: "";
    in property <[PipelineStepData]> pipeline-steps: [];
    // True when the chat TextInput or command bar is focused. The host
    // reads this to gate engine keyboard handling — without it, WASD /
    // shortcut keys leak through to the viewport while the user is
    // typing a message, moving the camera under their fingers.
    out property <bool> input-has-focus: input-area.has-focus;

    // The status bar + step list hide on idle/conversing so the panel
    // doesn't look like it's working when the user is just chatting.
    in property <string> pipeline-state: "idle";
    // Collapsed by default — user clicks the chevron in the status row
    // to drop down the 13-step detail list. Without this the step list
    // took ~400 px of vertical space on every frame of real work.
    in-out property <bool> pipeline-steps-expanded: false;
    in property <string> product-name: "";
    in property <int> total-artifacts: 0;
    in property <string> estimated-cost: "$0.00";
    in property <bool> api-key-valid: false;

    // Stage 2: Active modes (AI-inferred, multiple simultaneous) + command bar
    in property <string> active-modes-text: "⚡ General";   // formatted badge text
    in-out property <string> command-text: "";
    in property <int> tool-count: 0;
    in property <string> active-tool: "";          // currently executing tool name (empty = idle)

    // Conversation history — live list from SoulService/Workshop/.
    // Host refreshes this via `sync_workshop_sessions_to_slint` every
    // ~500 ms so new conversations appear without an engine restart.
    in property <[ConversationSummary]> past-conversations: [];
    /// Session id of the conversation currently loaded in the chat.
    /// Drives the highlighted tab in the session tab strip.
    in property <string> active-session-id: "";
    in-out property <bool> show-history-modal: false;
    in-out property <string> history-search: "";
    /// Fires when the user clicks the × on a session tab. The host
    /// handler removes the entry from `past-conversations` (it may
    /// also delete the on-disk folder — host decision).
    callback on-close-conversation(string);
    /// Fires when a drag-reorder ends. `session_id` is the tab that
    /// was dragged; `target_index` is its new 0-based position in
    /// `past-conversations`. Host maintains the order override and
    /// pushes the reordered list back on the next sync tick.
    callback on-reorder-tab(string /* session_id */, int /* target_index */);

    // ── Drag-to-reorder state ───────────────────────────────────────────
    // The dragged tab's session id while the mouse is held down on it,
    // plus the live x-offset relative to its resting position so we
    // can translate it during the drag. Slint has no native drag-drop
    // API; we synthesise it from TouchArea.pressed + mouse-x deltas.
    private property <string> drag-session-id: "";
    private property <length> drag-offset-x: 0px;
    // Horizontal cursor position (relative to the tab strip's left
    // edge) while dragging. Drives the target-index computation on
    // release and lives on the root so per-tab Rectangles can read it.
    private property <length> drag-cursor-x: 0px;
    // Approximate tab stride — the tabs use `min(180, label+40)` so a
    // uniform stride here is an acceptable heuristic; drop-zone math
    // rounds cursor-x / stride to pick the target index. If we ever
    // add variable-width tabs with per-tab bounds reporting we'd
    // replace this with an exact hit-test.
    private property <length> drag-tab-stride: 120px;

    // ── @ Mention autocomplete ───────────────────────────────────────────
    // Popup state driven by user typing. When the user types `@`, the host
    // (Bevy side) receives the query prefix, searches the MentionIndex,
    // and pushes results back via `mention-items`. Enter commits the
    // selected item, which replaces the `@foo` token in `input-text` with
    // the chosen entry's canonical path.
    in property <[MentionItemData]> mention-items: [];
    in-out property <bool> mention-popup-visible: false;
    in-out property <int> mention-selected-index: 0;
    /// Prefix the user has typed after `@` (no `@` char). Bevy side
    /// watches this and re-queries on change.
    in-out property <string> mention-query: "";
    /// Character position where the `@` sits in `input-text`. Needed so
    /// commit can splice the chip in exactly the right spot.
    in-out property <int> mention-at-pos: -1;

    callback on-mention-query-changed(string);  // emit when prefix changes
    callback on-mention-commit(int);            // item index committed (also fires record_usage)
    callback on-mention-cancel();               // popup dismissed without commit

    /// Scan `input-text` for a trailing `@prefix` token; if found, open
    /// the popup and emit a query. Called from the input field's `edited`
    /// hook every keystroke. Cursor position isn't directly exposed by
    /// Slint's TextInput so we scan from the end — works perfectly for
    /// the common case (user types `@` at the caret).
    function update-mention-state() {
        // Find the last `@` in input-text. If the tail from there to end
        // contains whitespace, the user already closed a previous mention;
        // don't re-open.
        // Slint has no .find() for strings — emulate via manual scan.
        // For performance: input text is typically < 1 KB, linear scan is fine.
        //
        // Algorithm:
        //   1. Walk characters from end to start.
        //   2. If we hit whitespace before an `@`, no active mention.
        //   3. If we hit `@`, extract the tail after it as the query.
        //
        // We implement this in a compact inline form.
        //
        // NOTE: Slint .character-count and string slicing are limited; we
        // rely on the host callback to do the heavy lifting by passing
        // the raw input-text. The host parses it and pushes query back
        // via `mention-query` so the UI stays reactive.
        root.on-mention-query-changed(root.input-text);
    }

    // ---- Callbacks ----
    callback on-send-message(string);               // User sends a message
    callback on-approve-mcp(int);                   // User approves an MCP command by message id
    callback on-skip-mcp(int);                      // User skips an MCP command
    callback on-edit-mcp(int);                      // User wants to edit before running
    callback on-open-artifact(string);              // User clicks an artifact path
    callback on-select-entity(string);              // User clicks an entity chip in a chat bubble — select by name in Explorer
    callback on-start-pipeline();                   // Start the ideation pipeline
    callback on-pause-pipeline();                   // Pause to let user review
    callback on-resume-pipeline();                  // Resume after pause/edit
    callback on-cancel-pipeline();                  // Cancel the whole thing
    callback on-configure-api();                    // Open Soul Settings for API key
    callback on-optimize-and-build();               // Hand off to Systems 1-8
    callback on-execute-command(string);             // Command bar executed (Rune, /run workflow, etc.)
    callback on-load-conversation(string);           // Load a past conversation by session ID
    callback on-new-conversation();                  // Start a new conversation

    background: Theme.panel-background;

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // Unified side-panel title — shared 36px gradient + bold
        // label + optional count badge, consistent with Properties /
        // History / Soul / Problems.
        SidePanelHeader {
            title: "WORKSHOP";
            count: root.past-conversations.length;
            show-icon: true;
            icon: @image-url("../../assets/icons/wrench.svg");
        }

        // Secondary toolbar — + / history buttons moved here to keep
        // the title strip clean.
        Rectangle {
            height: 28px;
            background: Theme.header-background;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 4px;
                spacing: 4px;
                alignment: end;

                // New conversation button
                Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 3px;
                    background: new-conv-touch.has-hover ? Theme.button-hover : transparent;
                    y: (parent.height - self.height) / 2;

                    new-conv-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-new-conversation(); }
                    }

                    Text {
                        text: "+";
                        color: Theme.text-secondary;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // History button
                Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 3px;
                    background: hist-touch.has-hover ? Theme.button-hover : transparent;
                    y: (parent.height - self.height) / 2;

                    hist-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.show-history-modal = true; }
                    }

                    Image {
                        width: 14px;
                        height: 14px;
                        source: @image-url("../../assets/icons/ui/history.svg");
                        image-fit: contain;
                        colorize: Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── Session tab strip ───────────────────────────────────────────────
        //
        // Horizontal scrollable list of recent Workshop sessions. Each tab
        // shows the session's short title (Haiku-generated when available,
        // first-message fallback otherwise) and an × button. Clicking the
        // body switches the chat to that session; clicking × removes the
        // tab via `on-close-conversation`.
        //
        // Rendered only when there's at least one session on disk. An
        // empty strip takes zero vertical space so fresh installs aren't
        // cluttered.
        if root.past-conversations.length > 0: Rectangle {
            height: 32px;
            background: Theme.panel-background;

            // 1px bottom divider separating tabs from the chat area below.
            Rectangle {
                x: 0px;
                y: parent.height - 1px;
                width: 100%;
                height: 1px;
                background: Theme.border-color;
            }

            // Absorb scroll events so the mouse wheel scrolls the tab
            // strip horizontally (via the inner Flickable) instead of
            // bubbling to the Bevy viewport (camera zoom) or the chat.
            TouchArea {
                scroll-event(event) => { accept }
            }

            Flickable {
                x: 0px; y: 0px;
                width: 100%;
                height: 31px; // leave 1px for divider
                viewport-width: tab-row.preferred-width;
                viewport-height: self.height;

                tab-row := HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 6px;
                    spacing: 4px;
                    alignment: start;

                    // Outer Rectangle is a layout-controlled slot — only
                    // width/height/y live here because HorizontalLayout
                    // manages its children's x directly and Slint rejects
                    // any manual `x:` binding on a layout child. The
                    // visual tab (background, border, shadow, contents)
                    // is an inner Rectangle whose x shifts while dragging.
                    for conv[tab-index] in root.past-conversations: Rectangle {
                        property <bool> is-active: conv.session-id == root.active-session-id;
                        property <bool> is-dragging: conv.session-id == root.drag-session-id;
                        // Fixed tab width — referencing `label-text.preferred-width`
                        // from both this slot AND the nested tab-visual (whose
                        // HorizontalLayout contains label-text with
                        // horizontal-stretch + overflow: elide) tripped Slint's
                        // cycle detector. Uniform widths also match how
                        // VS Code / Chrome render their tab strips, so we pay
                        // a small readability cost (long titles elide) to get
                        // a stable layout.
                        width: 160px;
                        height: 26px;
                        y: 2px;
                        background: transparent;
                        clip: false;

                        // tab-touch is declared FIRST so tab-visual (and its
                        // nested close-touch) render on top and their
                        // TouchAreas win over this one for the × button.
                        // tab-touch lives at the layout slot (outside the
                        // translating tab-visual) so pressed-x / mouse-x
                        // stay in a stable coordinate frame during drag.
                        tab-touch := TouchArea {
                            mouse-cursor: is-dragging ? grabbing : pointer;

                            // Press-to-drag threshold: treat movement
                            // > 5px as a drag, anything less as a plain
                            // click. Without this threshold even tiny
                            // jitters on-click would register as drags.
                            pointer-event(ev) => {
                                if ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left {
                                    root.drag-session-id = conv.session-id;
                                    root.drag-offset-x = 0px;
                                }
                                if ev.kind == PointerEventKind.up && ev.button == PointerEventButton.left {
                                    // Commit the reorder if we dragged far
                                    // enough in either direction. 0.5 tab-
                                    // widths is the threshold the cursor
                                    // must pass to snap into an adjacent slot.
                                    if root.drag-session-id == conv.session-id
                                       && abs(root.drag-offset-x / 1px) >= 30 {
                                        // Compute target index from cursor delta.
                                        // Positive delta → shift right; negative → left.
                                        // Clamp to [0, length-1].
                                        let raw = tab-index + round(root.drag-offset-x / root.drag-tab-stride);
                                        let clamped = max(0, min(root.past-conversations.length - 1, raw));
                                        root.on-reorder-tab(conv.session-id, clamped);
                                    }
                                    root.drag-session-id = "";
                                    root.drag-offset-x = 0px;
                                }
                            }

                            moved => {
                                if root.drag-session-id == conv.session-id && self.pressed {
                                    // mouse-x is relative to this TouchArea; pressed-x was
                                    // the initial grab position. Delta = live - initial.
                                    root.drag-offset-x = self.mouse-x - self.pressed-x;
                                }
                            }

                            clicked => {
                                // Only treat as a tab-switch click when
                                // we weren't dragging (offset stayed
                                // below the threshold on release).
                                if abs(root.drag-offset-x / 1px) < 5 {
                                    root.on-load-conversation(conv.session-id);
                                }
                            }
                        }

                        tab-visual := Rectangle {
                            // Match the fixed slot width. `parent.width`
                            // would pull through the outer Rectangle and
                            // Slint flagged that as recursive once
                            // label-text was nested here. A constant width
                            // sidesteps any layout-dependency chain.
                            width: 160px;
                            height: 26px;
                            // Translate the dragged tab by the cursor delta
                            // so it follows the mouse. A slight opacity drop
                            // + shadow reads as "being moved" since Slint
                            // doesn't expose z directly on layout children.
                            // NOTE: tab-touch stays OUTSIDE this Rectangle so
                            // it keeps its original coordinate frame — if
                            // the TouchArea translated with the visual, the
                            // self.mouse-x / self.pressed-x delta would chase
                            // its own tail and the drag would stall.
                            x: is-dragging ? root.drag-offset-x : 0px;
                            opacity: is-dragging ? 0.85 : 1.0;
                            background: is-active ? Theme.background-tertiary : (tab-touch.has-hover ? Theme.button-hover : transparent);
                            border-radius: 4px;
                            border-width: is-active || is-dragging ? 1px : 0px;
                            border-color: is-dragging ? Theme.accent-green : Theme.accent-blue;
                            drop-shadow-blur: is-dragging ? 12px : 0px;
                            drop-shadow-color: #00000080;

                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 4px;
                                spacing: 4px;

                                label-text := Text {
                                    text: conv.title;
                                    color: is-active ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 11px;
                                    font-weight: is-active ? 600 : 400;
                                    vertical-alignment: center;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }

                                // × close button. Only emits the callback —
                                // doesn't fire the outer tab click thanks to
                                // its own TouchArea eating the event.
                                Rectangle {
                                    width: 18px;
                                    height: 18px;
                                    y: (parent.height - self.height) / 2;
                                    border-radius: 3px;
                                    background: close-touch.has-hover ? #3d1515 : transparent;

                                    close-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.on-close-conversation(conv.session-id); }
                                    }

                                    Text {
                                        text: "×";
                                        color: close-touch.has-hover ? #ef5350 : Theme.text-disabled;
                                        font-size: 14px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // API key warning (if not configured)
        if !root.api-key-valid: Rectangle {
            height: 56px;
            background: #3e3e20;

            VerticalLayout {
                padding: 8px;
                spacing: 4px;
                alignment: center;

                HorizontalLayout {
                    spacing: 4px;
                    alignment: center;

                    Image {
                        width: 14px;
                        height: 14px;
                        source: @image-url("../../assets/icons/ui/info.svg");
                        image-fit: contain;
                        vertical-alignment: center;
                    }

                    Text {
                        text: "Soul Service API key required";
                        color: Theme.text-primary;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                HorizontalLayout {
                    alignment: center;

                    Rectangle {
                        width: 70px;
                        height: 22px;
                        background: Theme.button-background;
                        border-radius: 4px;

                        TouchArea {
                            clicked => { root.on-configure-api(); }
                        }

                        Text {
                            text: "Configure";
                            color: Theme.text-primary;
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // ── Pipeline status row (only when work is happening or just done) ──
        //
        // Hidden entirely during `idle` and `conversing` — those are chat
        // states with nothing to report, and an empty progress bar was
        // making the panel look like it was churning when it wasn't.
        // `running | paused | complete | error` each get a one-line strip.
        if root.pipeline-state == "running"
            || root.pipeline-state == "paused"
            || root.pipeline-state == "complete"
            || root.pipeline-state == "error": Rectangle {
            height: 28px;
            background: root.pipeline-state == "complete" ? #1a3e2c :
                        root.pipeline-state == "error" ? #4a2020 :
                        root.pipeline-state == "paused" ? #3e3e20 :
                        #1a1a3e;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 8px;

                Rectangle {
                    width: 8px;
                    y: (parent.height - self.height) / 2;
                    height: 8px;
                    border-radius: 4px;
                    background: root.pipeline-state == "running" ? Theme.accent-blue :
                                root.pipeline-state == "complete" ? Theme.accent-green :
                                root.pipeline-state == "paused" ? #cccc44 :
                                Theme.accent-red;
                }

                Text {
                    horizontal-stretch: 1;
                    text: root.pipeline-state == "running" ? "Creating " + root.product-name :
                          root.pipeline-state == "complete" ? root.product-name + " ready" :
                          root.pipeline-state == "paused" ? "Waiting for your input" :
                          "Pipeline error";
                    color: Theme.text-primary;
                    font-size: 11px;
                    vertical-alignment: center;
                    overflow: elide;
                }

                Text {
                    text: "~" + root.estimated-cost;
                    color: Theme.text-secondary;
                    font-size: 10px;
                    vertical-alignment: center;
                }

                Text {
                    text: root.total-artifacts + " files";
                    color: #44cc88;
                    font-size: 10px;
                    vertical-alignment: center;
                }

                // Expand/collapse the per-step detail list.
                Rectangle {
                    width: 20px;
                    y: (parent.height - self.height) / 2;
                    height: 20px;
                    border-radius: 3px;
                    background: chevron-touch.has-hover ? Theme.button-hover : transparent;
                    visible: root.pipeline-steps.length > 0;

                    chevron-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.pipeline-steps-expanded = !root.pipeline-steps-expanded;
                        }
                    }

                    Text {
                        text: root.pipeline-steps-expanded ? "▾" : "▸";
                        color: Theme.text-secondary;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // ── Step detail list — only when user expands the chevron ───────────
        //
        // The 13-step vertical list used to show permanently and ate the
        // whole chat panel. Now it's opt-in: click the chevron in the
        // status row to drop it down, capped to 180px with a scroll.
        if root.pipeline-steps-expanded
            && root.pipeline-steps.length > 0
            && (root.pipeline-state == "running"
                || root.pipeline-state == "paused"
                || root.pipeline-state == "complete"): Rectangle {
            max-height: 180px;
            background: Theme.background-secondary;

            ScrollView {
                VerticalLayout {
                    padding: 4px;
                    spacing: 0px;

                    for step in root.pipeline-steps: PipelineStep {
                        index: step.index;
                        label: step.label;
                        status: step.status;
                        artifact-count: step.artifact-count;
                    }
                }
            }
        }

        // Chat messages area
        if root.messages.length == 0: Rectangle {
            vertical-stretch: 1;
            background: Theme.panel-background;

            VerticalLayout {
                alignment: center;
                spacing: 8px;

                HorizontalLayout {
                    alignment: center;
                    height: 40px;

                    Image {
                        width: 40px;
                        height: 40px;
                        source: @image-url("../../assets/icons/ui/sparkle.svg");
                        image-fit: contain;
                        opacity: 0.5;
                    }
                }

                Text {
                    text: "Workshop";
                    color: Theme.text-primary;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Describe your product idea.\nThe system will guide you through\npatent, validation, meshes, and TOML\ngeneration — step by step.";
                    color: Theme.text-secondary;
                    font-size: 11px;
                    horizontal-alignment: center;
                }

                // Quick start examples
                Rectangle {
                    height: 80px;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;

                        Text {
                            text: "Try:";
                            color: Theme.text-disabled;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }

                        // Example 1
                        Rectangle {
                            height: 24px;
                            background: example1-touch.has-hover ? #ffffff08 : transparent;
                            border-radius: 4px;

                            example1-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.on-send-message("Solid-state sodium-sulfur battery, 15k cycle life, 900 Wh/kg");
                                }
                            }

                            Text {
                                text: "\"Solid-state sodium-sulfur battery, 15k cycle life\"";
                                color: Theme.accent-blue;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Example 2
                        Rectangle {
                            height: 24px;
                            background: example2-touch.has-hover ? #ffffff08 : transparent;
                            border-radius: 4px;

                            example2-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.on-send-message("Gravity drive using Element 115 stable island isotope");
                                }
                            }

                            Text {
                                text: "\"Gravity drive using Element 115 stable island isotope\"";
                                color: Theme.accent-blue;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        if root.messages.length > 0: ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding: 4px;
                spacing: 0px;

                for msg in root.messages: ChatBubble {
                    role: msg.role;
                    content: msg.content;
                    timestamp: msg.timestamp;
                    mcp-endpoint: msg.mcp-endpoint;
                    mcp-method: msg.mcp-method;
                    mcp-status: msg.mcp-status;
                    artifact-path: msg.artifact-path;
                    artifact-type: msg.artifact-type;
                    entity-class: msg.entity-class;
                    entity-name: msg.entity-name;
                    entity-icon: msg.entity-icon;
                    message-id: msg.id;

                    approve-mcp(id) => { root.on-approve-mcp(id); }
                    skip-mcp(id) => { root.on-skip-mcp(id); }
                    edit-mcp(id) => { root.on-edit-mcp(id); }
                    open-artifact(path) => { root.on-open-artifact(path); }
                    select-entity(name) => { root.on-select-entity(name); }
                }
            }
        }

        // "Optimize & Build" handoff button (shown when ideation is complete)
        if root.pipeline-state == "complete": Rectangle {
            height: 44px;
            background: #1a3e2c;

            HorizontalLayout {
                padding: 8px;
                spacing: 8px;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 28px;
                    background: optimize-touch.has-hover ? #2d7d46 : #245a36;
                    border-radius: 4px;

                    optimize-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-optimize-and-build(); }
                    }

                    HorizontalLayout {
                        alignment: center;
                        spacing: 6px;

                        Image {
                            width: 14px;
                            height: 14px;
                            source: @image-url("../../assets/icons/ui/play.svg");
                            image-fit: contain;
                            colorize: white;
                            vertical-alignment: center;
                        }

                        Text {
                            text: "Optimize & Build (Systems 1-8)";
                            color: white;
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // Input area (always visible, dynamic height)
        Rectangle {
            min-height: 80px;
            background: Theme.background-secondary;

            // Top separator
            Rectangle {
                y: 0px;
                height: 1px;
                background: Theme.border-color;
            }

            VerticalLayout {
                padding: 8px;
                spacing: 6px;

                // ── Mode bar + tool count — vertically centered row ──
                HorizontalLayout {
                    height: 20px;
                    spacing: 6px;
                    alignment: start;

                    Text {
                        text: root.active-modes-text;
                        color: Theme.text-secondary;
                        font-size: 10px;
                        vertical-alignment: center;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }

                    if root.active-tool != "": Text {
                        text: "⟳ " + root.active-tool;
                        color: #4caf50;
                        font-size: 9px;
                        vertical-alignment: center;
                    }

                    if root.active-tool == "" && root.tool-count > 0: Text {
                        text: root.tool-count + " tools";
                        color: Theme.text-secondary;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                }

                // ── Chat input (multi-line, dynamic height) ──
                //
                // Windsurf / Cursor / ChatGPT convention: the box starts at
                // one line of text and grows as the user adds lines, up to
                // a cap of ~6 lines. Past that, a scrollbar appears and
                // the mouse wheel navigates the text inside. Mouse wheel
                // never leaks to the 3D viewport because the camera
                // controller already skips wheel input when the cursor is
                // over a UI panel (see camera_controller.rs: ui_focus.has_focus).
                HorizontalLayout {
                    spacing: 6px;

                    Rectangle {
                        horizontal-stretch: 1;
                        // Grow-to-fit with a 6-line cap. `input-area.preferred-height`
                        // is the natural height TextInput needs to render all text
                        // without clipping — cheap to read, recomputed automatically
                        // as the user types. We clamp to min=36px (one comfortable
                        // line + padding) and max=132px (six lines + padding);
                        // past that ScrollView kicks in.
                        // (Slint rejects `height` + `min-height` on the same
                        // element, so the floor lives inside the `max(...)`.)
                        height: min(132px, max(36px, input-area.preferred-height + 16px));
                        background: Theme.background-tertiary;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: input-area.has-focus ? Theme.accent-blue : Theme.border-color;
                        clip: true;

                        input-scroll := ScrollView {
                            x: 10px;
                            y: 6px;
                            width: parent.width - 20px;
                            height: parent.height - 12px;
                            // Tell the ScrollView exactly how tall the content is
                            // so its scrollbar + wheel handler activate at the
                            // right threshold. When preferred-height ≤ viewport,
                            // ScrollView hides the bar and behaves as a plain wrap.
                            viewport-width: self.width;
                            viewport-height: max(self.height, input-area.preferred-height);

                            input-area := TextInput {
                                width: parent.width;
                                color: Theme.text-primary;
                                font-size: 12px;
                                text <=> root.input-text;
                                single-line: false;
                                wrap: word-wrap;

                            accepted => {
                                // If the popup is open, Enter commits the
                                // highlighted mention instead of sending.
                                if root.mention-popup-visible && root.mention-items.length > 0 {
                                    root.on-mention-commit(root.mention-selected-index);
                                    return;
                                }
                                if root.input-text != "" {
                                    root.on-send-message(root.input-text);
                                    root.input-text = "";
                                }
                            }

                            // Live-edit hook — every keystroke scans back
                            // from the cursor for the most recent `@`. If
                            // one is found within 32 chars and not
                            // followed by whitespace, the popup opens with
                            // the prefix query.
                            edited => {
                                // Slint doesn't expose cursor-position here;
                                // we approximate by scanning from the end
                                // of input-text for the last `@` not
                                // preceded by alphanumerics.
                                // Simple heuristic: split on whitespace,
                                // examine the final token.
                                // Future refinement: expose cursor position
                                // via a custom property.
                                root.update-mention-state();
                            }

                            key-pressed(ev) => {
                                // Ctrl+Enter sends the message without
                                // inserting a newline. Plain Enter still
                                // inserts a newline (standard multi-line
                                // TextInput behavior) — matches Discord /
                                // Slack / ChatGPT conventions.
                                if ev.text == Key.Return && ev.modifiers.control {
                                    if root.input-text != "" {
                                        root.on-send-message(root.input-text);
                                        root.input-text = "";
                                    }
                                    return accept;
                                }
                                // Intercept nav keys only when popup is open.
                                if root.mention-popup-visible {
                                    if ev.text == Key.UpArrow {
                                        if root.mention-selected-index > 0 {
                                            root.mention-selected-index -= 1;
                                        }
                                        return accept;
                                    }
                                    if ev.text == Key.DownArrow {
                                        if root.mention-selected-index < root.mention-items.length - 1 {
                                            root.mention-selected-index += 1;
                                        }
                                        return accept;
                                    }
                                    if ev.text == Key.Escape {
                                        root.mention-popup-visible = false;
                                        root.on-mention-cancel();
                                        return accept;
                                    }
                                    if ev.text == Key.Tab {
                                        if root.mention-items.length > 0 {
                                            root.on-mention-commit(root.mention-selected-index);
                                        }
                                        return accept;
                                    }
                                }
                                return reject;
                            }
                        } // close TextInput (input-area)
                        } // close ScrollView (input-scroll)
                    } // close outer Rectangle (input container)

                    // Send button (arrow-up icon). Bottom-pinned to the
                    // layout so the icon stays aligned with the first
                    // line of the input even as the box grows taller.
                    // 2px inset from the bottom keeps the arrow's visual
                    // centre on the text baseline.
                    Rectangle {
                        width: 36px;
                        height: 36px;
                        y: parent.height - self.height - 2px;
                        background: root.input-text != "" ? (send-touch.has-hover ? #2d7d46 : Theme.button-primary) : Theme.button-background;
                        border-radius: 8px;

                        send-touch := TouchArea {
                            mouse-cursor: root.input-text != "" ? pointer : default;
                            enabled: root.input-text != "";
                            clicked => {
                                root.on-send-message(root.input-text);
                                root.input-text = "";
                            }
                        }

                        // Icon centred inside the button with explicit
                        // x/y math — `horizontal-alignment`/`vertical-alignment`
                        // defaults can leave Image floating when its
                        // parent dimensions change at runtime. The
                        // arithmetic below keeps the glyph pixel-perfect
                        // regardless of button size.
                        Image {
                            width: 16px;
                            height: 16px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            source: @image-url("../../assets/icons/ui/send.svg");
                            image-fit: contain;
                            colorize: root.input-text != "" ? white : Theme.text-disabled;
                        }
                    }
                }
            }
        }
    }

    // ── @ Mention Popup overlay ──────────────────────────────────────────
    // Floats above the input area. Anchored bottom-right of the chat so
    // it opens upward from the input. Host (Bevy) toggles visibility via
    // `mention-popup-visible` in response to the user typing `@`.
    if root.mention-popup-visible: Rectangle {
        // Position: centered on the chat, aligned with the input. Sits
        // just above the input area (~70px offset) so it doesn't
        // obscure what the user is typing. Height matches the popup's
        // own min(28 + 320, 348) budget when the list is long.
        x: (parent.width - 360px) / 2;
        y: parent.height - 120px - self.height;
        width: 360px;
        height: root.mention-items.length > 0
            ? min(28px + min(root.mention-items.length * 42px + 8px, 320px), 348px)
            : 68px;

        // Eat wheel events that hit the popup's outer rectangle (the
        // few pixels around the rounded border). Without this, scroll
        // past the corners falls through to the 3D viewport and zooms
        // the camera. Inner ScrollView handles wheel within the list.
        TouchArea {
            scroll-event(event) => { accept }
        }

        MentionPopup {
            items: root.mention-items;
            selected-index: root.mention-selected-index;
            show-recent-header: root.mention-query == "";
            title: root.mention-query == "" ? "Mentions" : "@" + root.mention-query;
            on-select(i) => { root.on-mention-commit(i); }
        }
    }

    // ── Conversation History Modal ──
    if root.show-history-modal: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000060;

        TouchArea {
            clicked => { root.show-history-modal = false; }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(parent.width - 40px, 500px);
            height: min(parent.height - 60px, 450px);
            background: Theme.panel-background;
            border-radius: 10px;
            border-width: 1px;
            border-color: Theme.border-color;
            drop-shadow-blur: 20px;
            drop-shadow-color: #00000080;

            // Absorb clicks on the modal itself
            TouchArea {
                scroll-event(event) => { return accept; }
            }

            VerticalLayout {
                padding: 0px;
                spacing: 0px;

                // Modal header
                Rectangle {
                    height: 44px;
                    background: Theme.header-background;
                    border-top-left-radius: 10px;
                    border-top-right-radius: 10px;

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 8px;

                        Text {
                            text: "Conversations";
                            color: Theme.text-primary;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        // Close button — matches the red-hover convention
                        // used by every other × in the Workshop (tab close,
                        // mention-popup close, etc.): dark-red background
                        // + bright-red glyph on hover.
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 4px;
                            background: hist-close-touch.has-hover ? #3d1515 : transparent;
                            y: (parent.height - self.height) / 2;

                            hist-close-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.show-history-modal = false; }
                            }

                            Image {
                                width: 12px;
                                height: 12px;
                                source: @image-url("../../assets/icons/ui/close.svg");
                                image-fit: contain;
                                colorize: hist-close-touch.has-hover ? #ef5350 : Theme.text-secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Search bar
                Rectangle {
                    height: 36px;
                    background: Theme.header-background;

                    HorizontalLayout {
                        padding: 6px;
                        padding-left: 16px;
                        padding-right: 16px;

                        Rectangle {
                            horizontal-stretch: 1;
                            border-radius: 6px;
                            background: #1a1a1a;
                            border-width: 1px;
                            border-color: #3a3a3a;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 6px;
                                // `alignment: start` pins the icon to the
                                // left edge so it reads as a search prefix,
                                // not a centered decoration. The input still
                                // `horizontal-stretch: 1` and fills the rest.
                                alignment: start;

                                // Wrap the 14x14 icon in a Rectangle sized to
                                // the row height and center the Image inside.
                                // HorizontalLayout stretches children to fill
                                // height, so a bare Image with `vertical-
                                // alignment: center` drew the tiny glyph at
                                // the top-left of a stretched 14x34 cell.
                                Rectangle {
                                    width: 14px;
                                    height: parent.height;
                                    background: transparent;

                                    Image {
                                        width: 14px;
                                        height: 14px;
                                        x: 0px;
                                        y: (parent.height - self.height) / 2;
                                        source: @image-url("../../assets/icons/ui/search.svg");
                                        image-fit: contain;
                                        colorize: #666;
                                    }
                                }

                                hist-search-input := TextInput {
                                    font-size: 12px;
                                    color: Theme.text-primary;
                                    horizontal-stretch: 1;
                                    single-line: true;
                                    vertical-alignment: center;
                                    text <=> root.history-search;
                                }
                            }
                        }
                    }
                }

                // Separator
                Rectangle { height: 1px; background: Theme.border-color; }

                // Conversation list
                ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;

                        for conv in root.past-conversations: Rectangle {
                            height: 64px;
                            border-radius: 6px;
                            background: conv-touch.has-hover ? #2a2a3a : #1e1e2a;

                            conv-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.on-load-conversation(conv.session-id);
                                    root.show-history-modal = false;
                                }
                            }

                            VerticalLayout {
                                padding: 10px;
                                padding-left: 14px;
                                padding-right: 14px;
                                spacing: 4px;

                                // Title row: name + date
                                HorizontalLayout {
                                    spacing: 8px;

                                    Text {
                                        text: conv.product-name != "" ? conv.product-name : "New Conversation";
                                        color: Theme.text-primary;
                                        font-size: 12px;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: conv.last-active;
                                        color: Theme.text-secondary;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }
                                }

                                // Preview + metadata
                                HorizontalLayout {
                                    spacing: 8px;

                                    Text {
                                        text: conv.preview;
                                        color: Theme.text-secondary;
                                        font-size: 11px;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }

                                    Text {
                                        text: conv.message-count + " msgs";
                                        color: #666;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }

                                    if conv.cost != "$0.00": Text {
                                        text: conv.cost;
                                        color: #666;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        if root.past-conversations.length == 0: Rectangle {
                            height: 60px;

                            Text {
                                text: "No past conversations";
                                color: Theme.text-secondary;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}
