// ============================================================================
// Eustress Engine Studio - Workshop Panel
// Conversational ideation interface for product creation (System 0)
//
// Table of Contents:
//   1. Data Structures — ChatMessage, MCP command card, pipeline step
//   2. ChatBubble — message display (user, system, MCP command, approval gate)
//   3. MCPCommandCard — inline MCP endpoint display with approve/edit/skip
//   4. PipelineStep — compact step status indicator
//   5. WorkshopPanel — main panel with chat scroll, input, pipeline sidebar
// ============================================================================

import { VerticalBox, HorizontalBox, ScrollView, Button, LineEdit, TextEdit } from "std-widgets.slint";
import { Theme, PanelHeader } from "theme.slint";
import { MentionPopup, MentionItemData } from "mention_popup.slint";

export { MentionItemData }

// ============================================================================
// 1. Data Structures
// ============================================================================

// A single message in the ideation conversation
export struct ChatMessage {
    id: int,
    role: string,           // "user" | "system" | "mcp" | "approval" | "artifact" | "error"
    content: string,        // Message text (markdown-ish)
    timestamp: string,      // Display timestamp
    mcp-endpoint: string,   // For role="mcp": the MCP endpoint being called
    mcp-method: string,     // For role="mcp": GET/POST
    mcp-status: string,     // For role="mcp": "pending" | "approved" | "running" | "done" | "skipped" | "error"
    artifact-path: string,  // For role="artifact": file path of generated artifact
    artifact-type: string,  // For role="artifact": "patent" | "sota" | "requirements" | "mesh" | "toml" | "readme" | "catalog"
}

// Past conversation summary for history browser
export struct ConversationSummary {
    session-id: string,
    product-name: string,     // e.g. "V-Cell 4680" or "Untitled"
    state: string,            // "idle" | "running" | "complete" etc.
    message-count: int,
    cost: string,             // formatted: "$1.23"
    last-active: string,      // formatted date: "Apr 11, 2026"
    preview: string,          // first user message (truncated)
}

// Pipeline step status for the compact sidebar
export struct PipelineStepData {
    index: int,
    label: string,
    status: string,         // "waiting" | "active" | "done" | "error" | "skipped"
    artifact-count: int,    // Number of files generated in this step
}

// ============================================================================
// 2. ChatBubble — renders a single conversation message
// ============================================================================

component ChatBubble inherits Rectangle {
    in property <string> role: "system";
    in property <string> content: "";
    in property <string> timestamp: "";
    in property <string> mcp-endpoint: "";
    in property <string> mcp-method: "";
    in property <string> mcp-status: "pending";
    in property <string> artifact-path: "";
    in property <string> artifact-type: "";

    callback approve-mcp(int);
    callback skip-mcp(int);
    callback edit-mcp(int);
    callback open-artifact(string);

    in property <int> message-id: 0;

    // User messages align right, everything else left
    height: bubble.preferred-height + 8px;

    HorizontalLayout {
        padding-left: root.role == "user" ? 40px : 8px;
        padding-right: root.role == "user" ? 8px : 40px;
        padding-top: 4px;
        padding-bottom: 4px;

        bubble := Rectangle {
            background: root.role == "user" ? #1a5276 :
                        root.role == "mcp" ? #2c2c3e :
                        root.role == "approval" ? #3e2c1a :
                        root.role == "artifact" ? #1a3e2c :
                        root.role == "error" ? #4a2020 :
                        Theme.background-tertiary;
            border-radius: 8px;
            border-width: root.role == "mcp" ? 1px : 0px;
            border-color: root.role == "mcp" ? #4a4a6a : transparent;

            VerticalLayout {
                padding: 10px;
                spacing: 6px;

                // Role label (not for user messages)
                if root.role != "user": Text {
                    text: root.role == "system" ? "Workshop" :
                          root.role == "mcp" ? "MCP Command" :
                          root.role == "approval" ? "Approval Required" :
                          root.role == "artifact" ? "Artifact Generated" :
                          "Error";
                    color: root.role == "mcp" ? #8888cc :
                           root.role == "approval" ? #cc8844 :
                           root.role == "artifact" ? #44cc88 :
                           root.role == "error" ? #cc4444 :
                           Theme.accent-blue;
                    font-size: 10px;
                    font-weight: 600;
                }

                // MCP endpoint badge (for MCP commands)
                if root.role == "mcp": Rectangle {
                    height: 28px;
                    background: #1a1a2e;
                    border-radius: 4px;

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 6px;

                        // Method badge
                        Rectangle {
                            width: 40px;
                            height: 20px;
                            background: root.mcp-method == "POST" ? #2d5a27 : #27455a;
                            border-radius: 3px;

                            Text {
                                text: root.mcp-method;
                                color: white;
                                font-size: 9px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Endpoint path
                        Text {
                            text: root.mcp-endpoint;
                            color: #aaaadd;
                            font-size: 11px;
                            font-family: "Consolas";
                            vertical-alignment: center;
                        }
                    }
                }

                // Message content
                Text {
                    text: root.content;
                    color: root.role == "error" ? #ff8888 : Theme.text-primary;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                // Artifact file path (clickable)
                if root.role == "artifact": Rectangle {
                    height: 24px;
                    background: #0a2a1a;
                    border-radius: 4px;

                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.open-artifact(root.artifact-path); }
                    }

                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 4px;

                        Image {
                            width: 12px;
                            height: 12px;
                            source: @image-url("../../assets/icons/ui/new-file.svg");
                            image-fit: contain;
                            colorize: #44cc88;
                            vertical-alignment: center;
                        }

                        Text {
                            text: root.artifact-path;
                            color: #44cc88;
                            font-size: 11px;
                            font-family: "Consolas";
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }

                // Approval buttons (for MCP commands pending approval)
                if root.role == "mcp" && root.mcp-status == "pending": HorizontalLayout {
                    spacing: 6px;
                    padding-top: 4px;

                    // Approve button
                    Rectangle {
                        width: 70px;
                        height: 26px;
                        background: approve-touch.has-hover ? #2d7d46 : #245a36;
                        border-radius: 4px;

                        approve-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.approve-mcp(root.message-id); }
                        }

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 4px;

                            Image {
                                width: 12px;
                                height: 12px;
                                source: @image-url("../../assets/icons/ui/check.svg");
                                image-fit: contain;
                                colorize: white;
                                vertical-alignment: center;
                            }

                            Text {
                                text: "Run";
                                color: white;
                                font-size: 11px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Edit button (lets user modify before running)
                    Rectangle {
                        width: 60px;
                        height: 26px;
                        background: edit-touch.has-hover ? #5a5a2d : #3e3e20;
                        border-radius: 4px;

                        edit-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.edit-mcp(root.message-id); }
                        }

                        Text {
                            text: "Edit";
                            color: #cccc88;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // Skip button
                    Rectangle {
                        width: 60px;
                        height: 26px;
                        background: skip-touch.has-hover ? #5a2d2d : #3e2020;
                        border-radius: 4px;

                        skip-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.skip-mcp(root.message-id); }
                        }

                        Text {
                            text: "Skip";
                            color: #cc8888;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // MCP status indicator (after approval)
                if root.role == "mcp" && root.mcp-status != "pending": HorizontalLayout {
                    spacing: 4px;
                    padding-top: 2px;

                    VerticalLayout {
                        alignment: center;
                        width: 8px;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: root.mcp-status == "running" ? Theme.accent-blue :
                                        root.mcp-status == "done" ? Theme.accent-green :
                                        root.mcp-status == "skipped" ? Theme.text-secondary :
                                        root.mcp-status == "error" ? Theme.accent-red :
                                        Theme.accent-blue;
                        }
                    }

                    Text {
                        text: root.mcp-status == "running" ? "Running..." :
                              root.mcp-status == "done" ? "Complete" :
                              root.mcp-status == "skipped" ? "Skipped" :
                              root.mcp-status == "approved" ? "Queued" :
                              root.mcp-status == "error" ? "Failed" : "";
                        color: Theme.text-secondary;
                        font-size: 10px;
                        vertical-alignment: center;
                    }
                }

                // Timestamp
                Text {
                    text: root.timestamp;
                    color: Theme.text-disabled;
                    font-size: 9px;
                    horizontal-alignment: root.role == "user" ? right : left;
                }
            }
        }
    }
}

// ============================================================================
// 3. PipelineStep — compact step indicator in sidebar
// ============================================================================

component PipelineStep inherits Rectangle {
    in property <int> index: 0;
    in property <string> label: "";
    in property <string> status: "waiting";
    in property <int> artifact-count: 0;

    height: 28px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;

        // Status dot
        VerticalLayout {
            alignment: center;
            width: 10px;
            Rectangle {
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: root.status == "done" ? Theme.accent-green :
                            root.status == "active" ? Theme.accent-blue :
                            root.status == "error" ? Theme.accent-red :
                            root.status == "skipped" ? Theme.text-disabled :
                            #333344;
            }
        }

        // Step label
        Text {
            horizontal-stretch: 1;
            text: root.label;
            color: root.status == "active" ? Theme.text-primary :
                   root.status == "done" ? Theme.text-success :
                   root.status == "error" ? Theme.text-error :
                   Theme.text-secondary;
            font-size: 11px;
            font-weight: root.status == "active" ? 600 : 400;
            vertical-alignment: center;
            overflow: elide;
        }

        // Artifact count badge
        if root.artifact-count > 0: Rectangle {
            width: 18px;
            height: 16px;
            background: #1a3e2c;
            border-radius: 8px;

            Text {
                text: root.artifact-count;
                color: #44cc88;
                font-size: 9px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

// ============================================================================
// 4. WorkshopPanel — main conversational ideation panel
// ============================================================================

export component WorkshopPanel inherits Rectangle {
    // ---- Properties ----
    in property <[ChatMessage]> messages: [];
    in-out property <string> input-text: "";
    in property <[PipelineStepData]> pipeline-steps: [];
    in property <string> pipeline-state: "idle";    // "idle" | "running" | "paused" | "complete" | "error"
    in property <string> product-name: "";
    in property <int> total-artifacts: 0;
    in property <string> estimated-cost: "$0.00";
    in property <bool> api-key-valid: false;

    // Stage 2: Active modes (AI-inferred, multiple simultaneous) + command bar
    in property <string> active-modes-text: "⚡ General";   // formatted badge text
    in-out property <string> command-text: "";
    in property <int> tool-count: 0;
    in property <string> active-tool: "";          // currently executing tool name (empty = idle)

    // Conversation history
    in property <[ConversationSummary]> past-conversations: [];
    in-out property <bool> show-history-modal: false;
    in-out property <string> history-search: "";

    // ── @ Mention autocomplete ───────────────────────────────────────────
    // Popup state driven by user typing. When the user types `@`, the host
    // (Bevy side) receives the query prefix, searches the MentionIndex,
    // and pushes results back via `mention-items`. Enter commits the
    // selected item, which replaces the `@foo` token in `input-text` with
    // the chosen entry's canonical path.
    in property <[MentionItemData]> mention-items: [];
    in-out property <bool> mention-popup-visible: false;
    in-out property <int> mention-selected-index: 0;
    /// Prefix the user has typed after `@` (no `@` char). Bevy side
    /// watches this and re-queries on change.
    in-out property <string> mention-query: "";
    /// Character position where the `@` sits in `input-text`. Needed so
    /// commit can splice the chip in exactly the right spot.
    in-out property <int> mention-at-pos: -1;

    callback on-mention-query-changed(string);  // emit when prefix changes
    callback on-mention-commit(int);            // item index committed (also fires record_usage)
    callback on-mention-cancel();               // popup dismissed without commit

    /// Scan `input-text` for a trailing `@prefix` token; if found, open
    /// the popup and emit a query. Called from the input field's `edited`
    /// hook every keystroke. Cursor position isn't directly exposed by
    /// Slint's TextInput so we scan from the end — works perfectly for
    /// the common case (user types `@` at the caret).
    function update-mention-state() {
        // Find the last `@` in input-text. If the tail from there to end
        // contains whitespace, the user already closed a previous mention;
        // don't re-open.
        // Slint has no .find() for strings — emulate via manual scan.
        // For performance: input text is typically < 1 KB, linear scan is fine.
        //
        // Algorithm:
        //   1. Walk characters from end to start.
        //   2. If we hit whitespace before an `@`, no active mention.
        //   3. If we hit `@`, extract the tail after it as the query.
        //
        // We implement this in a compact inline form.
        //
        // NOTE: Slint .character-count and string slicing are limited; we
        // rely on the host callback to do the heavy lifting by passing
        // the raw input-text. The host parses it and pushes query back
        // via `mention-query` so the UI stays reactive.
        root.on-mention-query-changed(root.input-text);
    }

    // ---- Callbacks ----
    callback on-send-message(string);               // User sends a message
    callback on-approve-mcp(int);                   // User approves an MCP command by message id
    callback on-skip-mcp(int);                      // User skips an MCP command
    callback on-edit-mcp(int);                      // User wants to edit before running
    callback on-open-artifact(string);              // User clicks an artifact path
    callback on-start-pipeline();                   // Start the ideation pipeline
    callback on-pause-pipeline();                   // Pause to let user review
    callback on-resume-pipeline();                  // Resume after pause/edit
    callback on-cancel-pipeline();                  // Cancel the whole thing
    callback on-configure-api();                    // Open Soul Settings for API key
    callback on-optimize-and-build();               // Hand off to Systems 1-8
    callback on-execute-command(string);             // Command bar executed (Rune, /run workflow, etc.)
    callback on-load-conversation(string);           // Load a past conversation by session ID
    callback on-new-conversation();                  // Start a new conversation

    background: Theme.panel-background;

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // Header with conversation history button
        Rectangle {
            height: 28px;
            background: Theme.header-background;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 4px;
                spacing: 4px;

                Text {
                    text: "Workshop";
                    color: Theme.text-primary;
                    font-size: 12px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                // New conversation button
                Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 3px;
                    background: new-conv-touch.has-hover ? Theme.button-hover : transparent;
                    y: (parent.height - self.height) / 2;

                    new-conv-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-new-conversation(); }
                    }

                    Text {
                        text: "+";
                        color: Theme.text-secondary;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // History button
                Rectangle {
                    width: 22px;
                    height: 22px;
                    border-radius: 3px;
                    background: hist-touch.has-hover ? Theme.button-hover : transparent;
                    y: (parent.height - self.height) / 2;

                    hist-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.show-history-modal = true; }
                    }

                    Image {
                        width: 14px;
                        height: 14px;
                        source: @image-url("../../assets/icons/ui/history.svg");
                        image-fit: contain;
                        colorize: Theme.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // API key warning (if not configured)
        if !root.api-key-valid: Rectangle {
            height: 56px;
            background: #3e3e20;

            VerticalLayout {
                padding: 8px;
                spacing: 4px;
                alignment: center;

                HorizontalLayout {
                    spacing: 4px;
                    alignment: center;

                    Image {
                        width: 14px;
                        height: 14px;
                        source: @image-url("../../assets/icons/ui/info.svg");
                        image-fit: contain;
                        vertical-alignment: center;
                    }

                    Text {
                        text: "Soul Service API key required";
                        color: Theme.text-primary;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                HorizontalLayout {
                    alignment: center;

                    Rectangle {
                        width: 70px;
                        height: 22px;
                        background: Theme.button-background;
                        border-radius: 4px;

                        TouchArea {
                            clicked => { root.on-configure-api(); }
                        }

                        Text {
                            text: "Configure";
                            color: Theme.text-primary;
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // Pipeline status bar (compact, always visible when running)
        if root.pipeline-state != "idle": Rectangle {
            height: 32px;
            background: root.pipeline-state == "complete" ? #1a3e2c :
                        root.pipeline-state == "error" ? #4a2020 :
                        root.pipeline-state == "paused" ? #3e3e20 :
                        #1a1a3e;

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                spacing: 8px;

                // Status dot
                VerticalLayout {
                    alignment: center;
                    width: 8px;
                    Rectangle {
                        width: 8px;
                        height: 8px;
                        border-radius: 4px;
                        background: root.pipeline-state == "running" ? Theme.accent-blue :
                                    root.pipeline-state == "complete" ? Theme.accent-green :
                                    root.pipeline-state == "paused" ? #cccc44 :
                                    Theme.accent-red;
                    }
                }

                Text {
                    horizontal-stretch: 1;
                    text: root.pipeline-state == "running" ? "Creating " + root.product-name + "..." :
                          root.pipeline-state == "complete" ? root.product-name + " ready" :
                          root.pipeline-state == "paused" ? "Waiting for your input..." :
                          "Pipeline error";
                    color: Theme.text-primary;
                    font-size: 11px;
                    vertical-alignment: center;
                    overflow: elide;
                }

                // Cost estimate
                Text {
                    text: "~" + root.estimated-cost;
                    color: Theme.text-secondary;
                    font-size: 10px;
                    vertical-alignment: center;
                }

                // Artifact count
                Text {
                    text: root.total-artifacts + " files";
                    color: #44cc88;
                    font-size: 10px;
                    vertical-alignment: center;
                }
            }
        }

        // Pipeline step sidebar (collapsible — shown when pipeline is active)
        if root.pipeline-state != "idle" && root.pipeline-steps.length > 0: Rectangle {
            min-height: root.pipeline-steps.length * 28px + 8px;
            max-height: 200px;
            background: Theme.background-secondary;

            ScrollView {
                VerticalLayout {
                    padding: 4px;
                    spacing: 0px;

                    for step in root.pipeline-steps: PipelineStep {
                        index: step.index;
                        label: step.label;
                        status: step.status;
                        artifact-count: step.artifact-count;
                    }
                }
            }
        }

        // Chat messages area
        if root.messages.length == 0: Rectangle {
            vertical-stretch: 1;
            background: Theme.panel-background;

            VerticalLayout {
                alignment: center;
                spacing: 8px;

                HorizontalLayout {
                    alignment: center;
                    height: 40px;

                    Image {
                        width: 40px;
                        height: 40px;
                        source: @image-url("../../assets/icons/ui/sparkle.svg");
                        image-fit: contain;
                        opacity: 0.5;
                    }
                }

                Text {
                    text: "Workshop";
                    color: Theme.text-primary;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Describe your product idea.\nThe system will guide you through\npatent, validation, meshes, and TOML\ngeneration — step by step.";
                    color: Theme.text-secondary;
                    font-size: 11px;
                    horizontal-alignment: center;
                }

                // Quick start examples
                Rectangle {
                    height: 80px;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;

                        Text {
                            text: "Try:";
                            color: Theme.text-disabled;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }

                        // Example 1
                        Rectangle {
                            height: 24px;
                            background: example1-touch.has-hover ? #ffffff08 : transparent;
                            border-radius: 4px;

                            example1-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.on-send-message("Solid-state sodium-sulfur battery, 15k cycle life, 900 Wh/kg");
                                }
                            }

                            Text {
                                text: "\"Solid-state sodium-sulfur battery, 15k cycle life\"";
                                color: Theme.accent-blue;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Example 2
                        Rectangle {
                            height: 24px;
                            background: example2-touch.has-hover ? #ffffff08 : transparent;
                            border-radius: 4px;

                            example2-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.on-send-message("Gravity drive using Element 115 stable island isotope");
                                }
                            }

                            Text {
                                text: "\"Gravity drive using Element 115 stable island isotope\"";
                                color: Theme.accent-blue;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        if root.messages.length > 0: ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding: 4px;
                spacing: 0px;

                for msg in root.messages: ChatBubble {
                    role: msg.role;
                    content: msg.content;
                    timestamp: msg.timestamp;
                    mcp-endpoint: msg.mcp-endpoint;
                    mcp-method: msg.mcp-method;
                    mcp-status: msg.mcp-status;
                    artifact-path: msg.artifact-path;
                    artifact-type: msg.artifact-type;
                    message-id: msg.id;

                    approve-mcp(id) => { root.on-approve-mcp(id); }
                    skip-mcp(id) => { root.on-skip-mcp(id); }
                    edit-mcp(id) => { root.on-edit-mcp(id); }
                    open-artifact(path) => { root.on-open-artifact(path); }
                }
            }
        }

        // "Optimize & Build" handoff button (shown when ideation is complete)
        if root.pipeline-state == "complete": Rectangle {
            height: 44px;
            background: #1a3e2c;

            HorizontalLayout {
                padding: 8px;
                spacing: 8px;

                Rectangle {
                    horizontal-stretch: 1;
                    height: 28px;
                    background: optimize-touch.has-hover ? #2d7d46 : #245a36;
                    border-radius: 4px;

                    optimize-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.on-optimize-and-build(); }
                    }

                    HorizontalLayout {
                        alignment: center;
                        spacing: 6px;

                        Image {
                            width: 14px;
                            height: 14px;
                            source: @image-url("../../assets/icons/ui/play.svg");
                            image-fit: contain;
                            colorize: white;
                            vertical-alignment: center;
                        }

                        Text {
                            text: "Optimize & Build (Systems 1-8)";
                            color: white;
                            font-size: 12px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        // Input area (always visible, dynamic height)
        Rectangle {
            min-height: 80px;
            background: Theme.background-secondary;

            // Top separator
            Rectangle {
                y: 0px;
                height: 1px;
                background: Theme.border-color;
            }

            VerticalLayout {
                padding: 8px;
                spacing: 6px;

                // ── Mode bar + tool count — vertically centered row ──
                HorizontalLayout {
                    height: 20px;
                    spacing: 6px;
                    alignment: start;

                    Text {
                        text: root.active-modes-text;
                        color: Theme.text-secondary;
                        font-size: 10px;
                        vertical-alignment: center;
                        overflow: elide;
                        horizontal-stretch: 1;
                    }

                    if root.active-tool != "": Text {
                        text: "⟳ " + root.active-tool;
                        color: #4caf50;
                        font-size: 9px;
                        vertical-alignment: center;
                    }

                    if root.active-tool == "" && root.tool-count > 0: Text {
                        text: root.tool-count + " tools";
                        color: Theme.text-secondary;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                }

                // ── Chat input (multi-line, dynamic height) ──
                HorizontalLayout {
                    spacing: 6px;

                    Rectangle {
                        horizontal-stretch: 1;
                        min-height: 40px;
                        background: Theme.background-tertiary;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: input-area.has-focus ? Theme.accent-blue : Theme.border-color;

                        input-area := TextInput {
                            x: 10px;
                            y: 8px;
                            width: parent.width - 20px;
                            height: parent.height - 16px;
                            color: Theme.text-primary;
                            font-size: 12px;
                            text <=> root.input-text;
                            single-line: false;
                            wrap: word-wrap;

                            accepted => {
                                // If the popup is open, Enter commits the
                                // highlighted mention instead of sending.
                                if root.mention-popup-visible && root.mention-items.length > 0 {
                                    root.on-mention-commit(root.mention-selected-index);
                                    return;
                                }
                                if root.input-text != "" {
                                    root.on-send-message(root.input-text);
                                    root.input-text = "";
                                }
                            }

                            // Live-edit hook — every keystroke scans back
                            // from the cursor for the most recent `@`. If
                            // one is found within 32 chars and not
                            // followed by whitespace, the popup opens with
                            // the prefix query.
                            edited => {
                                // Slint doesn't expose cursor-position here;
                                // we approximate by scanning from the end
                                // of input-text for the last `@` not
                                // preceded by alphanumerics.
                                // Simple heuristic: split on whitespace,
                                // examine the final token.
                                // Future refinement: expose cursor position
                                // via a custom property.
                                root.update-mention-state();
                            }

                            key-pressed(ev) => {
                                // Intercept nav keys only when popup is open.
                                if root.mention-popup-visible {
                                    if ev.text == Key.UpArrow {
                                        if root.mention-selected-index > 0 {
                                            root.mention-selected-index -= 1;
                                        }
                                        return accept;
                                    }
                                    if ev.text == Key.DownArrow {
                                        if root.mention-selected-index < root.mention-items.length - 1 {
                                            root.mention-selected-index += 1;
                                        }
                                        return accept;
                                    }
                                    if ev.text == Key.Escape {
                                        root.mention-popup-visible = false;
                                        root.on-mention-cancel();
                                        return accept;
                                    }
                                    if ev.text == Key.Tab {
                                        if root.mention-items.length > 0 {
                                            root.on-mention-commit(root.mention-selected-index);
                                        }
                                        return accept;
                                    }
                                }
                                return reject;
                            }
                        }
                    }

                    // Send button (arrow-up icon)
                    Rectangle {
                        width: 36px;
                        height: 36px;
                        y: parent.height - self.height;
                        background: root.input-text != "" ? (send-touch.has-hover ? #2d7d46 : Theme.button-primary) : Theme.button-background;
                        border-radius: 8px;

                        send-touch := TouchArea {
                            mouse-cursor: root.input-text != "" ? pointer : default;
                            enabled: root.input-text != "";
                            clicked => {
                                root.on-send-message(root.input-text);
                                root.input-text = "";
                            }
                        }

                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("../../assets/icons/ui/send.svg");
                            image-fit: contain;
                            colorize: root.input-text != "" ? white : Theme.text-disabled;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ── @ Mention Popup overlay ──────────────────────────────────────────
    // Floats above the input area. Anchored bottom-right of the chat so
    // it opens upward from the input. Host (Bevy) toggles visibility via
    // `mention-popup-visible` in response to the user typing `@`.
    if root.mention-popup-visible: Rectangle {
        // Position: centered on the chat, aligned with the input. Sits
        // just above the input area (~70px offset) so it doesn't obscure
        // what the user is typing.
        x: (parent.width - 360px) / 2;
        y: parent.height - 120px - self.height;
        width: 360px;
        height: root.mention-items.length > 0
            ? min(28px + root.mention-items.length * 42px, 360px)
            : 60px;

        MentionPopup {
            items: root.mention-items;
            selected-index: root.mention-selected-index;
            show-recent-header: root.mention-query == "";
            on-select(i) => { root.on-mention-commit(i); }
        }
    }

    // ── Conversation History Modal ──
    if root.show-history-modal: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000060;

        TouchArea {
            clicked => { root.show-history-modal = false; }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(parent.width - 40px, 500px);
            height: min(parent.height - 60px, 450px);
            background: Theme.panel-background;
            border-radius: 10px;
            border-width: 1px;
            border-color: Theme.border-color;
            drop-shadow-blur: 20px;
            drop-shadow-color: #00000080;

            // Absorb clicks on the modal itself
            TouchArea {
                scroll-event(event) => { return accept; }
            }

            VerticalLayout {
                padding: 0px;
                spacing: 0px;

                // Modal header
                Rectangle {
                    height: 44px;
                    background: Theme.header-background;
                    border-top-left-radius: 10px;
                    border-top-right-radius: 10px;

                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 8px;

                        Text {
                            text: "Conversations";
                            color: Theme.text-primary;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        // Close button
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 4px;
                            background: hist-close-touch.has-hover ? #3a3a3a : transparent;
                            y: (parent.height - self.height) / 2;

                            hist-close-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.show-history-modal = false; }
                            }

                            Image {
                                width: 12px;
                                height: 12px;
                                source: @image-url("../../assets/icons/ui/close.svg");
                                image-fit: contain;
                                colorize: Theme.text-secondary;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Search bar
                Rectangle {
                    height: 36px;
                    background: Theme.header-background;

                    HorizontalLayout {
                        padding: 6px;
                        padding-left: 16px;
                        padding-right: 16px;

                        Rectangle {
                            horizontal-stretch: 1;
                            border-radius: 6px;
                            background: #1a1a1a;
                            border-width: 1px;
                            border-color: #3a3a3a;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 6px;
                                alignment: center;

                                Image {
                                    width: 14px;
                                    height: 14px;
                                    source: @image-url("../../assets/icons/ui/search.svg");
                                    image-fit: contain;
                                    colorize: #666;
                                    vertical-alignment: center;
                                }

                                hist-search-input := TextInput {
                                    font-size: 12px;
                                    color: Theme.text-primary;
                                    horizontal-stretch: 1;
                                    single-line: true;
                                    vertical-alignment: center;
                                    text <=> root.history-search;
                                }
                            }
                        }
                    }
                }

                // Separator
                Rectangle { height: 1px; background: Theme.border-color; }

                // Conversation list
                ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;

                        for conv in root.past-conversations: Rectangle {
                            height: 64px;
                            border-radius: 6px;
                            background: conv-touch.has-hover ? #2a2a3a : #1e1e2a;

                            conv-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.on-load-conversation(conv.session-id);
                                    root.show-history-modal = false;
                                }
                            }

                            VerticalLayout {
                                padding: 10px;
                                padding-left: 14px;
                                padding-right: 14px;
                                spacing: 4px;

                                // Title row: name + date
                                HorizontalLayout {
                                    spacing: 8px;

                                    Text {
                                        text: conv.product-name != "" ? conv.product-name : "New Conversation";
                                        color: Theme.text-primary;
                                        font-size: 12px;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }

                                    Text {
                                        text: conv.last-active;
                                        color: Theme.text-secondary;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }
                                }

                                // Preview + metadata
                                HorizontalLayout {
                                    spacing: 8px;

                                    Text {
                                        text: conv.preview;
                                        color: Theme.text-secondary;
                                        font-size: 11px;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }

                                    Text {
                                        text: conv.message-count + " msgs";
                                        color: #666;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }

                                    if conv.cost != "$0.00": Text {
                                        text: conv.cost;
                                        color: #666;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        if root.past-conversations.length == 0: Rectangle {
                            height: 60px;

                            Text {
                                text: "No past conversations";
                                color: Theme.text-secondary;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}
