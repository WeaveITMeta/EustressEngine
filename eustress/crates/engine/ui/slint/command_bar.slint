// ============================================================================
// Eustress Engine Studio - Command Bar
// Docked at the bottom of the engine window for executing Rune/Luau scripts.
// Resizable by dragging the top edge.
// ============================================================================

import { VerticalBox, HorizontalBox, LineEdit, ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";

export struct CommandSuggestion {
    id: string,
    label: string,
    description: string,
    shortcut: string,
    category: string,
}

export struct ScriptOutputEntry {
    text: string,
    is-error: bool,
    timestamp: string,
}

export component CommandBar inherits Rectangle {
    in-out property <string> command-text: "";
    in-out property <string> language: "rune";
    in property <[CommandSuggestion]> suggestions: [];
    in property <int> selected-index: 0;
    in property <[string]> history: [];
    in-out property <length> bar-height: 28px;

    out property <bool> input-has-focus: input.has-focus;

    callback on-execute(/* language */ string, /* script */ string);
    callback on-close();
    callback on-text-changed(string);
    callback on-select-suggestion(int);
    callback on-clear-output();

    width: 100%;
    height: root.bar-height;
    background: Theme.header-background;
    border-width: 1px;
    border-color: Theme.border-color;

    // Resize handle at top edge — drag to resize
    Rectangle {
        y: 0px;
        width: 100%;
        height: 4px;
        background: resize-touch.has-hover ? Theme.accent-blue : transparent;

        resize-touch := TouchArea {
            mouse-cursor: ns-resize;
            moved => {
                root.bar-height = max(28px, min(400px, root.bar-height - (self.mouse-y - self.pressed-y)));
            }
        }
    }

    VerticalLayout {
        padding-top: 4px;

        // Input bar at top
        Rectangle {
            height: 28px;

            HorizontalLayout {
                padding-left: 4px;
                padding-right: 4px;
                padding-top: 3px;
                padding-bottom: 3px;
                spacing: 4px;

                // Language selector
                Rectangle {
                    width: 48px;
                    height: 22px;
                    background: lang-touch.has-hover ? Theme.button-hover : Theme.input-background;
                    border-radius: 3px;
                    border-width: 1px;
                    border-color: Theme.input-border;

                    lang-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.language = root.language == "luau" ? "rune" : "luau";
                        }
                    }

                    Text {
                        width: 100%;
                        height: 100%;
                        text: root.language == "luau" ? "Luau" : "Rune";
                        color: root.language == "luau" ? #4fc3f7 : #ffb74d;
                        font-size: 11px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Prompt
                Text {
                    width: 14px;
                    text: ">";
                    color: root.language == "luau" ? #4fc3f7 : #ffb74d;
                    font-size: 14px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }

                // Input field
                Rectangle {
                    horizontal-stretch: 1;
                    height: 22px;
                    background: input.has-focus ? Theme.input-background : transparent;
                    border-radius: 3px;
                    border-width: input.has-focus ? 1px : 0px;
                    border-color: Theme.accent-blue;

                    TouchArea {
                        clicked => { input.focus(); }
                    }

                    input := TextInput {
                        x: 6px;
                        width: parent.width - 12px;
                        height: 100%;
                        text <=> root.command-text;
                        color: Theme.text-primary;
                        font-size: 12px;
                        single-line: true;
                        vertical-alignment: center;

                        edited => { root.on-text-changed(self.text); }

                        accepted => {
                            if self.text != "" {
                                root.on-execute(root.language, self.text);
                                self.text = "";
                            }
                        }
                    }
                }

                // Run button
                Rectangle {
                    width: 22px;
                    height: 22px;
                    background: run-touch.has-hover ? Theme.button-hover : Theme.input-background;
                    border-radius: 3px;
                    border-width: 1px;
                    border-color: Theme.input-border;

                    run-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            if root.command-text != "" {
                                root.on-execute(root.language, root.command-text);
                                root.command-text = "";
                            }
                        }
                    }

                    Text {
                        text: "▶";
                        color: #8bc34a;
                        font-size: 11px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Separator (only when expanded)
        if root.bar-height > 32px: Rectangle {
            height: 1px;
            background: Theme.border-color;
        }

        // Output log — fills remaining space when expanded
        if root.bar-height > 32px: Rectangle {
            vertical-stretch: 1;
            background: #0d0d12;

            ScrollView {
                VerticalLayout {
                    padding: 4px;
                    spacing: 1px;

                    for entry in root.output-log: Text {
                        text: entry.text;
                        color: entry.is-error ? #ef5350 : #8bc34a;
                        font-size: 11px;
                        font-family: "Cascadia Code";
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
