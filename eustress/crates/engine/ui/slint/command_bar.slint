// ============================================================================
// Eustress Engine Studio - Command Bar
// Docked at the bottom of the engine window for executing Rune/Luau scripts.
// Output goes to the existing Output panel, not rendered here.
// ============================================================================

import { HorizontalBox, LineEdit } from "std-widgets.slint";
import { Theme } from "theme.slint";

export struct CommandSuggestion {
    id: string,
    label: string,
    description: string,
    shortcut: string,
    category: string,
}

export struct ScriptOutputEntry {
    text: string,
    is-error: bool,
    timestamp: string,
}

export component CommandBar inherits Rectangle {
    in-out property <string> command-text: "";
    in-out property <string> language: "rune";

    out property <bool> input-has-focus: input.has-focus;

    callback on-execute(/* language */ string, /* script */ string);
    callback on-close();
    callback on-text-changed(string);
    callback on-select-suggestion(int);
    callback on-clear-output();

    width: 100%;
    height: 28px;
    background: Theme.header-background;
    border-width: 1px;
    border-color: Theme.border-color;

    HorizontalLayout {
        padding-left: 4px;
        padding-right: 4px;
        padding-top: 3px;
        padding-bottom: 3px;
        spacing: 4px;

        // Language selector
        Rectangle {
            width: 48px;
            height: 22px;
            background: lang-touch.has-hover ? Theme.button-hover : Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: Theme.input-border;

            lang-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    root.language = root.language == "luau" ? "rune" : "luau";
                }
            }

            Text {
                width: 100%;
                height: 100%;
                text: root.language == "luau" ? "Luau" : "Rune";
                color: root.language == "luau" ? #4fc3f7 : #ffb74d;
                font-size: 11px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        // Prompt
        Text {
            width: 14px;
            text: ">";
            color: root.language == "luau" ? #4fc3f7 : #ffb74d;
            font-size: 14px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-alignment: center;
        }

        // Input field
        input := LineEdit {
            horizontal-stretch: 1;
            placeholder-text: "";
            text <=> root.command-text;

            edited(text) => { root.on-text-changed(text); }

            accepted(text) => {
                if text != "" {
                    root.on-execute(root.language, text);
                    root.command-text = "";
                }
            }
        }

        // Run button
        Rectangle {
            width: 22px;
            height: 22px;
            background: run-touch.has-hover ? Theme.button-hover : Theme.input-background;
            border-radius: 3px;
            border-width: 1px;
            border-color: Theme.input-border;

            run-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => {
                    if root.command-text != "" {
                        root.on-execute(root.language, root.command-text);
                        root.command-text = "";
                    }
                }
            }

            Image {
                width: 12px;
                height: 12px;
                source: @image-url("../../assets/icons/ui/play.svg");
                image-fit: contain;
                colorize: #8bc34a;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
        }
    }
}
