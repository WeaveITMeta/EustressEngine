// ============================================================================
// Eustress Engine Studio - Main UI Layout
// Slint 1.12 declarative UI replacing egui immediate-mode
// ============================================================================

import { VerticalBox, HorizontalBox, TabWidget, Button, ComboBox, LineEdit, ScrollView, StandardListView, CheckBox, Slider, GridBox, GroupBox, SpinBox, TextEdit } from "std-widgets.slint";
import { Ribbon, SavedIdentityData } from "ribbon.slint";
import { ExplorerPanel, TreeNode } from "explorer.slint";
import { PropertiesPanel, PropertyData } from "properties.slint";
import { OutputConsole, LogData } from "output.slint";
import { CommandBar, ScriptOutputEntry } from "command_bar.slint";
import { Toolbox } from "toolbox.slint";
import { AssetManager, AssetNode } from "asset_manager.slint";
import { Collaboration } from "collaboration.slint";
import { SoulPanel, SoulScriptData } from "soul_panel.slint";
import { ScriptEditor, ScriptTab, CenterTab, HighlightLine, TokenSpan, DiagnosticSpan } from "script_editor.slint";
import { ProblemsPanel, ProblemItem } from "problems_panel.slint";
import { WebBrowser } from "web_browser.slint";
import { Notifications, NotificationData } from "notifications.slint";
import { ViewSelector } from "view_selector.slint";
import { AIGeneration } from "ai_generation.slint";
import { PublishDialog } from "publish.slint";
import { LoginDialog } from "login.slint";
import { HistoryPanel, HistoryEntry } from "history_panel.slint";
import { PublishTreeNode } from "publish.slint";
import { ContextMenu, MenuItem } from "context_menu.slint";
import { Theme } from "theme.slint";
// Dock layout system
import { LayoutPresetSelector, LayoutDropdownMenu, AdvancedTabBar, PerformanceOverlay, DockZoneIndicator, ThemeEditor, LayoutPreset, DockTab, DockZone } from "dock_layout.slint";
// New components for complete egui parity
import { TerrainEditor } from "terrain_editor.slint";
import { SettingsDialog } from "settings.slint";
import { NetworkPanel } from "network_panel.slint";
import { FindDialog } from "find_dialog.slint";
import { ServiceProperties } from "service_properties.slint";
// Modal dialogs
import { SimulationSettingsDialog, WatchpointData, SimOutputBinding } from "simulation_settings.slint";
import { ForgeConnectDialog } from "forge_connect.slint";
import { StressTestDialog } from "stress_test.slint";
import { DataSourcesDialog } from "data_sources.slint";
import { KeybindingsDialog } from "keybindings.slint";
import { AboutDialog } from "about_dialog.slint";
// BillboardCard is instantiated per-entity by the engine's billboard_gui
// systems, not nested inside StudioWindow. Re-export the combined form so
// slint-build emits the generated Rust bindings into the module that
// `include_modules!()` pulls in — a plain `import` alone won't surface
// the types in the generated Rust.
export { BillboardCard, BillboardLabelData } from "billboard_card.slint";
import { ExitConfirmationDialog } from "exit_confirmation.slint";
import { SyncDomainDialog } from "sync_domain.slint";
import { WorkshopPanel, ChatMessage, PipelineStepData, ConversationSummary, MentionItemData } from "workshop_panel.slint";
import { ApiReferencePanel, ApiEntryData } from "api_reference_panel.slint";
import { UniverseBrowser, UniverseItem, SpaceItem } from "universe_browser.slint";

// ============================================================================
// ScreenGui Element Data — pushed from Rust, rendered by Slint
// ============================================================================

export struct GuiElementData {
    // Layout
    x: float,
    y: float,
    width: float,
    height: float,
    z-order: int,
    visible: bool,
    clip-children: bool,
    // Scroll (ScrollingFrame)
    scroll-x: float,
    scroll-y: float,
    // Appearance
    bg-r: float,
    bg-g: float,
    bg-b: float,
    bg-a: float,
    border-size: float,
    border-r: float,
    border-g: float,
    border-b: float,
    border-a: float,
    corner-radius: float,
    // Text (empty string = no text)
    text: string,
    text-r: float,
    text-g: float,
    text-b: float,
    text-a: float,
    font-size: float,
    text-align: string, // "left", "center", "right"
    // Image (empty = no image)
    image-source: image,
    has-image: bool,
    // Class type for specialized rendering
    class-type: string, // "frame", "textlabel", "textbutton", "scrollingframe", "imagelabel", etc.
}

// ============================================================================
// Main Studio Window Component
// ============================================================================

export component StudioWindow inherits Window {
    // Window properties
    // NOTE: Do NOT set width/height here — the size comes from the BevyWindowAdapter
    // via WindowEvent::Resized. Hardcoding dimensions prevents resize from working.
    preferred-width: 1600px;
    preferred-height: 900px;
    title: "Eustress Engine";
    background: transparent;  // Transparent so 3D scene shows through viewport; panels have own opaque backgrounds
    default-font-family: "Segoe UI";
    default-font-size: 13px;

    // ========================================================================
    // Global State Properties
    // ========================================================================
    
    // Theme
    in-out property <bool> dark-theme: true;
    
    // Panel visibility
    in-out property <bool> show-explorer: true;
    in-out property <bool> show-properties: true;
    in-out property <bool> show-output: true;
    in-out property <bool> show-toolbox: true;
    in-out property <bool> show-assets: false;
    in-out property <bool> show-collaboration: false;
    in-out property <bool> show-soul-panel: false;
    in-out property <bool> show-script-editor: false;
    in-out property <bool> show-history: false;
    in property <[HistoryEntry]> history-entries: [];
    in-out property <int> history-current-index: 0;
    in-out property <bool> show-ai-generation: false;
    in-out property <bool> show-workshop-panel: false;
    in-out property <bool> show-universe-browser: false;

    // Universe browser data
    in property <[UniverseItem]> universe-items: [];
    in property <string> active-space-path: "";

    // Callback: user selected a Space from the browser
    callback space-selected(string);

    // HUD visibility (toggle all Eustress Engine UI, keep Bevy UI)
    in-out property <bool> show-hud: true;
    
    // Tab context menu state
    in-out property <bool> show-tab-context-menu: false;
    in-out property <int> tab-context-menu-index: -1;
    in-out property <length> tab-context-menu-x: 0px;
    in-out property <length> tab-context-menu-y: 0px;
    
    // Command bar (docked at bottom)
    in-out property <bool> show-command-bar: true;
    in-out property <string> command-text: "";
    in-out property <string> command-language: "rune";
    in-out property <[ScriptOutputEntry]> script-output-log: [];
    
    // Dialogs
    in-out property <bool> show-publish-dialog: false;
    in-out property <string> publish-experience-name: "";
    in-out property <string> publish-description: "";
    in-out property <string> publish-genre: "All";
    in-out property <bool> publish-is-public: true;
    in-out property <bool> publish-open-source: false;
    in-out property <bool> publish-studio-editable: false;
    in-out property <string> publish-mode: "universe"; // "universe" or "space"
    in-out property <bool> publish-is-update: false;
    in property <[string]> publish-spaces: [];
    in property <[PublishTreeNode]> publish-tree-nodes: [];
    in property <string> publish-pak-size: "";
    in-out property <string> publish-target: "Cloudflare R2";
    in-out property <bool> show-login-dialog: false;
    in-out property <string> login-identity-path: "";
    in-out property <string> login-error: "";
    in-out property <string> login-status: "";
    in-out property <bool> login-loading: false;
    callback browse-identity();
    callback login-with-identity();
    in-out property <bool> show-keybindings-dialog: false;
    in-out property <bool> show-about-dialog: false;
    in-out property <string> about-version: "0.4.0";
    in-out property <string> about-commit: "";
    in-out property <string> about-build-date: "";
    in-out property <bool> show-soul-settings-dialog: false;
    in-out property <bool> show-exit-confirmation: false;
    in-out property <bool> show-settings-dialog: false;
    in-out property <int> settings-active-tab: 0;
    in-out property <bool> show-find-dialog: false;
    
    // New panels for egui parity
    in-out property <bool> show-terrain-editor: false;
    in-out property <bool> show-network-panel: false;
    in-out property <bool> show-mindspace-panel: false;
    in-out property <bool> show-global-sources-window: false;
    in-out property <bool> show-domains-window: false;
    in-out property <bool> show-global-variables-window: false;
    
    // Additional modal dialogs
    in-out property <bool> show-forge-connect-dialog: false;
    in-out property <bool> show-stress-test-dialog: false;
    // Stress test live state (pushed from Rust each frame)
    in-out property <int> stress-max-clients: 50;
    in-out property <bool> stress-running: false;
    in-out property <float> stress-progress: 0;
    in-out property <string> stress-status: "";
    in-out property <int> stress-total-messages: 0;
    in-out property <float> stress-avg-latency: 0;
    in-out property <int> stress-errors: 0;
    callback start-stress-test(int, int, int, bool, bool); // clients, rate, duration, movement, interactions
    callback stop-stress-test();
    // ScreenGui elements — pushed from Rust, rendered by Slint overlay
    in property <[GuiElementData]> gui-elements: [];

    in-out property <bool> show-sync-domain-dialog: false;
    in-out property <bool> show-simulation-settings-dialog: false;

    // Simulation settings state (mirrors SimulationSettingsDialog properties)
    in-out property <string> sim-time-scale-preset: "Realtime (1\u{00d7})";
    in-out property <string> sim-custom-time-scale: "1.0";
    in-out property <string> sim-tick-rate: "60";
    in-out property <string> sim-max-ticks-per-frame: "10";
    in-out property <bool> sim-auto-start: false;
    in-out property <bool> sim-recording-enabled: true;
    in-out property <string> sim-clock-display: "0.0s | Tick 0";
    in-out property <string> sim-output-dir: "recordings";
    in-out property <bool> sim-auto-export: true;
    in-out property <[WatchpointData]> sim-watchpoints: [];
    in-out property <[SimOutputBinding]> sim-output-bindings: [];
    
    // Camera orientation for axis gizmo (projected 2D endpoints)
    // Each axis is projected from camera view: (dx, dy) normalized to -1..1
    in-out property <float> gizmo-ax: 1.0;
    in-out property <float> gizmo-ay: 0.0;
    in-out property <float> gizmo-bx: 0.0;
    in-out property <float> gizmo-by: -1.0;
    in-out property <float> gizmo-cx: 0.5;
    in-out property <float> gizmo-cy: 0.5;

    // Workshop Panel state (System 0: Ideation conversational interface)
    in-out property <[ChatMessage]> workshop-messages: [];
    in-out property <string> workshop-input-text: "";
    in-out property <[PipelineStepData]> workshop-pipeline-steps: [];
    in-out property <string> workshop-pipeline-state: "idle";
    in-out property <string> workshop-product-name: "";
    in-out property <int> workshop-total-artifacts: 0;
    in-out property <string> workshop-estimated-cost: "$0.00";
    in-out property <bool> workshop-api-key-valid: false;
    in-out property <string> workshop-active-modes-text: "⚡ General";
    in-out property <int> workshop-tool-count: 0;
    in-out property <string> workshop-active-tool: "";

    // Session tab strip — live list of Workshop sessions under
    // SoulService/Workshop/. Host sync system refreshes this each
    // frame so newly-created sessions appear without a restart.
    in-out property <[ConversationSummary]> workshop-past-conversations: [];
    in-out property <string> workshop-active-session-id: "";

    // @ Mention autocomplete state — backed by MentionIndex in Bevy
    in-out property <[MentionItemData]> workshop-mention-items: [];
    in-out property <bool> workshop-mention-popup-visible: false;
    in-out property <int> workshop-mention-selected-index: 0;
    in-out property <string> workshop-mention-query: "";

    // Problems panel (Rune analyzer diagnostics — right-side tab 4)
    in property <[ProblemItem]> problem-items: [];
    in property <int> problem-error-count: 0;
    in property <int> problem-warning-count: 0;
    in property <bool> problems-can-fix-with-workshop: false;

    // API Reference Panel (browsable scripting API catalog — opens as center tab)
    in property <[ApiEntryData]> api-entries: [];
    in property <[string]> api-categories: [];
    in-out property <int> api-total-count: 0;
    in-out property <int> api-filtered-count: 0;
    in-out property <string> api-selected-category: "All";
    in-out property <string> api-language-filter: "All";
    callback api-search-changed(string);
    callback api-category-selected(string);
    callback api-language-filter-changed(string);
    callback api-copy-example(string);

    // Scene name for exit confirmation
    in-out property <string> scene-name: "Untitled";
    
    // Terrain state
    in-out property <bool> has-terrain: false;
    in-out property <bool> terrain-edit-mode: false;
    in-out property <string> terrain-brush: "raise";
    in-out property <float> terrain-brush-size: 10.0;
    in-out property <float> terrain-brush-strength: 0.5;
    in-out property <float> terrain-brush-falloff: 0.5;
    
    // Terrain config properties (from _terrain.toml, synced from TerrainConfig)
    in-out property <string> terrain-size: "512";
    in-out property <string> terrain-chunk-size: "64";
    in-out property <string> terrain-resolution: "256";
    in-out property <string> terrain-height-scale: "1.0";
    in-out property <string> terrain-lod-levels: "5";
    in-out property <string> terrain-chunk-count: "0";
    in-out property <string> terrain-material: "Default";
    
    // Network state
    in-out property <bool> server-running: false;
    in-out property <bool> forge-connected: false;
    in-out property <string> forge-server-url: "https://forge.eustress.dev";
    in-out property <string> forge-api-key: "";

    // Account and sync state
    in-out property <string> account-name: "Guest";
    in-out property <string> account-status: "Logged out";
    in-out property <string> sync-status: "Local-first";
    in-out property <string> session-hours: "0h 0m";
    in-out property <string> total-hours: "0h";
    in-out property <[SavedIdentityData]> saved-identities: [];
    callback switch-identity(string);
    callback remove-identity(string);

    // Update system
    in-out property <bool> update-available: false;
    in-out property <string> update-version: "";
    in-out property <string> update-status: "";
    in-out property <int> update-progress: 0;
    callback update-clicked();

    // Bliss node state
    in-out property <string> bliss-balance: "0.000000000000000000";
    in-out property <string> bliss-balance-short: "0.00";
    in-out property <string> bliss-pending: "+0.000000000000000000";
    in-out property <string> bliss-node-mode: "Light";
    in-out property <string> bliss-bonus: "1.0x";
    in-out property <bool> bliss-enabled: true;
    callback bliss-set-light();
    callback bliss-set-full();
    callback bliss-toggle-enabled();
    
    // Service selection (for service properties)
    in-out property <string> selected-service: ""; // "workspace", "lighting", "players", etc.
    
    // Context menu
    in-out property <bool> show-context-menu: false;
    in-out property <length> context-menu-x: 0px;
    in-out property <length> context-menu-y: 0px;
    in-out property <string> context-menu-node-type: ""; // "entity" or "file"
    in-out property <[MenuItem]> context-menu-items: [];
    // Soul Panel context menu — target script entity id + target-type tag
    in-out property <int> context-menu-target-id: -1;
    in-out property <string> context-menu-target-type: "";
    
    // Current tool
    in-out property <string> current-tool: "select";
    
    // Transform mode
    in-out property <string> transform-mode: "world";
    
    // Grid/Snap state (synced from Bevy EditorSettings)
    in-out property <bool> snap-enabled: true;
    in-out property <float> snap-size: 1.96;
    in-out property <bool> grid-visible: true;
    in-out property <float> grid-size: 9.81;
    
    // View mode
    in-out property <string> view-mode: "perspective";
    
    // Play mode state
    in-out property <string> play-state: "stopped"; // stopped, playing, paused
    
    // Selection info (for properties panel)
    in-out property <int> selected-count: 0;
    in-out property <string> selected-class: "";
    in-out property <image> selected-icon;    // Class icon for Properties panel header
    
    // Unsaved changes tracking
    in-out property <bool> has-unsaved-changes: false;
    
    // Output console log data (pushed from Bevy each frame)
    in-out property <[LogData]> output-logs: [];
    in-out property <string> output-all-text: "";
    in-out property <string> output-source-filter: "all";
    in-out property <bool> output-show-info: true;
    in-out property <bool> output-show-warnings: true;
    in-out property <bool> output-show-errors: true;
    in-out property <bool> output-show-debug: false;

    // Dynamic keyboard shortcuts — pushed from Bevy's KeyBindings resource
    // on startup and on every change. Empty string hides the subtitle.
    in-out property <string> shortcut-new: "";
    in-out property <string> shortcut-open: "";
    in-out property <string> shortcut-save: "";
    in-out property <string> shortcut-undo: "";
    in-out property <string> shortcut-redo: "";
    in-out property <string> shortcut-cut: "";
    in-out property <string> shortcut-copy: "";
    in-out property <string> shortcut-paste: "";
    in-out property <string> shortcut-duplicate: "";
    in-out property <string> shortcut-delete: "";
    in-out property <string> shortcut-select: "";
    in-out property <string> shortcut-move: "";
    in-out property <string> shortcut-scale: "";
    in-out property <string> shortcut-rotate: "";
    in-out property <string> shortcut-group: "";
    in-out property <string> shortcut-ungroup: "";
    in-out property <string> shortcut-lock: "";
    in-out property <string> shortcut-unlock: "";
    in-out property <string> shortcut-anchor: "";
    in-out property <string> shortcut-focus: "";

    // Notifications (pushed from Bevy — bottom-right stack above output panel)
    in-out property <[NotificationData]> notifications: [];
    callback dismiss-notification(int);

    // Soul Panel — full script audit view (Rune + Luau, grouped)
    in-out property <[SoulScriptData]> soul-scripts: [];
    in-out property <int> soul-selected-script: -1;
    // "not-set" | "valid" | "invalid" — drives the Soul & Workshop banners.
    // Written by a Bevy sync system that reads SoulServiceSettings.
    in-out property <string> soul-api-key-status: "not-set";

    // Shared Soul API key — Settings dialog edits it, sync system pushes
    // whatever is in `SoulServiceSettings`/`GlobalSoulSettings` on the way
    // in, the save action pushes it back out. BYOK: never leaves the
    // machine until the user makes an API call themselves.
    in-out property <string> soul-api-key: "";
    in-out property <bool> soul-api-key-valid: false;
    callback soul-api-key-saved();
    in-out property <int> soul-rune-count: 0;
    in-out property <int> soul-luau-server-count: 0;
    in-out property <int> soul-luau-client-count: 0;
    in-out property <int> soul-luau-module-count: 0;
    callback soul-build-all();

    // Notification settings (mirrored into File > Settings > Notifications)
    in-out property <bool> notifications-enabled: true;
    in-out property <bool> notifications-show-dismiss: true;
    in-out property <bool> notifications-mute-file: false;
    in-out property <bool> notifications-mute-script: false;
    in-out property <bool> notifications-mute-editor: false;
    in-out property <bool> notifications-mute-simulation: false;
    in-out property <bool> notifications-mute-network: false;
    in-out property <bool> notifications-mute-task: false;
    in-out property <bool> notifications-mute-general: false;
    in-out property <bool> notifications-mute-info: false;
    in-out property <bool> notifications-mute-warning: false;
    callback notification-settings-changed();
    
    // Unified explorer tree data: ECS entities + filesystem (pushed from Bevy)
    in-out property <[TreeNode]> tree-nodes: [];
    
    // Properties panel data (pushed from Bevy for selected entity)
    in-out property <[PropertyData]> entity-properties: [];
    // Help icon settings (from File > Settings)
    in-out property <bool> show-help-icons: true;
    in-out property <bool> help-opens-in-tab: false;
    
    // Input focus tracking — when true, Rust sync systems should NOT push property updates
    // to avoid overwriting user input while they're typing. Set by callbacks from input fields.
    in-out property <bool> any-input-has-focus: false;
    out property <bool> command-bar-has-focus: cmd-bar.input-has-focus;
    
    // Panel widths (resizable)
    in-out property <length> left-panel-width: 280px;
    in-out property <length> right-panel-width: 340px;
    in-out property <length> output-height: 150px;
    
    // ========================================================================
    // Dock Layout System Properties
    // ========================================================================
    
    // Layout presets
    in-out property <int> current-layout-preset: 0;
    in-out property <bool> show-layout-dropdown: false;
    property <float> layout-dropdown-x: 0;
    property <float> layout-dropdown-y: 0;
    
    // Theme settings
    in-out property <bool> show-theme-editor: false;
    in-out property <bool> high-contrast-mode: false;
    in-out property <float> ui-scale: 1.0;
    
    // Performance overlay
    in-out property <bool> show-performance-overlay: true;
    in-out property <float> current-fps: 60.0;
    in-out property <float> current-frame-time: 16.67;
    in-out property <int> current-entity-count: 0;
    
    // Floating panels
    in-out property <bool> has-floating-panels: false;
    
    // Drag-drop docking state
    in-out property <bool> is-dragging-panel: false;
    in-out property <DockZone> active-dock-zone: DockZone.center;
    
    // Viewport dimensions (reported to Bevy for camera viewport clipping)
    // Bound to viewport-sizer which always exists inside center-content's VerticalLayout.
    // Uses absolute-position for correct window-absolute coordinates.
    out property <float> viewport-width: viewport-sizer.width / 1px;
    out property <float> viewport-height: viewport-sizer.height / 1px;
    out property <float> viewport-x: viewport-sizer.absolute-position.x / 1px;
    out property <float> viewport-y: viewport-sizer.absolute-position.y / 1px;
    
    // Box selection overlay (set by Bevy during drag-to-select)
    in property <bool> box-select-visible: false;
    in property <float> box-select-x: 0;
    in property <float> box-select-y: 0;
    in property <float> box-select-w: 0;
    in property <float> box-select-h: 0;

    // Viewport image (set by Bevy with rendered 3D scene)
    in-out property <image> viewport-image;
    
    // Center viewport tab bar (VS Code-style tabbed viewer)
    // Tab types: "scene" = 3D viewport, "script" = Soul Script, "web" = browser
    in-out property <[CenterTab]> center-tabs: [];
    in-out property <int> center-active-tab: 0;
    in-out property <string> script-editor-content: "";
    in property <string> script-line-numbers: "1";  // Pre-computed "1\n2\n3...N" pushed by Rust
    // One entry per source line ("1", "2", …) so the gutter can render each
    // on the same 18px grid as the code overlay. Pushed by Rust alongside
    // `script-line-numbers`.
    in property <[string]> script-line-numbers-array: ["1"];
    // Pulsed true by Rust on tab switch/load to reset the editor scroll to line 1
    in-out property <bool> script-scroll-to-top: false;
    // Syntax-highlighted lines pushed from Rust (one per source line).
    // Empty when no file is open or language is unsupported.
    in property <[HighlightLine]> script-highlight-lines: [];
    in property <[TokenSpan]> script-token-spans: [];
    in property <[DiagnosticSpan]> script-diagnostic-spans: [];
    // Set by Rust when go-to-definition / problem-jump wants the editor to
    // scroll to a specific line. One-shot: Slint resets to 0 after applying.
    in-out property <int> script-scroll-to-line: 0;
    
    // Active tab type helper (set by Rust sync system)
    in-out property <string> active-tab-type: "scene"; // "scene", "script", "web"
    
    // Web browser state for active web tab
    in-out property <string> web-url-bar: "";
    in-out property <image> web-content-image;  // Offscreen-rendered web page
    in-out property <bool> web-secure: false;
    in-out property <bool> web-has-url: false;
    in-out property <bool> web-loading: false;
    in-out property <bool> web-can-go-back: false;
    in-out property <bool> web-can-go-forward: false;
    
    // Tab drag-and-drop reorder state
    in-out property <int> tab-drag-source: -1;   // Index of tab being dragged (-1 = none)
    in-out property <int> tab-drag-target: -1;    // Drop target index (-1 = none)
    in-out property <bool> tab-dragging: false;
    // Mouse-x relative to the tab strip start (updated by overlay TouchArea each frame)
    in-out property <length> tab-drag-x: 0px;
    // Width of the pinned Space1 tab (used as offset when computing drop index)
    in-out property <length> tab-strip-space1-width: 80px;
    in-out property <string> scene-tab-name: "Space";
    
    // Left panel tab
    in-out property <int> left-tab-index: 0;
    
    // Right panel tab
    in-out property <int> right-tab-index: 0;

    // Asset Manager
    in property <[AssetNode]> asset-nodes: [];
    in property <string> asset-category: "All";
    in property <int> universe-asset-count: 0;
    in property <int> space-asset-count: 0;
    callback asset-select(int);
    callback asset-expand(int);
    callback asset-import(string);
    callback asset-search(string);
    callback asset-category-changed(string);

    // ========================================================================
    // Callbacks (bound to Bevy systems)
    // ========================================================================
    
    // File operations
    callback new-universe();
    callback new-scene();
    callback open-scene();
    callback save-scene();
    callback save-scene-as();
    callback publish-universe();
    callback publish-space();
    callback publish(string, string, string, bool, bool, bool, bool);
    callback exit-app();
    
    // Edit operations
    callback undo();
    callback redo();
    callback history-jump-to(int);
    callback history-clear();
    callback copy();
    callback cut();
    callback paste();
    callback delete-selected();
    callback select-all();
    callback duplicate();
    callback group();
    callback ungroup();
    
    // Tool selection
    callback select-tool(string);
    
    // Transform
    callback set-transform-mode(string);
    callback toggle-snap();
    callback set-snap-increment(float);
    
    // View
    callback set-view-mode(string);
    callback focus-selected();
    callback toggle-wireframe();
    callback toggle-grid();
    
    // Play mode
    callback play-solo();
    callback play-with-character();
    callback pause();
    callback stop();
    
    // Explorer (unified: entities + files)
    callback select-node(int, string, /* ctrl */ bool, /* shift */ bool);
    callback expand-node(int, string);
    callback collapse-node(int, string);
    callback open-node(int, string);
    callback rename-node(int, string, string);
    callback reparent-node(int, int);  // Drag-and-drop: move source node into target node
    callback add-service();  // (+) button — add a new service to the Space
    callback expand-all();   // Expand all explorer tree nodes
    callback collapse-all(); // Collapse all explorer tree nodes
    callback deselect();     // Click on empty space — clear selection
    callback explorer-navigate-up();       // Arrow up in Explorer
    callback explorer-navigate-down();     // Arrow down in Explorer
    callback explorer-navigate-collapse(); // Arrow left — collapse node
    callback explorer-navigate-expand();   // Arrow right — expand node
    
    // Properties
    callback property-changed(string, string);
    // Section header chevron toggle — Rust drives collapsed state
    callback section-toggle(string);
    // Help icon — open /learn documentation URL
    callback open-learn-url(string);
    
    // Command bar
    callback execute-command(string);
    callback execute-script(/* language */ string, /* script */ string);
    callback clear-script-output();
    
    // Toolbox part insertion
    callback insert-part(string);
    
    // Context menu
    callback context-action(string);
    
    // Soul/Scripts
    callback build-script(int);
    callback summarize-script(int);
    callback open-script(int);
    
    // Center tab management
    callback close-center-tab(int);
    callback reopen-closed-tab();
    callback select-center-tab(int);
    callback script-content-changed(string);
    callback reorder-center-tab(int, int); // (from-index, to-index)
    callback toggle-mode(int);             // Toggle summary/code for SoulScript tab at index
    
    // Tab context menu actions
    callback close-other-tabs(int);         // Close all tabs except index
    callback close-tabs-to-right(int);      // Close all tabs to the right of index
    callback close-all-tabs();              // Close all closable tabs
    callback copy-tab-path(int);            // Copy tab file path to clipboard
    callback reveal-tab-in-explorer(int);   // Reveal tab's file in explorer panel
    
    // Web browser navigation
    callback open-web-tab(string);          // Open URL in new tab
    callback web-navigate(string);          // Navigate active web tab to URL
    callback web-go-back();
    callback web-go-forward();
    callback web-refresh();
    
    // Auth
    callback login();
    callback logout();
    callback open-path-from-log(string);
    
    // Terrain
    callback generate-terrain(string); // "small", "medium", "large"
    callback toggle-terrain-edit-mode();
    callback set-terrain-brush(string);
    callback import-heightmap();
    callback export-heightmap();
    
    // Network
    callback start-server();
    callback stop-server();
    callback connect-forge();
    callback disconnect-forge();
    callback allocate-forge-server();
    callback spawn-synthetic-clients(int);
    callback disconnect-all-clients();
    
    // Simulation settings
    callback apply-simulation-settings();
    callback save-simulation-settings();
    callback add-sim-watchpoint();
    callback remove-sim-watchpoint(int);
    callback add-sim-output-binding();
    callback remove-sim-output-binding(int);

    // Data menu
    callback open-global-sources();
    callback open-domains();
    callback open-global-variables();
    callback open-sync-domain();
    callback add-data-source(string);
    
    // MindSpace / Plugins
    callback toggle-mindspace();
    callback mindspace-add-label();
    callback mindspace-connect();
    callback plugin-action(string);
    callback open-url(string);
    callback menu-action(string);
    
    // Workshop Panel (System 0: Ideation)
    callback workshop-send-message(string);
    callback workshop-mention-query-changed(string);
    callback workshop-mention-commit(int);
    callback workshop-mention-cancel();

    // Problems panel callbacks
    callback problems-jump-to(string, int, int);   // file_path, line, column
    callback problems-fix-with-workshop();

    // Script editor IDE features (Phase 3-4)
    callback script-go-to-definition(int, int);    // line, col (1-based)
    callback script-find-references(int, int);     // line, col (1-based)
    callback workshop-approve-mcp(int);
    callback workshop-skip-mcp(int);
    callback workshop-edit-mcp(int);
    callback workshop-open-artifact(string);
    callback workshop-start-pipeline();
    callback workshop-pause-pipeline();
    callback workshop-resume-pipeline();
    callback workshop-cancel-pipeline();
    callback workshop-optimize-and-build();
    callback workshop-load-conversation(string);
    callback workshop-new-conversation();
    /// Close a session tab in the Workshop panel. Host removes the
    /// session from the in-memory list and optionally deletes the
    /// folder under SoulService/Workshop/ (policy TBD — for now
    /// we just remove from UI and keep the folder on disk).
    callback workshop-close-conversation(string);
    /// Drag-to-reorder commit. `target_index` is the 0-based final
    /// position in `workshop-past-conversations`. Host updates an
    /// in-memory order override that the sync system honours.
    callback workshop-reorder-tab(string /* session_id */, int /* target_index */);

    // Settings / Panels
    callback open-settings();
    callback open-find();
    // Help icon setting changes (fired immediately from Settings dialog)
    callback help-icons-changed(bool);
    callback help-opens-in-tab-changed(bool);
    
    // Dock Layout System Callbacks
    callback apply-layout-preset(int);
    callback save-layout-to-file();
    callback load-layout-from-file();
    callback reset-layout-to-default();
    callback toggle-theme-editor();
    callback apply-theme-settings(bool, bool, float); // dark-mode, high-contrast, ui-scale
    callback detach-panel-to-window(string);
    callback dock-panel(string, DockZone);
    
    // Native Window Integration Callbacks
    // These are called when viewport bounds change so Bevy can reposition its window
    callback viewport-bounds-changed(float, float, float, float); // x, y, width, height
    callback close-requested();
    callback force-exit(); // Skip unsaved check (after exit confirmation dialog)

    // ========================================================================
    // Main Layout
    // ========================================================================
    
    VerticalLayout {
        spacing: 0px;

        // ====================================================================
        // Top Ribbon
        // ====================================================================
        Ribbon {
            current-tool: root.current-tool;
            transform-mode: root.transform-mode;
            play-state: root.play-state;
            has-unsaved-changes: root.has-unsaved-changes;

            // Bind View menu panel visibility (two-way)
            show-explorer <=> root.show-explorer;
            show-properties <=> root.show-properties;
            show-output <=> root.show-output;
            show-assets <=> root.show-assets;
            show-collaboration <=> root.show-collaboration;
            show-command-bar <=> root.show-command-bar;

            // Pipe dynamic keyboard shortcuts into the ribbon subtitles
            shortcut-new: root.shortcut-new;
            shortcut-open: root.shortcut-open;
            shortcut-save: root.shortcut-save;
            shortcut-undo: root.shortcut-undo;
            shortcut-redo: root.shortcut-redo;
            shortcut-cut: root.shortcut-cut;
            shortcut-copy: root.shortcut-copy;
            shortcut-paste: root.shortcut-paste;
            shortcut-duplicate: root.shortcut-duplicate;
            shortcut-delete: root.shortcut-delete;
            shortcut-select: root.shortcut-select;
            shortcut-move: root.shortcut-move;
            shortcut-scale: root.shortcut-scale;
            shortcut-rotate: root.shortcut-rotate;
            shortcut-group: root.shortcut-group;
            shortcut-ungroup: root.shortcut-ungroup;
            shortcut-lock: root.shortcut-lock;
            shortcut-unlock: root.shortcut-unlock;
            shortcut-anchor: root.shortcut-anchor;
            shortcut-focus: root.shortcut-focus;

            account-name: root.account-name;
            account-status: root.account-status;
            sync-status: root.sync-status;
            session-hours: root.session-hours;
            total-hours: root.total-hours;
            saved-identities: root.saved-identities;
            on-sign-out => { root.logout(); }
            on-switch-identity(username) => { root.switch-identity(username); }
            on-remove-identity(username) => { root.remove-identity(username); }

            // Update system
            update-available: root.update-available;
            update-version: root.update-version;
            update-status: root.update-status;
            update-progress: root.update-progress;
            on-update-clicked => { root.update-clicked(); }

            // Bliss
            bliss-balance: root.bliss-balance;
            bliss-balance-short: root.bliss-balance-short;
            bliss-pending: root.bliss-pending;
            bliss-node-mode: root.bliss-node-mode;
            bliss-bonus: root.bliss-bonus;
            bliss-enabled: root.bliss-enabled;
            on-bliss-set-light => { root.bliss-set-light(); }
            on-bliss-set-full => { root.bliss-set-full(); }
            on-bliss-toggle-enabled => { root.bliss-toggle-enabled(); }
            
            // File
            on-new-universe => { root.new-universe(); }
            on-new-scene => { root.new-scene(); }
            on-open-scene => { root.open-scene(); }
            on-save-scene => { root.save-scene(); }
            on-save-scene-as => { root.save-scene-as(); }
            on-publish-universe => { root.publish-universe(); }
            on-publish-space => { root.publish-space(); }
            on-exit => { root.exit-app(); }
            
            // Edit
            on-undo => { root.undo(); }
            on-redo => { root.redo(); }
            on-copy => { root.copy(); }
            on-cut => { root.cut(); }
            on-paste => { root.paste(); }
            on-delete => { root.delete-selected(); }
            on-duplicate => { root.duplicate(); }
            on-select-all => { root.select-all(); }
            on-group => { root.group(); }
            on-ungroup => { root.ungroup(); }
            
            // Tools
            on-select-tool(tool) => { root.select-tool(tool); }
            on-set-transform-mode(mode) => { root.set-transform-mode(mode); }
            
            // View
            on-focus-selection => { root.focus-selected(); }
            
            // Play
            on-play-solo => { root.play-solo(); }
            on-play-with-character => { root.play-with-character(); }
            on-pause => { root.pause(); }
            on-stop => { root.stop(); }
            on-show-simulation-settings => { root.show-simulation-settings-dialog = true; }
            
            // Network
            on-start-server => { root.start-server(); }
            on-stop-server => { root.stop-server(); }
            on-show-forge-connect => { root.show-forge-connect-dialog = true; }
            on-show-network-panel => { root.show-network-panel = true; }
            on-show-stress-test => { root.show-stress-test-dialog = true; }
            
            // Data
            on-show-global-sources => { root.open-global-sources(); }
            on-show-domains => { root.open-domains(); }
            on-show-global-variables => { root.open-global-variables(); }
            on-show-sync-domain => { root.open-sync-domain(); }
            on-add-data-source(source-type) => { root.add-data-source(source-type); }
            
            // Terrain
            on-spawn-terrain(size) => { root.generate-terrain(size); }
            on-toggle-terrain-edit => { root.toggle-terrain-edit-mode(); }
            on-set-terrain-brush(brush) => { root.set-terrain-brush(brush); }
            on-import-heightmap => { root.import-heightmap(); }
            on-export-heightmap => { root.export-heightmap(); }
            
            // Plugins / MindSpace
            on-plugin-action(action) => { root.plugin-action(action); }
            
            // Other
            on-toggle-command-bar => { root.show-command-bar = !root.show-command-bar; }
            on-show-keybindings => { root.show-keybindings-dialog = true; }
            on-show-about => { root.show-about-dialog = true; }
            on-show-soul-settings => { root.settings-active-tab = 3; root.show-settings-dialog = true; }
            on-show-settings => { root.show-settings-dialog = true; }
            on-open-url(url) => { root.open-url(url); }
            on-open-login => { root.show-login-dialog = true; }
            on-menu-action(action) => { root.menu-action(action); }
        }

        // ====================================================================
        // Main Content Area (Left Panel | Viewport | Right Panel)
        // ====================================================================
        HorizontalLayout {
            spacing: 0px;
            
            // ================================================================
            // Left Panel (Explorer, Toolbox, Assets, etc.)
            // ================================================================
            if root.show-explorer || root.show-toolbox || root.show-assets || root.show-terrain-editor || root.show-universe-browser: Rectangle {
                width: root.left-panel-width;
                background: Theme.panel-background;
                border-width: 0px;
                // Right edge separator
                Rectangle {
                    x: parent.width - 1px;
                    width: 1px;
                    height: 100%;
                    background: Theme.border-color;
                }
                
                VerticalLayout {
                    spacing: 0px;
                    
                    // Tab bar
                    Rectangle {
                        height: 30px;
                        background: Theme.header-background;
                        
                        HorizontalLayout {
                            padding-left: 2px;
                            padding-right: 2px;
                            padding-top: 2px;
                            spacing: 1px;

                            // Tab 0: Universes (always visible, first)
                            Rectangle {
                                horizontal-stretch: 1;
                                background: root.left-tab-index == 0 ? Theme.panel-background : Theme.tab-inactive;
                                border-top-left-radius: 4px;
                                border-top-right-radius: 4px;

                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.left-tab-index = 0; }
                                }

                                Text {
                                    text: "Explorer";
                                    color: root.left-tab-index == 0 ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // Tab 1: Assets
                            Rectangle {
                                horizontal-stretch: 1;
                                background: root.left-tab-index == 1 ? Theme.panel-background : Theme.tab-inactive;
                                border-top-left-radius: 4px;
                                border-top-right-radius: 4px;

                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.left-tab-index = 1; }
                                }

                                Text {
                                    text: "Assets";
                                    color: root.left-tab-index == 1 ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // Tab 2: Explorer
                            Rectangle {
                                horizontal-stretch: 1;
                                background: root.left-tab-index == 2 ? Theme.panel-background : Theme.tab-inactive;
                                border-top-left-radius: 4px;
                                border-top-right-radius: 4px;

                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.left-tab-index = 2; }
                                }

                                Text {
                                    text: "Universes";
                                    color: root.left-tab-index == 2 ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // Tab 3: Toolbox
                            Rectangle {
                                horizontal-stretch: 1;
                                background: root.left-tab-index == 3 ? Theme.panel-background : Theme.tab-inactive;
                                border-top-left-radius: 4px;
                                border-top-right-radius: 4px;

                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.left-tab-index = 3; }
                                }

                                Text {
                                    text: "Toolbox";
                                    color: root.left-tab-index == 3 ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            // Overflow: chevron dropdown for additional panels (Terrain, etc.)
                            Rectangle {
                                width: 24px;
                                background: more-panels-touch.has-hover ? Theme.button-hover : Theme.tab-inactive;
                                border-top-left-radius: 4px;
                                border-top-right-radius: 4px;

                                more-panels-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { more-panels-popup.show(); }
                                }

                                Image {
                                    width: 12px;
                                    height: 12px;
                                    source: @image-url("../../assets/icons/ui/chevron-down.svg");
                                    image-fit: contain;
                                    colorize: Theme.text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                more-panels-popup := PopupWindow {
                                    x: -60px;
                                    y: parent.height;
                                    width: 140px;

                                    Rectangle {
                                        background: #1e1e1e;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: #3a3a3a;
                                        drop-shadow-blur: 8px;
                                        drop-shadow-color: #00000080;
                                        width: 140px;

                                        VerticalLayout {
                                            padding-top: 4px;
                                            padding-bottom: 4px;

                                            // Terrain toggle
                                            Rectangle {
                                                height: 24px;
                                                background: terrain-item-touch.has-hover ? Theme.button-hover : transparent;

                                                terrain-item-touch := TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => { root.left-tab-index = 4; }
                                                }

                                                HorizontalLayout {
                                                    padding-left: 10px;
                                                    spacing: 6px;

                                                    Text {
                                                        text: "Terrain";
                                                        color: root.left-tab-index == 4 ? Theme.text-primary : Theme.text-secondary;
                                                        font-size: 11px;
                                                        vertical-alignment: center;
                                                        horizontal-stretch: 1;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                    
                    // Tab content (must stretch to fill remaining space so inner ScrollView works)
                    Rectangle {
                        vertical-stretch: 1;
                        clip: true;
                        background: Theme.panel-background;
                        
                        if root.left-tab-index == 0: ExplorerPanel {
                            tree-nodes: root.tree-nodes;
                            on-select-node(id, node-type, ctrl, shift) => { root.select-node(id, node-type, ctrl, shift); }
                            on-expand-node(id, node-type) => { root.expand-node(id, node-type); }
                            on-collapse-node(id, node-type) => { root.collapse-node(id, node-type); }
                            on-open-node(id, node-type) => { root.open-node(id, node-type); }
                            on-reparent-node(source, target) => { root.reparent-node(source, target); }
                            on-add-service() => { root.add-service(); }
                            on-expand-all() => { root.expand-all(); }
                            on-collapse-all() => { root.collapse-all(); }
                            on-deselect() => { root.deselect(); }
                            navigate-up() => { root.explorer-navigate-up(); }
                            navigate-down() => { root.explorer-navigate-down(); }
                            navigate-collapse() => { root.explorer-navigate-collapse(); }
                            navigate-expand() => { root.explorer-navigate-expand(); }
                            on-context-menu(x, y, node-id, node-type) => {
                                root.context-menu-x = x;
                                root.context-menu-y = y;
                                root.context-menu-node-type = node-type;
                                
                                // Populate menu items based on node type
                                if node-type == "file" {
                                    root.context-menu-items = [
                                        { id: "open", label: "Open", shortcut: "Enter", icon: @image-url("../../assets/icons/ui/new-file.svg"), enabled: true, separator-after: false },
                                        { id: "open-with", label: "Open With...", shortcut: "", icon: @image-url("../../assets/icons/ui/settings.svg"), enabled: true, separator-after: true },
                                        { id: "cut", label: "Cut", shortcut: "Ctrl+X", icon: @image-url("../../assets/icons/ui/cut.svg"), enabled: true, separator-after: false },
                                        { id: "copy", label: "Copy", shortcut: "Ctrl+C", icon: @image-url("../../assets/icons/ui/copy.svg"), enabled: true, separator-after: false },
                                        { id: "paste", label: "Paste", shortcut: "Ctrl+V", icon: @image-url("../../assets/icons/ui/paste.svg"), enabled: true, separator-after: false },
                                        { id: "delete", label: "Delete", shortcut: "Del", icon: @image-url("../../assets/icons/ui/delete.svg"), enabled: true, separator-after: true },
                                        { id: "rename", label: "Rename", shortcut: "F2", icon: @image-url("../../assets/icons/ui/rename.svg"), enabled: true, separator-after: false },
                                        { id: "duplicate", label: "Duplicate", shortcut: "Ctrl+D", icon: @image-url("../../assets/icons/ui/duplicate.svg"), enabled: true, separator-after: true },
                                        { id: "show-in-explorer", label: "Show in File Explorer", shortcut: "", icon: @image-url("../../assets/icons/folder.svg"), enabled: true, separator-after: false },
                                        { id: "copy-path", label: "Copy Path", shortcut: "", icon: @image-url("../../assets/icons/ui/link.svg"), enabled: true, separator-after: false },
                                        { id: "copy-relative-path", label: "Copy Relative Path", shortcut: "", icon: @image-url("../../assets/icons/ui/link.svg"), enabled: true, separator-after: true },
                                        { id: "properties", label: "Properties", shortcut: "Alt+Enter", icon: @image-url("../../assets/icons/ui/settings.svg"), enabled: true, separator-after: false },
                                    ];
                                } else {
                                    // Entity menu - use default items from ContextMenu component
                                    root.context-menu-items = [];
                                }
                                
                                root.show-context-menu = true;
                            }
                        }
                        
                        if root.left-tab-index == 3: Toolbox {
                            current-tool: root.current-tool;
                            on-select-tool(tool) => { root.select-tool(tool); }
                            on-insert-part(part-type) => { root.insert-part(part-type); }
                        }
                        
                        if root.left-tab-index == 1: AssetManager {
                            asset-nodes: root.asset-nodes;
                            current-category: root.asset-category;
                            universe-asset-count: root.universe-asset-count;
                            space-asset-count: root.space-asset-count;
                            on-select-asset(id) => { root.asset-select(id); }
                            on-expand-asset(id) => { root.asset-expand(id); }
                            on-import-asset(kind) => { root.asset-import(kind); }
                            on-search-changed(text) => { root.asset-search(text); }
                            on-category-changed(cat) => { root.asset-category-changed(cat); }
                        }
                        
                        if root.left-tab-index == 2: UniverseBrowser {
                            universe-items: root.universe-items;
                            active-space-path: root.active-space-path;
                            space-selected(path) => { root.space-selected(path); }
                        }

                        if root.left-tab-index == 4: TerrainEditor {
                            has-terrain: root.has-terrain;
                            edit-mode: root.terrain-edit-mode;
                            current-brush: root.terrain-brush;
                            terrain-size: root.terrain-size;
                            terrain-chunk-size: root.terrain-chunk-size;
                            terrain-resolution: root.terrain-resolution;
                            terrain-height-scale: root.terrain-height-scale;
                            terrain-lod-levels: root.terrain-lod-levels;
                            terrain-chunk-count: root.terrain-chunk-count;
                            terrain-material: root.terrain-material;
                            on-toggle-edit-mode() => { root.toggle-terrain-edit-mode(); }
                            on-generate-terrain(size) => { root.generate-terrain(size); }
                            on-import-heightmap() => { root.import-heightmap(); }
                            on-export-heightmap() => { root.export-heightmap(); }
                        }
                    }
                }
                
                // Resize handle — 8px interactive strip on the right edge with hover highlight
                left-resize := Rectangle {
                    x: parent.width - 4px;
                    width: 8px;
                    height: 100%;
                    background: left-resize-ta.has-hover || left-resize-ta.pressed ? Theme.border-focus : transparent;
                    opacity: left-resize-ta.pressed ? 1.0 : 0.5;
                    
                    left-resize-ta := TouchArea {
                        mouse-cursor: ew-resize;
                        moved => {
                            root.left-panel-width = max(180px, min(600px, root.left-panel-width + (self.mouse-x - self.pressed-x)));
                        }
                    }
                }
            }

            // ================================================================
            // Central Area: Tab Bar + Viewport / Script Editor
            // ================================================================
            center-content := Rectangle {
                horizontal-stretch: 1;
                background: transparent;
                
                VerticalLayout {
                    spacing: 0px;
                
                // ---- VS Code-style Tab Bar ----
                tab-bar := Rectangle {
                    height: 35px;
                    background: Theme.background-secondary;
                    
                    // Bottom border
                    Rectangle {
                        y: parent.height - 1px;
                        height: 1px;
                        background: Theme.border-color;
                    }
                    
                    // === Home button (left-aligned) ===
                    Rectangle {
                        x: 0px;
                        y: 0px;
                        width: 36px;
                        height: 35px;
                        background: home-btn-touch.has-hover ? #ffffff0c : transparent;
                        
                        home-btn-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.open-web-tab("https://eustress.dev/learn"); }
                        }
                        
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("../../assets/icons/ui/globe.svg");
                            image-fit: contain;
                            colorize: Theme.accent-blue;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        
                        // Right separator
                        Rectangle {
                            x: parent.width - 1px;
                            width: 1px;
                            height: parent.height;
                            background: Theme.border-color;
                        }
                    }
                    
                    // === UI Toggle button (right-aligned) ===
                    Rectangle {
                        x: parent.width - 36px;
                        y: 0px;
                        width: 36px;
                        height: 35px;
                        background: hud-toggle-touch.has-hover ? #ffffff0c : transparent;
                        
                        hud-toggle-touch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.show-hud = !root.show-hud; }
                        }
                        
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("../../assets/icons/ui/layout-default.svg");
                            image-fit: contain;
                            colorize: root.show-hud ? Theme.text-secondary : #ef5350;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        
                        // Left separator
                        Rectangle {
                            x: 0px;
                            width: 1px;
                            height: parent.height;
                            background: Theme.border-color;
                        }
                    }
                    
                    // === Tab strip (between Home and UI toggle) ===
                    // Wrapped in Rectangle so the drag-overlay TouchArea can be positioned
                    // absolutely on top of the entire strip — this is the only way in Slint
                    // to receive moved() events that cross multiple tab boundaries.
                    tab-strip := Rectangle {
                        x: 36px;
                        y: 0px;
                        width: parent.width - 72px;
                        height: 35px;

                    HorizontalLayout {
                        width: parent.width;
                        height: parent.height;
                        spacing: 0px;
                        alignment: start;
                        
                        // Pinned Space1 tab (always first, never closable)
                        Rectangle {
                            width: space1-label.preferred-width + 24px;
                            height: 35px;
                            background: root.center-active-tab == 0 ? Theme.panel-background : 
                                        space1-touch.has-hover ? #ffffff08 : Theme.background-secondary;
                            
                            // Active tab indicator (blue top border — VS Code style)
                            if root.center-active-tab == 0: Rectangle {
                                y: 0px;
                                height: 2px;
                                background: Theme.accent-blue;
                            }
                            
                            // Right separator
                            Rectangle {
                                x: parent.width - 1px;
                                width: 1px;
                                height: parent.height;
                                background: Theme.border-color;
                            }
                            
                            space1-touch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.center-active-tab = 0;
                                    root.select-center-tab(0);
                                }
                                // Right-click context menu
                                pointer-event(event) => {
                                    if event.kind == PointerEventKind.up && event.button == PointerEventButton.right {
                                        root.tab-context-menu-index = -1;
                                        root.tab-context-menu-x = self.absolute-position.x + self.mouse-x - tab-strip.absolute-position.x;
                                        root.tab-context-menu-y = 35px;
                                        tab-ctx-menu.show();
                                    }
                                }
                            }
                            
                            space1-label := Text {
                                text: root.scene-tab-name;
                                color: root.center-active-tab == 0 ? Theme.text-primary : Theme.text-secondary;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                        
                        // Dynamic tabs (script + web) with drag-and-drop reorder
                        for tab[index] in root.center-tabs: Rectangle {
                            width: tab.tab-type == "web" ? 200px : 180px;
                            height: 35px;
                            background: root.center-active-tab == index + 1
                                ? Theme.panel-background
                                : (tab-hover.has-hover ? #ffffff08 : Theme.background-secondary);
                            
                            // Active tab indicator (blue top border — VS Code style)
                            if root.center-active-tab == index + 1: Rectangle {
                                y: 0px;
                                height: 2px;
                                background: Theme.accent-blue;
                            }
                            
                            // Drop indicator line (left edge) when dragging over
                            if root.tab-dragging && root.tab-drag-target == index && root.tab-drag-source != index: Rectangle {
                                x: -1px;
                                width: 2px;
                                height: parent.height;
                                background: Theme.accent-blue;
                            }
                            
                            // Right separator
                            Rectangle {
                                x: parent.width - 1px;
                                width: 1px;
                                height: parent.height;
                                background: Theme.border-color;
                            }
                            
                            tab-hover := TouchArea {
                                mouse-cursor: root.tab-dragging ? move : pointer;
                                property <bool> left-down: false;
                                property <length> press-x: 0px;

                                clicked => {
                                    if !root.tab-dragging {
                                        root.center-active-tab = index + 1;
                                        root.select-center-tab(index + 1);
                                    }
                                }
                                moved => {
                                    // Start drag after 5px horizontal movement
                                    if self.left-down && !root.tab-dragging && abs(self.mouse-x - self.press-x) > 5px {
                                        root.tab-drag-source = index;
                                        root.tab-dragging = true;
                                    }
                                }
                                pointer-event(event) => {
                                    if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                                        self.left-down = true;
                                        self.press-x = self.mouse-x;
                                    }
                                    if event.button == PointerEventButton.left && event.kind == PointerEventKind.up {
                                        self.left-down = false;
                                    }
                                    if event.button == PointerEventButton.right && event.kind == PointerEventKind.up {
                                        root.tab-context-menu-index = index;
                                        root.tab-context-menu-x = self.absolute-position.x + self.mouse-x - tab-strip.absolute-position.x;
                                        root.tab-context-menu-y = 35px;
                                        tab-ctx-menu.show();
                                    }
                                }
                            }
                            
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 4px;
                                spacing: 6px;
                                // No alignment: center here — it fights horizontal-stretch on the
                                // tab name text. Each child uses vertical-alignment: center instead.

                                // Tab icon (type-dependent) — vertically centered via VerticalLayout
                                if tab.tab-type == "web" && tab.favicon.width > 0: VerticalLayout {
                                    alignment: center;
                                    width: 14px;
                                    Image {
                                        width: 14px;
                                        height: 14px;
                                        source: tab.favicon;
                                        image-fit: contain;
                                    }
                                }
                                if tab.tab-type == "web" && tab.favicon.width == 0: VerticalLayout {
                                    alignment: center;
                                    width: 14px;
                                    Image {
                                        width: 14px;
                                        height: 14px;
                                        source: @image-url("../../assets/icons/ui/globe.svg");
                                        image-fit: contain;
                                        colorize: Theme.text-secondary;
                                    }
                                }
                                if tab.tab-type == "script": VerticalLayout {
                                    alignment: center;
                                    width: 14px;
                                    Image {
                                        width: 14px;
                                        height: 14px;
                                        source: @image-url("../../assets/icons/script.svg");
                                        image-fit: contain;
                                    }
                                }
                                if tab.tab-type == "code": VerticalLayout {
                                    alignment: center;
                                    width: 14px;
                                    Image {
                                        width: 14px;
                                        height: 14px;
                                        source: @image-url("../../assets/icons/ui/new-file.svg");
                                        image-fit: contain;
                                        colorize: Theme.text-secondary;
                                    }
                                }

                                // Tab name — stretches to fill space, pushing close button right
                                Text {
                                    horizontal-stretch: 1;
                                    text: tab.name;
                                    color: root.center-active-tab == index + 1 ? Theme.text-primary : Theme.text-secondary;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }

                                // Loading spinner
                                if tab.loading: Text {
                                    text: "◌";
                                    color: Theme.accent-blue;
                                    font-size: 10px;
                                    vertical-alignment: center;
                                }

                                // Dirty indicator (unsaved dot)
                                if tab.dirty && !tab.loading: VerticalLayout {
                                    alignment: center;
                                    width: 8px;
                                    Rectangle {
                                        width: 8px;
                                        height: 8px;
                                        border-radius: 4px;
                                        background: #e8e8e8;
                                    }
                                }

                                // Spacer for close button area
                                Rectangle { width: 22px; }
                            }

                            // Close button (X) — absolutely positioned on top so it intercepts clicks above tab-hover
                            Rectangle {
                                x: parent.width - 26px;
                                y: (parent.height - 22px) / 2;
                                width: 22px;
                                height: 22px;
                                background: close-area.has-hover ? #c42b1c40 : transparent;
                                border-radius: 4px;

                                close-area := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.close-center-tab(index); }
                                }

                                Image {
                                    width: 12px;
                                    height: 12px;
                                    source: @image-url("../../assets/icons/ui/close.svg");
                                    image-fit: contain;
                                    colorize: close-area.has-hover ? #ef5350 : Theme.text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        
                        // Drop indicator at end (when dragging past last tab)
                        if root.tab-dragging && root.tab-drag-target >= root.center-tabs.length: Rectangle {
                            width: 2px;
                            height: 35px;
                            background: Theme.accent-blue;
                        }
                        
                        // Fill remaining space
                        Rectangle { horizontal-stretch: 1; }
                    } // end HorizontalLayout

                    // ── Drag overlay ─────────────────────────────────────────
                    // A single full-width TouchArea on top of all dynamic tabs.
                    // It is the ONLY place that tracks moved() during a drag so
                    // the event is never lost when the pointer crosses tab edges.
                    // Space1 tab (~80px) is skipped; dynamic tabs are 180/200px wide.
                    if root.tab-drag-source >= 0: TouchArea {
                        x: root.tab-strip-space1-width; // start after pinned Space1
                        y: 0px;
                        width: parent.width - root.tab-strip-space1-width;
                        height: parent.height;
                        mouse-cursor: move;

                        moved => {
                            // Begin drag after 5px threshold
                            if !root.tab-dragging && abs(self.mouse-x - self.pressed-x) > 5px {
                                root.tab-dragging = true;
                            }
                            if root.tab-dragging {
                                // Compute which tab slot the pointer is over from mouse-x
                                // Each dynamic tab is ~190px wide on average (mix of 180/200)
                                // We iterate via a step approximation — good enough for reorder UX
                                let raw-idx = floor((self.mouse-x) / 190px);
                                let clamped = max(0, min(raw-idx, root.center-tabs.length));
                                root.tab-drag-target = clamped;
                                root.tab-drag-x = self.mouse-x;
                            }
                        }

                        pointer-event(event) => {
                            if event.kind == PointerEventKind.up && event.button == PointerEventButton.left {
                                if root.tab-dragging && root.tab-drag-source != root.tab-drag-target && root.tab-drag-target >= 0 {
                                    root.reorder-center-tab(root.tab-drag-source, root.tab-drag-target);
                                }
                                root.tab-dragging = false;
                                root.tab-drag-source = -1;
                                root.tab-drag-target = -1;
                            }
                        }
                    }

                    // Drag overlay removed — drag initiation is now handled by per-tab
                    // tab-hover TouchAreas for proper hover feedback on close buttons.

                    } // end tab-strip Rectangle
                    
                    // Tab context menu (PopupWindow positioned relative to tab-bar)
                    tab-ctx-menu := PopupWindow {
                        x: root.tab-context-menu-x;
                        y: root.tab-context-menu-y;
                        width: 220px;
                        
                        Rectangle {
                            background: #1e1e1e;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: #3a3a3a;
                            drop-shadow-blur: 8px;
                            drop-shadow-color: #00000060;
                            width: 220px;
                            
                            VerticalLayout {
                                padding: 4px;
                                spacing: 0px;
                                
                                // Close
                                if root.tab-context-menu-index >= 0: Rectangle {
                                    height: 28px;
                                    background: ctx-close-touch.has-hover ? #ffffff10 : transparent;
                                    border-radius: 3px;
                                    ctx-close-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.close-center-tab(root.tab-context-menu-index); }
                                    }
                                    HorizontalLayout {
                                        padding-left: 8px; padding-right: 10px;
                                        spacing: 8px;
                                        Image { width: 14px; height: 14px; source: @image-url("../../assets/icons/ui/close.svg"); image-fit: contain; colorize: Theme.text-secondary; vertical-alignment: center; }
                                        Text { text: "Close"; color: Theme.text-primary; font-size: 12px; vertical-alignment: center; }
                                        Rectangle { horizontal-stretch: 1; }
                                        Text { text: "Ctrl+W"; color: Theme.text-secondary; font-size: 11px; vertical-alignment: center; }
                                    }
                                }

                                // Close Others
                                Rectangle {
                                    height: 28px;
                                    background: ctx-others-touch.has-hover ? #ffffff10 : transparent;
                                    border-radius: 3px;
                                    ctx-others-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.close-other-tabs(root.tab-context-menu-index); }
                                    }
                                    HorizontalLayout {
                                        padding-left: 8px; padding-right: 10px;
                                        spacing: 8px;
                                        Image { width: 14px; height: 14px; source: @image-url("../../assets/icons/ui/close.svg"); image-fit: contain; colorize: Theme.text-secondary; vertical-alignment: center; }
                                        Text { text: "Close Others"; color: Theme.text-primary; font-size: 12px; vertical-alignment: center; }
                                    }
                                }

                                // Close All
                                Rectangle {
                                    height: 28px;
                                    background: ctx-all-touch.has-hover ? #ffffff10 : transparent;
                                    border-radius: 3px;
                                    ctx-all-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.close-all-tabs(); }
                                    }
                                    HorizontalLayout {
                                        padding-left: 8px; padding-right: 10px;
                                        spacing: 8px;
                                        Image { width: 14px; height: 14px; source: @image-url("../../assets/icons/ui/close.svg"); image-fit: contain; colorize: Theme.text-secondary; vertical-alignment: center; }
                                        Text { text: "Close All"; color: Theme.text-primary; font-size: 12px; vertical-alignment: center; }
                                    }
                                }

                                // Close to the Right
                                if root.tab-context-menu-index >= 0: Rectangle {
                                    height: 28px;
                                    background: ctx-right-touch.has-hover ? #ffffff10 : transparent;
                                    border-radius: 3px;
                                    ctx-right-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.close-tabs-to-right(root.tab-context-menu-index); }
                                    }
                                    HorizontalLayout {
                                        padding-left: 8px; padding-right: 10px;
                                        spacing: 8px;
                                        Image { width: 14px; height: 14px; source: @image-url("../../assets/icons/ui/close.svg"); image-fit: contain; colorize: Theme.text-secondary; vertical-alignment: center; }
                                        Text { text: "Close to the Right"; color: Theme.text-primary; font-size: 12px; vertical-alignment: center; }
                                    }
                                }

                                // Separator
                                Rectangle { height: 1px; background: Theme.border-color; }

                                // Copy Path
                                if root.tab-context-menu-index >= 0: Rectangle {
                                    height: 28px;
                                    background: ctx-copy-touch.has-hover ? #ffffff10 : transparent;
                                    border-radius: 3px;
                                    ctx-copy-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.copy-tab-path(root.tab-context-menu-index); }
                                    }
                                    HorizontalLayout {
                                        padding-left: 8px; padding-right: 10px;
                                        spacing: 8px;
                                        Image { width: 14px; height: 14px; source: @image-url("../../assets/icons/ui/link.svg"); image-fit: contain; colorize: Theme.text-secondary; vertical-alignment: center; }
                                        Text { text: "Copy Path"; color: Theme.text-primary; font-size: 12px; vertical-alignment: center; }
                                    }
                                }

                                // Reveal in Explorer
                                if root.tab-context-menu-index >= 0: Rectangle {
                                    height: 28px;
                                    background: ctx-reveal-touch.has-hover ? #ffffff10 : transparent;
                                    border-radius: 3px;
                                    ctx-reveal-touch := TouchArea {
                                        mouse-cursor: pointer;
                                        clicked => { root.reveal-tab-in-explorer(root.tab-context-menu-index); }
                                    }
                                    HorizontalLayout {
                                        padding-left: 8px; padding-right: 10px;
                                        spacing: 8px;
                                        Image { width: 14px; height: 14px; source: @image-url("../../assets/icons/folder.svg"); image-fit: contain; colorize: Theme.text-secondary; vertical-alignment: center; }
                                        Text { text: "Reveal in Explorer"; color: Theme.text-primary; font-size: 12px; vertical-alignment: center; }
                                    }
                                }
                            }
                        }
                    }
                }
                
                // ---- Content Area: 3D Viewport / Script Editor / Web Browser ----
                // Persistent viewport sizer — always exists, reports absolute position to Bevy
                // via property bindings on root.viewport-width/height/x/y
                viewport-sizer := Rectangle {
                    vertical-stretch: 1;
                    background: transparent;
                
                // Keyboard shortcut handler (Ctrl+W to close active tab, Ctrl+T for new web tab)
                tab-keys := FocusScope {
                    
                    key-pressed(event) => {
                        // Ctrl+W: close active tab (not Space1)
                        if event.modifiers.control && event.text == "w" {
                            if root.center-active-tab > 0 {
                                root.close-center-tab(root.center-active-tab - 1);
                                if root.center-active-tab >= root.center-tabs.length + 1 {
                                    root.center-active-tab = root.center-tabs.length;
                                }
                            }
                            return accept;
                        }
                        // Ctrl+Shift+T: reopen last closed tab
                        if event.modifiers.control && event.modifiers.shift && event.text == "T" {
                            root.reopen-closed-tab();
                            return accept;
                        }
                        // Ctrl+T: open new web tab (only when not on Scene/3D tab)
                        if event.modifiers.control && event.text == "t" && root.center-active-tab > 0 {
                            root.open-web-tab("https://eustress.dev/learn");
                            return accept;
                        }
                        // Ctrl+L: focus URL bar (when on web tab)
                        if event.modifiers.control && event.text == "l" {
                            if root.active-tab-type == "web" {
                                // URL bar focus handled by Rust
                                return accept;
                            }
                        }
                        return reject;
                    }
                    
                    // ── ScreenGui overlay ─────────────────────────────────────
                    // Rendered FIRST so viewport widgets (Default, FPS) appear on top.
                    for elem[i] in root.gui-elements: Rectangle {
                        x: elem.x * 1px;
                        y: elem.y * 1px;
                        width: elem.width * 1px;
                        height: elem.height * 1px;
                        visible: elem.visible;
                        background: rgba(elem.bg-r * 255, elem.bg-g * 255, elem.bg-b * 255, elem.bg-a * 255);
                        border-width: elem.border-size * 1px;
                        border-color: rgba(elem.border-r * 255, elem.border-g * 255, elem.border-b * 255, elem.border-a * 255);
                        border-radius: elem.corner-radius * 1px;
                        clip: elem.clip-children;

                        if elem.has-image: Image {
                            width: 100%;
                            height: 100%;
                            source: elem.image-source;
                            image-fit: contain;
                        }

                        if elem.text != "": Text {
                            x: elem.scroll-x * -1px;
                            y: elem.scroll-y * -1px;
                            width: 100%;
                            height: 100%;
                            text: elem.text;
                            color: rgba(elem.text-r * 255, elem.text-g * 255, elem.text-b * 255, elem.text-a * 255);
                            font-size: max(elem.font-size * 1px, 8px);
                            horizontal-alignment: elem.text-align == "left" ? left :
                                                  elem.text-align == "right" ? right : center;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }

                    // 3D Viewport (shown when Space1 / scene tab is active)
                    // The Bevy 3D camera renders directly to the window; this area is transparent
                    // so the 3D scene shows through. The Slint overlay composites UI on top.
                    if root.active-tab-type == "scene": viewport-area := Rectangle {
                        background: transparent;
                        
                        // Layout Preset Selector (top-left)
                        LayoutPresetSelector {
                            x: 8px;
                            y: 8px;
                            current-preset-index: root.current-layout-preset;
                            dropdown-open: root.show-layout-dropdown;

                            request-open-dropdown(abs-x, abs-y) => {
                                root.layout-dropdown-x = abs-x;
                                root.layout-dropdown-y = abs-y;
                                root.show-layout-dropdown = true;
                            }
                        }
                        
                        // Performance Overlay (top-right)
                        if root.show-performance-overlay: PerformanceOverlay {
                            x: parent.width - self.width - 8px;
                            y: 8px;
                            fps: root.current-fps;
                            frame-time-ms: root.current-frame-time;
                            entity-count: root.current-entity-count;
                        }
                        
                        // Axis orientation gizmo (bottom-right of viewport)
                        Rectangle {
                            x: parent.width - self.width - 12px;
                            y: parent.height - self.height - 12px;
                            width: 80px;
                            height: 80px;
                            background: #00000040;
                            border-radius: 6px;

                            // X axis endpoint + label (red)
                            Rectangle {
                                x: (40 + root.gizmo-ax * 28 - 3) * 1px;
                                y: (40 + root.gizmo-ay * 28 - 3) * 1px;
                                width: 6px; height: 6px;
                                border-radius: 3px;
                                background: #ef5350;
                            }
                            Text {
                                x: (40 + root.gizmo-ax * 28 + 4) * 1px;
                                y: (40 + root.gizmo-ay * 28 - 6) * 1px;
                                text: "X";
                                color: #ef5350;
                                font-size: 9px;
                                font-weight: 700;
                            }

                            // Y axis endpoint + label (green)
                            Rectangle {
                                x: (40 + root.gizmo-bx * 28 - 3) * 1px;
                                y: (40 + root.gizmo-by * 28 - 3) * 1px;
                                width: 6px; height: 6px;
                                border-radius: 3px;
                                background: #66bb6a;
                            }
                            Text {
                                x: (40 + root.gizmo-bx * 28 + 4) * 1px;
                                y: (40 + root.gizmo-by * 28 - 6) * 1px;
                                text: "Y";
                                color: #66bb6a;
                                font-size: 9px;
                                font-weight: 700;
                            }

                            // Z axis endpoint + label (blue)
                            Rectangle {
                                x: (40 + root.gizmo-cx * 28 - 3) * 1px;
                                y: (40 + root.gizmo-cy * 28 - 3) * 1px;
                                width: 6px; height: 6px;
                                border-radius: 3px;
                                background: #42a5f5;
                            }
                            Text {
                                x: (40 + root.gizmo-cx * 28 + 4) * 1px;
                                y: (40 + root.gizmo-cy * 28 - 6) * 1px;
                                text: "Z";
                                color: #42a5f5;
                                font-size: 9px;
                                font-weight: 700;
                            }

                            // Center dot
                            Rectangle {
                                x: 38px; y: 38px;
                                width: 4px; height: 4px;
                                border-radius: 2px;
                                background: #ffffff80;
                            }
                        }

                        // Snap status — hidden (accessible via keybinds 1/2/3)
                        
                        // Play mode indicator with simulation clock
                        if root.play-state != "stopped": Rectangle {
                            x: (parent.width - self.width) / 2;
                            y: 8px;
                            width: 320px;
                            height: 32px;
                            background: root.play-state == "playing" ? #2d7d46 : #7d6d2d;
                            border-radius: 4px;

                            HorizontalBox {
                                padding: 8px;
                                spacing: 12px;
                                alignment: center;
                                Text {
                                    text: root.play-state == "playing" ? "▶ Playing" : "⏸ Paused";
                                    color: white;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: root.sim-clock-display;
                                    color: #ffffffcc;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                    
                    // Script/Code Editor (shown when a script or code tab is active)
                    if root.active-tab-type == "script" || root.active-tab-type == "code": ScriptEditor {
                        show-tab-bar: false;
                        tabs: root.center-tabs;
                        active-tab: root.center-active-tab - 1;
                        current-content: root.script-editor-content;
                        line-numbers-text: root.script-line-numbers;
                        line-numbers-array: root.script-line-numbers-array;
                        scroll-to-top-trigger <=> root.script-scroll-to-top;
                        highlight-lines: root.script-highlight-lines;
                        has-highlights: root.script-highlight-lines.length > 0;
                        token-spans: root.script-token-spans;
                        has-token-spans: root.script-token-spans.length > 0;
                        diagnostic-spans: root.script-diagnostic-spans;

                        on-tab-selected(idx) => {
                            root.center-active-tab = idx + 1;
                            root.select-center-tab(idx + 1);
                        }
                        on-tab-closed(idx) => {
                            root.close-center-tab(idx);
                        }
                        on-content-changed(text) => {
                            root.script-content-changed(text);
                        }
                        on-toggle-mode(idx) => {
                            root.toggle-mode(idx + 1);
                        }
                        on-go-to-definition(line, col) => { root.script-go-to-definition(line, col); }
                        on-find-references(line, col) => { root.script-find-references(line, col); }
                        on-save => { }
                        on-build => {
                            if root.center-active-tab > 0 && root.center-active-tab <= root.center-tabs.length {
                                root.build-script(root.center-tabs[root.center-active-tab - 1].entity-id);
                            }
                        }
                        on-summarize => {
                            if root.center-active-tab > 0 && root.center-active-tab <= root.center-tabs.length {
                                root.summarize-script(root.center-tabs[root.center-active-tab - 1].entity-id);
                            }
                        }
                    }
                    
                    // Web Browser (shown when a web tab is active)
                    if root.active-tab-type == "web": WebBrowser {
                        url: root.web-url-bar;
                        loading: root.web-loading;
                        can-go-back: root.web-can-go-back;
                        can-go-forward: root.web-can-go-forward;
                        secure: root.web-secure;
                        has-url: root.web-has-url;
                        page-image: root.web-content-image;
                        url-bar-text <=> root.web-url-bar;
                        
                        navigate(url) => { root.web-navigate(url); }
                        go-back => { root.web-go-back(); }
                        go-forward => { root.web-go-forward(); }
                        refresh => { root.web-refresh(); }
                    }
                    
                    
                    // Image Viewer (shown for "image" tab type)
                    if root.active-tab-type == "image": Rectangle {
                        background: #181825;
                        
                        VerticalLayout {
                            alignment: center;
                            Image {
                                width: 48px;
                                height: 48px;
                                source: @image-url("../../assets/icons/ui/image.svg");
                                image-fit: contain;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: "Image Viewer";
                                color: Theme.text-secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                            }
                        }
                    }
                    
                    // Video Player (shown for "video" tab type)
                    if root.active-tab-type == "video": Rectangle {
                        background: #11111b;
                        
                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: "Video Player";
                                color: Theme.text-secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: "WebView-based playback";
                                color: #45475a;
                                font-size: 12px;
                                horizontal-alignment: center;
                            }
                        }
                    }
                    
                    // Document Viewer (shown for "document" tab type)
                    if root.active-tab-type == "document": Rectangle {
                        background: Theme.panel-background;
                        
                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: "Document Viewer";
                                color: Theme.text-secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                            }
                        }
                    }
                    
                    // Parameters Editor (shown for "parameters" tab type)
                    if root.active-tab-type == "parameters": Rectangle {
                        background: Theme.panel-background;

                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: "Parameters Editor";
                                color: Theme.text-secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    // API Reference Browser (shown for "api" tab type)
                    if root.active-tab-type == "api": ApiReferencePanel {
                        entries: root.api-entries;
                        categories: root.api-categories;
                        total-count: root.api-total-count;
                        filtered-count: root.api-filtered-count;
                        selected-category: root.api-selected-category;

                        search-changed(text) => { root.api-search-changed(text); }
                        category-selected(cat) => {
                            root.api-selected-category = cat;
                            root.api-category-selected(cat);
                        }
                        language-filter-changed(lang) => {
                            root.api-language-filter = lang;
                            root.api-language-filter-changed(lang);
                        }
                        copy-example(ex) => { root.api-copy-example(ex); }
                    }
                }
                // ── Box Selection Overlay ──────────────────────────
                // Renders on top of 3D viewport during drag-to-select
                if root.box-select-visible: Rectangle {
                    x: root.box-select-x * 1px;
                    y: root.box-select-y * 1px;
                    width: root.box-select-w * 1px;
                    height: root.box-select-h * 1px;
                    background: #59bbff26;
                    border-width: 1px;
                    border-color: #59bbffcc;
                    border-radius: 1px;
                }

                } // close viewport-sizer
                }
            }

            // ================================================================
            // Right Panel (Properties, History, Soul, Workshop)
            // ================================================================
            if root.show-properties || root.show-history || root.show-soul-panel || root.show-script-editor || root.show-workshop-panel: Rectangle {
                width: root.right-panel-width;
                background: Theme.panel-background;
                border-width: 0px;
                // Left edge separator
                Rectangle {
                    x: 0px;
                    width: 1px;
                    height: 100%;
                    background: Theme.border-color;
                }
                
                // Resize handle — 8px interactive strip on the left edge with hover highlight
                right-resize := Rectangle {
                    x: -4px;
                    width: 8px;
                    height: 100%;
                    background: right-resize-ta.has-hover || right-resize-ta.pressed ? Theme.border-focus : transparent;
                    opacity: right-resize-ta.pressed ? 1.0 : 0.5;
                    
                    right-resize-ta := TouchArea {
                        mouse-cursor: ew-resize;
                        moved => {
                            root.right-panel-width = max(200px, min(700px, root.right-panel-width - (self.mouse-x - self.pressed-x)));
                        }
                    }
                }
                
                VerticalLayout {
                    spacing: 0px;
                    
                    // Tab bar
                    Rectangle {
                        height: 30px;
                        background: Theme.header-background;
                        
                        HorizontalLayout {
                            padding-left: 2px;
                            padding-right: 2px;
                            padding-top: 2px;
                            spacing: 1px;
                            
                            Rectangle {
                                horizontal-stretch: 1;
                                background: root.right-tab-index == 0 ? Theme.panel-background : Theme.tab-inactive;
                                border-top-left-radius: 4px;
                                border-top-right-radius: 4px;

                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.right-tab-index = 0; }
                                }

                                HorizontalLayout {
                                    padding-left: 6px;
                                    padding-right: 6px;
                                    alignment: center;
                                    Text {
                                        text: "Properties";
                                        color: root.right-tab-index == 0 ? Theme.text-primary : Theme.text-secondary;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                background: root.right-tab-index == 1 ? Theme.panel-background : Theme.tab-inactive;
                                border-top-left-radius: 4px;
                                border-top-right-radius: 4px;

                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.right-tab-index = 1; }
                                }

                                HorizontalLayout {
                                    padding-left: 6px;
                                    padding-right: 6px;
                                    alignment: center;
                                    Text {
                                        text: "History";
                                        color: root.right-tab-index == 1 ? Theme.text-primary : Theme.text-secondary;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                background: root.right-tab-index == 2 ? Theme.panel-background : Theme.tab-inactive;
                                border-top-left-radius: 4px;
                                border-top-right-radius: 4px;

                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.right-tab-index = 2; }
                                }

                                HorizontalLayout {
                                    padding-left: 6px;
                                    padding-right: 6px;
                                    alignment: center;
                                    Text {
                                        text: "Soul";
                                        color: root.right-tab-index == 2 ? Theme.text-primary : Theme.text-secondary;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                background: root.right-tab-index == 3 ? Theme.panel-background : Theme.tab-inactive;
                                border-top-left-radius: 4px;
                                border-top-right-radius: 4px;

                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.right-tab-index = 3; }
                                }

                                HorizontalLayout {
                                    padding-left: 6px;
                                    padding-right: 6px;
                                    alignment: center;
                                    Text {
                                        text: "Workshop";
                                        color: root.right-tab-index == 3 ? Theme.text-primary : Theme.text-secondary;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            // Overflow chevron → dropdown with additional panels
                            // (mirrors the left-panel Terrain overflow pattern).
                            // Houses the Problems panel; we can add more as other
                            // analyzer surfaces come online.
                            Rectangle {
                                width: 24px;
                                background: right-more-touch.has-hover ? Theme.button-hover : Theme.tab-inactive;
                                border-top-left-radius: 4px;
                                border-top-right-radius: 4px;

                                right-more-touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { right-more-popup.show(); }
                                }

                                // Error badge overlay on the chevron — makes it
                                // obvious when the Problems panel has unseen
                                // errors without needing the user to open it.
                                if root.problem-error-count > 0 && root.right-tab-index != 4: Rectangle {
                                    x: 2px; y: 2px;
                                    width: 8px; height: 8px;
                                    background: #e53935;
                                    border-radius: 4px;
                                }

                                Image {
                                    width: 12px;
                                    height: 12px;
                                    source: @image-url("../../assets/icons/ui/chevron-down.svg");
                                    image-fit: contain;
                                    colorize: Theme.text-secondary;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                right-more-popup := PopupWindow {
                                    x: -120px;
                                    y: parent.height;
                                    width: 160px;

                                    Rectangle {
                                        background: #1e1e1e;
                                        border-radius: 4px;
                                        border-width: 1px;
                                        border-color: #3a3a3a;
                                        drop-shadow-blur: 8px;
                                        drop-shadow-color: #00000080;
                                        width: 160px;

                                        VerticalLayout {
                                            padding-top: 4px;
                                            padding-bottom: 4px;

                                            // Problems toggle
                                            Rectangle {
                                                height: 26px;
                                                background: problems-item-touch.has-hover ? Theme.button-hover : transparent;

                                                problems-item-touch := TouchArea {
                                                    mouse-cursor: pointer;
                                                    clicked => { root.right-tab-index = 4; }
                                                }

                                                HorizontalLayout {
                                                    padding-left: 10px;
                                                    padding-right: 10px;
                                                    spacing: 6px;

                                                    Text {
                                                        text: "Problems";
                                                        color: root.right-tab-index == 4 ? Theme.text-primary : Theme.text-secondary;
                                                        font-size: 11px;
                                                        vertical-alignment: center;
                                                        horizontal-stretch: 1;
                                                    }
                                                    if root.problem-error-count > 0: Text {
                                                        text: root.problem-error-count;
                                                        color: #ef5350;
                                                        font-size: 10px;
                                                        vertical-alignment: center;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                        }
                    }
                    
                    // Tab content (must stretch to fill remaining space so inner ScrollView works)
                    Rectangle {
                        vertical-stretch: 1;
                        clip: true;
                        background: Theme.panel-background;
                        
                        if root.right-tab-index == 0: props-panel := PropertiesPanel {
                            selected-count: root.selected-count;
                            selected-class: root.selected-class;
                            selected-icon: root.selected-icon;
                            properties: root.entity-properties;
                            show-help-icons: root.show-help-icons;
                            help-opens-in-tab: root.help-opens-in-tab;
                            on-property-changed(name, value) => { root.property-changed(name, value); }
                            on-section-toggle(category) => { root.section-toggle(category); }
                            on-open-learn-url(url) => { root.open-learn-url(url); }
                            on-input-focus-changed(focused) => { root.any-input-has-focus = focused; }
                        }
                        
                        if root.right-tab-index == 1: HistoryPanel {
                            history: root.history-entries;
                            current-index: root.history-current-index;
                            on-undo => { root.undo(); }
                            on-redo => { root.redo(); }
                            on-jump-to(id) => { root.history-jump-to(id); }
                            on-clear-history => { root.history-clear(); }
                        }
                        
                        if root.right-tab-index == 2: SoulPanel {
                            scripts: root.soul-scripts;
                            selected-script: root.soul-selected-script;
                            api-key-status: root.soul-api-key-status;
                            rune-count: root.soul-rune-count;
                            luau-server-count: root.soul-luau-server-count;
                            luau-client-count: root.soul-luau-client-count;
                            luau-module-count: root.soul-luau-module-count;
                            on-select-script(id) => { root.soul-selected-script = id; }
                            on-build-script(id) => { root.build-script(id); }
                            on-open-script(id) => { root.open-script(id); }
                            on-build-all => { root.soul-build-all(); }
                            on-configure-api => { root.settings-active-tab = 3; root.show-settings-dialog = true; }
                            on-script-context-menu(id, x, y) => {
                                root.show-context-menu = true;
                                root.context-menu-x = x;
                                root.context-menu-y = y;
                                root.context-menu-target-id = id;
                                root.context-menu-target-type = "soul-script";
                                root.context-menu-items = [
                                    { id: "soul-reveal", label: "Reveal in Explorer", shortcut: "", icon: @image-url("../../assets/icons/folder.svg"), enabled: true, separator-after: false },
                                    { id: "soul-open-summary", label: "Open Summary", shortcut: "", icon: @image-url("../../assets/icons/ui/new-file.svg"), enabled: true, separator-after: false },
                                    { id: "soul-open-code", label: "Open Code", shortcut: "", icon: @image-url("../../assets/icons/script.svg"), enabled: true, separator-after: true },
                                    { id: "soul-build", label: "Build", shortcut: "", icon: @image-url("../../assets/icons/ui/settings.svg"), enabled: true, separator-after: true },
                                    { id: "copy-path", label: "Copy Path", shortcut: "", icon: @image-url("../../assets/icons/ui/link.svg"), enabled: true, separator-after: false },
                                ];
                            }
                        }
                        
                        if root.right-tab-index == 3: WorkshopPanel {
                            messages: root.workshop-messages;
                            input-text <=> root.workshop-input-text;
                            // Reflect chat-input focus into the root-level
                            // `any-input-has-focus` so Bevy's WASD / shortcut
                            // keys stop firing while the user types.
                            changed input-has-focus => { root.any-input-has-focus = self.input-has-focus; }
                            pipeline-steps: root.workshop-pipeline-steps;
                            pipeline-state: root.workshop-pipeline-state;
                            product-name: root.workshop-product-name;
                            total-artifacts: root.workshop-total-artifacts;
                            estimated-cost: root.workshop-estimated-cost;
                            api-key-valid: root.workshop-api-key-valid;
                            active-modes-text: root.workshop-active-modes-text;
                            tool-count: root.workshop-tool-count;
                            active-tool: root.workshop-active-tool;

                            // Session tab strip — live session list +
                            // highlighted active tab. Host updates
                            // `workshop-past-conversations` via a sync
                            // system that rescans SoulService/Workshop/
                            // every few hundred ms.
                            past-conversations: root.workshop-past-conversations;
                            active-session-id: root.workshop-active-session-id;
                            on-close-conversation(id) => { root.workshop-close-conversation(id); }
                            on-reorder-tab(id, target) => { root.workshop-reorder-tab(id, target); }

                            // @ Mention autocomplete plumbing
                            mention-items: root.workshop-mention-items;
                            mention-popup-visible <=> root.workshop-mention-popup-visible;
                            mention-selected-index <=> root.workshop-mention-selected-index;
                            mention-query <=> root.workshop-mention-query;

                            on-send-message(text) => { root.workshop-send-message(text); }
                            on-approve-mcp(id) => { root.workshop-approve-mcp(id); }
                            on-skip-mcp(id) => { root.workshop-skip-mcp(id); }
                            on-edit-mcp(id) => { root.workshop-edit-mcp(id); }
                            on-open-artifact(path) => { root.workshop-open-artifact(path); }
                            on-start-pipeline() => { root.workshop-start-pipeline(); }
                            on-pause-pipeline() => { root.workshop-pause-pipeline(); }
                            on-resume-pipeline() => { root.workshop-resume-pipeline(); }
                            on-cancel-pipeline() => { root.workshop-cancel-pipeline(); }
                            on-configure-api() => { root.settings-active-tab = 3; root.show-settings-dialog = true; }
                            on-optimize-and-build() => { root.workshop-optimize-and-build(); }
                            on-execute-command(cmd) => { root.workshop-send-message(cmd); }
                            on-load-conversation(id) => { root.workshop-load-conversation(id); }
                            on-new-conversation() => { root.workshop-new-conversation(); }
                            on-mention-query-changed(text) => { root.workshop-mention-query-changed(text); }
                            on-mention-commit(index) => { root.workshop-mention-commit(index); }
                            on-mention-cancel() => { root.workshop-mention-cancel(); }
                        }

                        if root.right-tab-index == 4: ProblemsPanel {
                            items: root.problem-items;
                            error-count: root.problem-error-count;
                            warning-count: root.problem-warning-count;
                            can-fix-with-workshop: root.problems-can-fix-with-workshop;
                            jump-to(path, line, col) => { root.problems-jump-to(path, line, col); }
                            fix-with-workshop() => { root.problems-fix-with-workshop(); }
                        }

                    }
                }
            }
        }

        // ====================================================================
        // Bottom Area (Output Console + Command Bar)
        // ====================================================================
        if root.show-output: Rectangle {
            height: root.output-height;
            background: Theme.panel-background;
            border-width: 0px;
            // Top edge separator only
            Rectangle {
                y: 0px;
                width: 100%;
                height: 1px;
                background: Theme.border-color;
            }
            
            // Resize handle — 8px interactive strip on top edge with hover highlight
            Rectangle {
                y: -4px;
                width: 100%;
                height: 8px;
                background: output-resize-ta.has-hover || output-resize-ta.pressed ? Theme.border-focus : transparent;
                opacity: output-resize-ta.pressed ? 1.0 : 0.5;

                output-resize-ta := TouchArea {
                    mouse-cursor: ns-resize;
                    moved => {
                        root.output-height = max(100px, min(400px, root.output-height - (self.mouse-y - self.pressed-y)));
                    }
                }
            }
            
            // Output content (has its own integrated toolbar)
            OutputConsole {
                vertical-stretch: 1;
                logs: root.output-logs;
                all-text: root.output-all-text;
                source-filter <=> root.output-source-filter;
                show-info <=> root.output-show-info;
                show-warnings <=> root.output-show-warnings;
                show-errors <=> root.output-show-errors;
                show-debug <=> root.output-show-debug;
                // Clear must hit BOTH sides — the Slint-side lists (so the
                // visible output blanks instantly) AND the Rust-side
                // `OutputConsole.entries` via `clear-script-output`.
                // Without the latter, the next sync push re-floods the
                // panel with every entry we "cleared" a moment earlier.
                on-clear => {
                    root.output-logs = [];
                    root.output-all-text = "";
                    root.clear-script-output();
                }
                on-close => { root.show-output = false; }
                on-open-path(msg) => { root.open-path-from-log(msg); }
            }
        }

        // ====================================================================
        // Command Bar (docked at very bottom)
        // ====================================================================
        cmd-bar := CommandBar {
            command-text <=> root.command-text;
            language <=> root.command-language;

            on-execute(language, script) => {
                root.execute-script(language, script);
            }
            on-close => { root.show-command-bar = false; }
            on-text-changed(text) => { root.command-text = text; }
            on-clear-output => { root.clear-script-output(); }
        }

    }

    // ========================================================================
    // Overlays and Dialogs
    // ========================================================================
    
    
    // Notifications (toast messages) — only rendered when the queue is
    // non-empty. Previous version was always-on and used `self.height` in
    // its y-binding, which triggered a Slint property-recursion crash at
    // startup.
    if root.notifications.length > 0: Notifications {
        width: 320px;
        x: parent.width - 336px;
        y: 80px;
        height: parent.height
            - (root.show-output ? root.output-height : 0px)
            - 36px   // command bar
            - 80px   // top offset matches self.y
            - 16px;  // bottom padding
        notifications: root.notifications;
        on-dismiss(id) => { root.dismiss-notification(id); }
    }
    
    // Layout dropdown overlay (click anywhere outside to dismiss)
    if root.show-layout-dropdown: Rectangle {
        width: root.width;
        height: root.height;
        background: transparent;

        // Backdrop — click anywhere outside to dismiss
        TouchArea {
            clicked => { root.show-layout-dropdown = false; }
        }

        LayoutDropdownMenu {
            x: root.layout-dropdown-x * 1px;
            y: root.layout-dropdown-y * 1px;
            current-preset-index: root.current-layout-preset;

            preset-selected(index, preset) => {
                root.current-layout-preset = index;
                root.show-explorer = preset.show-explorer;
                root.show-properties = preset.show-properties;
                root.show-output = preset.show-output;
                root.show-toolbox = preset.show-toolbox;
                root.show-assets = preset.show-assets;
                root.show-history = preset.show-history;
                root.show-soul-panel = preset.show-soul-panel;
                root.left-panel-width = preset.left-panel-width * 1px;
                root.right-panel-width = preset.right-panel-width * 1px;
                root.output-height = preset.output-height * 1px;
                root.left-tab-index = preset.left-tab-index;
                root.right-tab-index = preset.right-tab-index;
                root.apply-layout-preset(root.current-layout-preset);
                root.show-layout-dropdown = false;
            }
            load-layout-from-file => {
                root.load-layout-from-file();
                root.show-layout-dropdown = false;
            }
            reset-to-factory => {
                root.reset-layout-to-default();
                root.show-layout-dropdown = false;
            }
            close => { root.show-layout-dropdown = false; }
        }
    }

    // Context menu backdrop (click anywhere outside to dismiss)
    // Must be clip:false so the menu can overflow Explorer/Properties panel boundaries
    if root.show-context-menu: Rectangle {
        width: root.width;
        height: root.height;
        background: transparent;

        // Backdrop — click anywhere outside to dismiss
        TouchArea {
            clicked => { root.show-context-menu = false; }
        }

        // Context menu — clamped to viewport bounds
        ContextMenu {
            x: min(root.context-menu-x, root.width - 228px);
            y: min(max(root.context-menu-y, 4px), root.height - 320px);
            items: root.context-menu-items;
            on-action(action) => {
                root.context-action(action);
                root.show-context-menu = false;
            }
            on-close => { root.show-context-menu = false; }
        }
    }
    
    // Publish dialog
    if root.show-publish-dialog: PublishDialog {
        experience-name <=> root.publish-experience-name;
        description <=> root.publish-description;
        genre <=> root.publish-genre;
        is-public <=> root.publish-is-public;
        open-source <=> root.publish-open-source;
        studio-editable <=> root.publish-studio-editable;
        spaces: root.publish-spaces;
        tree-nodes: root.publish-tree-nodes;
        pak-size-estimate: root.publish-pak-size;
        publish-target: root.publish-target;
        sync-status: root.sync-status;
        is-update: root.publish-is-update;
        publish-mode: root.publish-mode;
        on-publish(experience_name, description, genre, is_public, open_source, studio_editable, as_new) => {
            root.show-publish-dialog = false;
            root.publish(experience_name, description, genre, is_public, open_source, studio_editable, as_new);
        }
        on-close => { root.show-publish-dialog = false; }
    }
    
    // Login dialog — SPI (Sign in with Private Identity)
    if root.show-login-dialog: LoginDialog {
        identity-path: root.login-identity-path;
        error-message: root.login-error;
        status-message: root.login-status;
        is-loading: root.login-loading;
        on-browse-identity => { root.browse-identity(); }
        on-login => { root.login-with-identity(); }
        on-close => {
            root.show-login-dialog = false;
            root.login-error = "";
            root.login-status = "";
            root.login-identity-path = "";
        }
    }
    
    // Exit confirmation
    if root.show-exit-confirmation: ExitConfirmationDialog {
        scene-name: root.scene-name;
        on-save-and-exit => {
            root.save-scene();
            root.show-exit-confirmation = false;
            root.force-exit();
        }
        on-exit-without-saving => {
            root.show-exit-confirmation = false;
            root.force-exit();
        }
        on-cancel => { root.show-exit-confirmation = false; }
    }
    
    // Settings dialog
    if root.show-settings-dialog: SettingsDialog {
        active-tab <=> root.settings-active-tab;
        show-help-icons <=> root.show-help-icons;
        help-opens-in-tab <=> root.help-opens-in-tab;
        soul-api-key <=> root.soul-api-key;
        soul-api-key-valid: root.soul-api-key-valid;
        notifications-enabled <=> root.notifications-enabled;
        notifications-show-dismiss <=> root.notifications-show-dismiss;
        notifications-mute-file <=> root.notifications-mute-file;
        notifications-mute-script <=> root.notifications-mute-script;
        notifications-mute-editor <=> root.notifications-mute-editor;
        notifications-mute-simulation <=> root.notifications-mute-simulation;
        notifications-mute-network <=> root.notifications-mute-network;
        notifications-mute-task <=> root.notifications-mute-task;
        notifications-mute-general <=> root.notifications-mute-general;
        notifications-mute-info <=> root.notifications-mute-info;
        notifications-mute-warning <=> root.notifications-mute-warning;
        on-help-icons-changed(val) => { root.help-icons-changed(val); }
        on-help-opens-in-tab-changed(val) => { root.help-opens-in-tab-changed(val); }
        on-notifications-changed => { root.notification-settings-changed(); }
        on-save => {
            // Commit the typed API key to Bevy so Soul/Workshop panels stop
            // showing the Configure banner. Settings dialog already wrote
            // root.soul-api-key via two-way binding.
            root.soul-api-key-saved();
            root.show-settings-dialog = false;
        }
        on-close => { root.show-settings-dialog = false; }
    }
    
    // Theme Editor panel (floating overlay — draggable)
    if root.show-theme-editor: theme-panel := Rectangle {
        property <length> drag-x: parent.width - 280px;
        property <length> drag-y: parent.height - 320px;
        
        x: self.drag-x;
        y: self.drag-y;
        width: 260px;
        height: 300px;
        background: Theme.panel-background;
        border-radius: 8px;
        border-width: 1px;
        border-color: Theme.border-color;
        drop-shadow-blur: 12px;
        drop-shadow-color: #00000060;
        
        VerticalBox {
            padding: 0px;
            
            // Draggable header with close button
            Rectangle {
                height: 32px;
                background: Theme.header-background;
                border-top-left-radius: 8px;
                border-top-right-radius: 8px;
                
                theme-drag := TouchArea {
                    mouse-cursor: move;
                    moved => {
                        if self.pressed {
                            theme-panel.drag-x += self.mouse-x - self.pressed-x;
                            theme-panel.drag-y += self.mouse-y - self.pressed-y;
                        }
                    }
                }
                
                HorizontalBox {
                    padding: 8px;
                    
                    Image {
                        width: 16px;
                        height: 16px;
                        source: @image-url("../../assets/icons/ui/palette.svg");
                        image-fit: contain;
                        vertical-alignment: center;
                    }
                    Text {
                        text: " Theme Settings";
                        color: Theme.text-primary;
                        font-weight: 600;
                        horizontal-stretch: 1;
                    }
                    
                    TouchArea {
                        width: 20px;
                        clicked => { root.show-theme-editor = false; }
                        
                        Image {
                            width: 12px;
                            height: 12px;
                            source: @image-url("../../assets/icons/ui/close.svg");
                            image-fit: contain;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
            
            ThemeEditor {
                dark-mode: root.dark-theme;
                high-contrast: root.high-contrast-mode;
                ui-scale: root.ui-scale;
                
                theme-changed => {
                    root.dark-theme = self.dark-mode;
                    root.high-contrast-mode = self.high-contrast;
                    root.ui-scale = self.ui-scale;
                }
                
                apply-theme => {
                    root.apply-theme-settings(root.dark-theme, root.high-contrast-mode, root.ui-scale);
                    root.show-theme-editor = false;
                }
            }
        }
    }
    
    // Find dialog
    if root.show-find-dialog: FindDialog {
        on-close => { root.show-find-dialog = false; }
    }
    
    // Forge connect dialog
    if root.show-forge-connect-dialog: ForgeConnectDialog {
        server-url <=> root.forge-server-url;
        api-key <=> root.forge-api-key;
        on-connect => { root.connect-forge(); }
        on-close => { root.show-forge-connect-dialog = false; }
    }
    
    // Stress test dialog
    if root.show-stress-test-dialog: StressTestDialog {
        running: root.stress-running;
        progress: root.stress-progress;
        status: root.stress-status;
        total-messages: root.stress-total-messages;
        avg-latency: root.stress-avg-latency;
        errors: root.stress-errors;
        on-start => {
            root.start-stress-test(
                self.client-count,
                self.message-rate,
                self.duration-seconds,
                self.simulate-movement,
                self.simulate-interactions,
            );
        }
        on-stop => { root.stop-stress-test(); }
        on-close => { root.show-stress-test-dialog = false; }
    }
    
    // Data sources dialog
    if root.show-global-sources-window: DataSourcesDialog {
        on-close => { root.show-global-sources-window = false; }
    }
    
    // Sync domain dialog
    if root.show-sync-domain-dialog: SyncDomainDialog {
        on-sync => { root.show-sync-domain-dialog = false; }
        on-close => { root.show-sync-domain-dialog = false; }
    }

    // Keyboard shortcuts dialog
    if root.show-keybindings-dialog: KeybindingsDialog {
        on-close => { root.show-keybindings-dialog = false; }
    }

    // About Eustress Engine dialog
    if root.show-about-dialog: AboutDialog {
        version: root.about-version;
        commit: root.about-commit;
        build-date: root.about-build-date;
        open-url(u) => { root.open-url(u); }
        on-close => { root.show-about-dialog = false; }
    }

    // Simulation settings dialog
    if root.show-simulation-settings-dialog: SimulationSettingsDialog {
        time-scale-preset <=> root.sim-time-scale-preset;
        custom-time-scale <=> root.sim-custom-time-scale;
        tick-rate <=> root.sim-tick-rate;
        max-ticks-per-frame <=> root.sim-max-ticks-per-frame;
        auto-start <=> root.sim-auto-start;
        recording-enabled <=> root.sim-recording-enabled;
        output-dir <=> root.sim-output-dir;
        auto-export <=> root.sim-auto-export;
        watchpoints <=> root.sim-watchpoints;
        output-bindings <=> root.sim-output-bindings;

        on-close => { root.show-simulation-settings-dialog = false; }
        on-save => { root.save-simulation-settings(); }
        on-add-watchpoint => { root.add-sim-watchpoint(); }
        on-remove-watchpoint(i) => { root.remove-sim-watchpoint(i); }
        on-add-output-binding => { root.add-sim-output-binding(); }
        on-remove-output-binding(i) => { root.remove-sim-output-binding(i); }
    }

    // (Duplicate hand-rolled context menu removed. The single source of
    // truth for the right-click popup is the `ContextMenu` component
    // invoked at the top of this `StudioWindow` — see around line 2438.
    // Keeping this placeholder comment so a future diff reader knows why
    // there isn't a second overlay here.)
}
