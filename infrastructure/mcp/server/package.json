{
  "name": "@eustress/mcp-server",
  "version": "0.2.1",
  "description": "Model Context Protocol server for Eustress Engine — exposes Universe Spaces, Rune scripts, entities, assets, and git state to any MCP-compatible AI client (Windsurf, Claude Desktop, Cursor, Zed).",
  "bin": {
    "eustress-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "eustress",
    "rune",
    "game-engine",
    "windsurf",
    "anthropic",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eustressengine/eustress.git",
    "directory": "infrastructure/mcp/server"
  },
  "homepage": "https://eustress.dev/learn#mcp",
  "bugs": {
    "url": "https://github.com/eustressengine/eustress/issues"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^3.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
