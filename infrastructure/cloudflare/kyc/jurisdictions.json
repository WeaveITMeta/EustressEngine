{
  "root": "Global KYC Compliance Framework (IRS QI Approved)",
  "version": "1.0",
  "lcd_rules": {
    "natural_persons": "Government-issued photo ID (passport, national ID, driver's license with photo, or local equivalent)",
    "legal_entities": "Certificate of incorporation/registration + beneficial-owner photo IDs",
    "default_verification": "In-person originals",
    "non_face_to_face": "Certified true copies, reliance on another IRS-approved KYC jurisdiction, or electronic/video methods only if the specific jurisdiction explicitly permits it",
    "retention_years": 7,
    "minors": {
      "default": "Same as adults — no age distinction in IRS PDFs",
      "exceptions": {
        "AU": "birth_certificate_under_21_allowed"
      }
    }
  },
