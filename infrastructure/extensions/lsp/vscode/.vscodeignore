.vscode/**
.vscode-test/**
.vscode-test-web/**
src/**
.gitignore
.yarnrc
vsc-extension-quickstart.md
**/tsconfig.json
**/.eslintrc.json
**/*.map
**/*.ts
!out/*.js
# esbuild bundles every runtime dep into out/extension.js, so we ship zero
# node_modules/ in the VSIX. Massive size reduction + no transitive-dep
# resolution issues (no more "Cannot find module 'balanced-match'" from
# hoisted packages that vsce forgot to include).
node_modules/**
