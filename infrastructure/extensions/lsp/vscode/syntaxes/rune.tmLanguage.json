{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Rune",
  "scopeName": "source.rune",
  "fileTypes": ["rune"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#functions" },
    { "include": "#attributes" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.rune",
          "match": "//.*$"
        },
        {
          "name": "comment.block.rune",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [{ "include": "#comments" }]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.rune",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.rune",
              "match": "\\\\([\\\\\"nrt0'\"]|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\})"
            }
          ]
        },
        {
          "name": "string.quoted.single.rune",
          "match": "'([^'\\\\]|\\\\.)'"
        },
        {
          "name": "string.template.rune",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "meta.template.expression.rune",
              "begin": "\\$\\{",
              "end": "\\}",
              "patterns": [{ "include": "$self" }]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.rune",
          "match": "\\b\\d[\\d_]*(\\.\\d[\\d_]*)?([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.hex.rune",
          "match": "\\b0x[0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.bin.rune",
          "match": "\\b0b[01_]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.rune",
          "match": "\\b(if|else|match|while|for|loop|break|continue|return|yield|select|await|async|in|not)\\b"
        },
        {
          "name": "keyword.declaration.rune",
          "match": "\\b(fn|let|const|struct|enum|impl|mod|use|pub)\\b"
        },
        {
          "name": "constant.language.rune",
          "match": "\\b(true|false|self)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.definition.rune",
          "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.rune" },
            "2": { "name": "entity.name.function.rune" }
          }
        },
        {
          "name": "meta.function.call.rune",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.rune" }
          }
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.rune",
          "begin": "#\\[",
          "end": "\\]",
          "patterns": [{ "include": "$self" }]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.rune",
          "match": "(==|!=|<=|>=|&&|\\|\\||<<|>>|=>|->|::|\\.\\.=?|[+\\-*/%=<>!&|^~?])"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.rune",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.other.rune",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
