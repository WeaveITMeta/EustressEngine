{
  "name": "rune-lsp",
  "displayName": "Eustress Rune LSP",
  "description": "Rune language features for Eustress Engine — connects to the LSP server bundled with Studio. Install Eustress Engine and this extension picks it up automatically. No separate download.",
  "version": "0.3.6",
  "publisher": "WeaveITMeta",
  "icon": "icons/rune.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "keywords": [
    "rune",
    "eustress",
    "lsp",
    "language-server",
    "game-engine"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eustressengine/eustress.git",
    "directory": "infrastructure/extensions/lsp/vscode"
  },
  "homepage": "https://eustress.dev/learn#ide-integration",
  "bugs": {
    "url": "https://github.com/eustressengine/eustress/issues"
  },
  "license": "MIT",
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:**/*.rune",
    "workspaceContains:**/.eustress/lsp.port"
  ],
  "contributes": {
    "languages": [
      {
        "id": "rune",
        "aliases": [
          "Rune",
          "rune"
        ],
        "extensions": [
          ".rune"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/rune.svg",
          "dark": "./icons/rune.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "rune",
        "scopeName": "source.rune",
        "path": "./syntaxes/rune.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Eustress Rune LSP",
      "properties": {
        "eustress.serverPath": {
          "type": "string",
          "default": "",
          "description": "Advanced. Normally you don't need this — Eustress Studio spawns the Rune LSP automatically and the extension discovers it over TCP. Set this only for headless / CI / no-engine setups where you want the extension to launch a standalone `eustress-lsp` itself. Resolution order when set: this path → `EUSTRESS_LSP_PATH` env var → workspace-local `target/release/eustress-lsp` → PATH."
        },
        "eustress.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP JSON-RPC traffic in the 'Eustress (Rune)' output channel. Useful for debugging; keep off in normal use."
        }
      }
    },
    "commands": [
      {
        "command": "eustress.restartServer",
        "title": "Eustress: Restart Rune Language Server"
      },
      {
        "command": "eustress.setupServer",
        "title": "Eustress: Set up Rune Language Server…"
      },
      {
        "command": "eustress.showServerPath",
        "title": "Eustress: Show resolved server path"
      },
      {
        "command": "eustress.showOutput",
        "title": "Eustress: Show Rune Language Server output"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "bun run bundle",
    "compile": "tsc -p ./ --noEmit",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18 --minify",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --out ../dist/"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.3.0"
  }
}
